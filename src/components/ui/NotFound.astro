---
import { getDictionary } from '../../i18n/dictionary';
import { getLocalizedPath } from '../../i18n/utils';

interface Props {
  locale: 'th' | 'en';
}

const { locale } = Astro.props;
const dict = await getDictionary(locale);

const heading = locale === 'th' ? 'ไม่พบหน้าที่คุณต้องการ' : 'Page not found';
const description =
  locale === 'th'
    ? 'หน้าที่คุณค้นหาอาจถูกย้าย ลบออก หรือไม่มีอยู่ในระบบ Green Office 2026'
    : 'The page you requested may have been moved, removed, or does not exist on Green Office 2026.';
const homeLabel = locale === 'th' ? 'กลับหน้าหลัก' : 'Back to home';
const dashboardLabel = dict.home.nav.dashboard;
const homeHref = getLocalizedPath(locale, '/');
const dashboardHref = getLocalizedPath(locale, '/dashboard/');
---

<section class="mx-auto flex min-h-[50vh] max-w-3xl flex-col items-center justify-center px-4 py-16 text-center">
  <p class="text-sm font-semibold uppercase tracking-widest text-primary" aria-hidden="true">404</p>
  <h1 class="mt-3 text-3xl font-bold text-gray-900 sm:text-4xl">{heading}</h1>
  <p class="mt-4 max-w-xl text-base text-gray-600">{description}</p>
  <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
    <a
      href={homeHref}
      class="inline-flex min-h-11 items-center rounded-stitch bg-primary px-5 py-2 text-sm font-semibold text-white transition hover:bg-primary-800 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
    >
      {homeLabel}
    </a>
    <a
      href={dashboardHref}
      class="inline-flex min-h-11 items-center rounded-stitch border border-primary/20 bg-white px-5 py-2 text-sm font-semibold text-primary transition hover:bg-primary-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
    >
      {dashboardLabel}
    </a>
  </div>
</section>
