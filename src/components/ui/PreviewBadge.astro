---
interface Props {
  locale?: 'th' | 'en';
}

const { locale = 'th' } = Astro.props;

const showPreviewBadge =
  import.meta.env.BASE_URL !== '/' ||
  import.meta.env.PUBLIC_PREVIEW_BADGE === 'true';
---
{showPreviewBadge && (
  <div
    role="status"
    aria-label={locale === 'th' ? 'สภาพแวดล้อมตัวอย่างบน GitHub Pages' : 'Preview environment on GitHub Pages'}
    class="fixed bottom-3 right-3 z-50 max-w-[calc(100vw-1.5rem)] rounded-md border border-amber-300 bg-amber-50 px-2.5 py-1.5 text-[11px] leading-tight text-amber-900 shadow-sm sm:bottom-4 sm:right-4 sm:text-xs"
  >
    <span class="block font-semibold uppercase tracking-wide">{locale === 'th' ? 'ตัวอย่าง' : 'Preview'}</span>
    <span class="block text-amber-800">GitHub Pages</span>
  </div>
)}
