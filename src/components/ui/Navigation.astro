---
import { getLocalizedPath, stripBasePath, stripLocalePrefix } from '../../i18n/utils';
import LanguageSwitcher from '../ui/LanguageSwitcher.astro';
import type { HomeNavStrings } from '../../i18n/dictionary';

interface Props {
  locale?: 'th' | 'en';
  t?: HomeNavStrings;
}

const locale = Astro.props.locale ?? 'en';
const t = Astro.props.t;
const navLabels = t ?? {
  home: 'Home',
  dashboard: 'Dashboard',
  categories: 'Categories',
  evidence: 'Evidence',
  documents: 'Documents',
  search: 'Search',
} as HomeNavStrings;

const siteName = 'Green Office 2026';

const navItems = [
  { href: '/', label: navLabels.home },
  { href: '/dashboard', label: navLabels.dashboard },
  { href: '/categories', label: navLabels.categories },
  { href: '/evidence', label: navLabels.evidence },
  { href: '/documents', label: navLabels.documents },
  { href: '/search', label: navLabels.search },
];

const pathWithoutBase = stripLocalePrefix(stripBasePath(Astro.url.pathname));
const currentPath = pathWithoutBase || '/';
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(`${href}/`);
---

<div class="bg-primary text-white">
  <div class="mx-auto flex min-h-10 max-w-6xl items-center justify-between gap-3 px-4 py-2 text-xs sm:text-sm">
    <p class="font-medium tracking-wide">
      Maejo University <span class="hidden text-primary-fixed sm:inline">· Green Office Platform</span>
    </p>
    <LanguageSwitcher />
  </div>
</div>

<nav class="border-b border-primary/10 bg-white px-4 py-3 shadow-sm" aria-label="Primary navigation">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4">
    <a href={getLocalizedPath(locale, '/')} class="group inline-flex min-w-0 items-center gap-3 text-left">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white shadow-sm">
        GO
      </span>
      <span class="min-w-0">
        <span class="block text-sm font-semibold leading-tight text-primary">{siteName}</span>
        <span class="block text-[11px] uppercase tracking-wide text-outline">Maejo University</span>
      </span>
    </a>

    <ul class="hidden items-center gap-1 text-sm lg:flex">
      {navItems.map((item) => (
        <li>
          <a
            href={getLocalizedPath(locale, item.href)}
            class:list={[
              'inline-flex min-h-10 items-center whitespace-nowrap rounded-md px-3 py-2 font-semibold transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2',
              isActive(item.href)
                ? 'bg-primary text-white'
                : 'text-on-surface hover:bg-primary-50 hover:text-primary',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <details class="relative lg:hidden">
      <summary class="flex min-h-10 cursor-pointer list-none items-center rounded-md border border-primary/20 px-3 py-2 text-sm font-semibold text-primary transition hover:bg-primary-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2">
        <span>Menu</span>
        <svg class="ml-2 h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 6h14M3 10h14M3 14h14" />
        </svg>
      </summary>
      <div class="absolute right-0 z-50 mt-2 w-64 rounded-lg border border-primary/15 bg-white p-2 shadow-xl">
        <ul class="space-y-1">
          {navItems.map((item) => (
            <li>
              <a
                href={getLocalizedPath(locale, item.href)}
                class:list={[
                  'flex min-h-11 items-center rounded-md px-3 py-2 text-sm font-semibold transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary',
                  isActive(item.href)
                    ? 'bg-primary text-white'
                    : 'text-on-surface hover:bg-primary-50 hover:text-primary',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </details>
  </div>
</nav>
