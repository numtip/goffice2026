---
import { getLocalizedPath, stripBasePath, stripLocalePrefix, getLocale } from '../../i18n/utils';
import LanguageSwitcher from '../ui/LanguageSwitcher.astro';
import SiteLogo from '../ui/SiteLogo.astro';
import type { HomeNavStrings } from '../../i18n/dictionary';

interface Props {
  locale?: 'th' | 'en';
  t?: HomeNavStrings;
  university?: string;
  platformLabel?: string;
}

const locale = Astro.props.locale ?? getLocale(Astro.url);
const navLabels = Astro.props.t ?? {
  home: 'Home',
  dashboard: 'Dashboard',
  categories: 'Categories',
  evidence: 'Evidence',
  documents: 'Documents',
  search: 'Search',
  menu: 'Menu',
} as HomeNavStrings;

const university = Astro.props.university ?? 'Maejo University';
const platformLabel = Astro.props.platformLabel ?? 'Green Office Platform';
const siteName = 'Green Office 2026';

const navItems = [
  { href: '/', label: navLabels.home },
  { href: '/dashboard', label: navLabels.dashboard },
  { href: '/categories', label: navLabels.categories },
  { href: '/evidence', label: navLabels.evidence },
  { href: '/documents', label: navLabels.documents },
  { href: '/search', label: navLabels.search },
];

const pathWithoutBase = stripLocalePrefix(stripBasePath(Astro.url.pathname));
const currentPath = pathWithoutBase || '/';
const isActive = (href: string) => {
  const normalized = href === '/' ? '/' : `${href.replace(/\/$/, '')}/`;
  if (normalized === '/') return currentPath === '/';
  return currentPath === normalized || currentPath.startsWith(normalized);
};
---

<div class="bg-primary text-white">
  <div class="mx-auto flex min-h-10 max-w-6xl items-center justify-between gap-3 px-4 py-2 text-xs sm:text-sm">
    <p class="font-medium tracking-wide">
      {university} <span class="hidden text-primary-fixed sm:inline">· {platformLabel}</span>
    </p>
    <LanguageSwitcher />
  </div>
</div>

<nav class="border-b border-primary/10 bg-white/95 px-4 py-3 shadow-sm backdrop-blur supports-[backdrop-filter]:bg-white/90" aria-label="Primary navigation">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4">
    <a href={getLocalizedPath(locale, '/')} class="group inline-flex min-w-0 items-center gap-3 text-left">
      <SiteLogo class="h-9 w-auto max-w-[7.5rem] shrink-0 object-contain object-left" width={36} height={29} />
      <span class="min-w-0">
        <span class="block text-sm font-semibold leading-tight text-primary">{siteName}</span>
        <span class="block text-[11px] uppercase tracking-wide text-outline">{university}</span>
      </span>
    </a>

    <ul class="hidden items-center gap-1 text-sm lg:flex">
      {navItems.map((item) => (
        <li>
          <a
            href={getLocalizedPath(locale, item.href)}
            class:list={[
              'inline-flex min-h-10 items-center whitespace-nowrap rounded-md px-3 py-2 font-semibold transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2',
              isActive(item.href)
                ? 'bg-primary text-white'
                : 'text-on-surface hover:bg-primary-50 hover:text-primary',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <details class="group relative lg:hidden" id="mobile-nav">
      <summary class="flex min-h-10 cursor-pointer list-none items-center rounded-md border border-primary/20 px-3 py-2 text-sm font-semibold text-primary transition hover:bg-primary-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2" aria-label={navLabels.menu}>
        <span class="nav-menu-label">{navLabels.menu}</span>
        <svg class="nav-icon-hamburger ml-2 h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 6h14M3 10h14M3 14h14" />
        </svg>
        <svg class="nav-icon-close ml-2 hidden h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M6 6l8 8M14 6l-8 8" />
        </svg>
      </summary>
      <div class="absolute right-0 z-[60] mt-2 w-64 rounded-lg border border-primary/15 bg-white p-3 shadow-xl" role="navigation" aria-label={navLabels.menu}>
        <div class="flex items-center justify-between mb-2 pb-2 border-b border-gray-100">
          <span class="nav-menu-heading text-xs font-semibold text-outline">{navLabels.menu}</span>
          <button type="button" class="nav-close-btn flex items-center justify-center h-7 w-7 rounded-md text-outline hover:bg-gray-100 hover:text-on-surface transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary" aria-label={`${locale === 'th' ? 'ปิด' : 'Close'} ${navLabels.menu}`}>
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M6 6l8 8M14 6l-8 8" />
            </svg>
          </button>
        </div>
        <ul class="space-y-0.5">
          {navItems.slice(0, 3).map((item) => (
            <li>
              <a
                href={getLocalizedPath(locale, item.href)}
                class:list={[
                  'flex min-h-11 items-center rounded-md px-3 py-2 text-sm font-semibold transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-1',
                  isActive(item.href)
                    ? 'bg-primary text-white'
                    : 'text-on-surface hover:bg-primary-50 hover:text-primary',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <div class="my-1.5 border-t border-gray-100" aria-hidden="true"></div>
        <ul class="space-y-0.5">
          {navItems.slice(3).map((item) => (
            <li>
              <a
                href={getLocalizedPath(locale, item.href)}
                class:list={[
                  'flex min-h-11 items-center rounded-md px-3 py-2 text-sm font-semibold transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-1',
                  isActive(item.href)
                    ? 'bg-primary text-white'
                    : 'text-on-surface hover:bg-primary-50 hover:text-primary',
                ]}
                aria-current={isActive(item.href) ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </details>

    <style>
      details[open] .nav-icon-hamburger { display: none; }
      details[open] .nav-icon-close { display: block; }
    </style>

    <script>
      const details = document.getElementById('mobile-nav') as HTMLDetailsElement | null;
      if (details) {
        const summary = details.querySelector('summary');
        const label = details.querySelector('.nav-menu-label') as HTMLElement | null;
        const closeBtn = details.querySelector('.nav-close-btn') as HTMLElement | null;
        const openLabel = '{navLabels.menu}';
        const closeLabel = '{locale === "th" ? "ปิด" : "Close"}';

        const updateState = () => {
          const isOpen = details.open;
          if (summary) {
            summary.setAttribute('aria-expanded', String(isOpen));
            summary.setAttribute('aria-label', isOpen ? closeLabel + ' ' + openLabel : openLabel);
          }
          if (label) {
            label.textContent = isOpen ? closeLabel : openLabel;
          }
        };

        details.addEventListener('toggle', updateState);

        if (closeBtn) {
          closeBtn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            details.open = false;
          });
        }

        details.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && details.open) {
            details.open = false;
            if (summary) summary.focus();
          }
        });

        document.addEventListener('click', (e) => {
          if (details.open && !details.contains(e.target as Node)) {
            details.open = false;
          }
        });

        updateState();
      }
    </script>
  </div>
</nav>
