---
import { statusBadgeClass } from '../../utils/data-status';

interface Props {
  label: string;
  value: string;
  unit?: string;
  subtext?: string;
  trendLabel?: string;
  trendColor?: string;
  status?: string;
  size?: 'lg' | 'md';
}

const {
  label,
  value,
  unit,
  subtext,
  trendLabel: trendLbl,
  trendColor = 'text-gray-400',
  status,
  size = 'md',
} = Astro.props;

const valueClass = size === 'lg' ? 'text-5xl md:text-6xl' : 'text-3xl md:text-4xl';
const unitClass = size === 'lg' ? 'text-2xl' : 'text-lg';
---

<div class="bg-white rounded-stitch-lg border border-outline-variant/20 p-5 shadow-sm">
  <p class="text-xs font-medium text-outline mb-1 uppercase tracking-wide">{label}</p>
  <p class={`${valueClass} font-bold text-primary leading-none`}>
    {value}
    {unit && <span class={`${unitClass} text-outline font-normal`}>{unit}</span>}
  </p>
  {trendLbl && (
    <p class={`text-xs font-semibold mt-1 ${trendColor}`}>{trendLbl}</p>
  )}
  {status && (
    <span class={`inline-block mt-1.5 px-2 py-0.5 rounded-full text-[10px] font-semibold ${statusBadgeClass(status as any)}`}>
      {status}
    </span>
  )}
  {subtext && (
    <p class="text-[11px] text-outline-variant mt-2 leading-tight">{subtext}</p>
  )}
</div>
