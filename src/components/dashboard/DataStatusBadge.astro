---
import type { DisplayStatus } from '../../utils/data-status';

interface Props {
  status: DisplayStatus;
  /** true = quality.valid === true */
  verified: boolean;
  locale: 'th' | 'en';
  size?: 'sm' | 'md';
}

const { status, verified, locale, size = 'md' } = Astro.props;
const th = locale === 'th';

const sizeClass = size === 'sm' ? 'text-[10px] px-2 py-0.5' : 'text-xs px-2.5 py-1';

// Build label + classes — NEVER show green/verified when quality.valid is false
let label: string;
let classes: string;
let dotClass: string;

if (!verified) {
  label = th ? 'ข้อมูลยังไม่ยืนยัน' : 'Unverified';
  classes = 'bg-amber-50 text-amber-800 border-amber-200';
  dotClass = 'bg-amber-500';
} else if (status === 'verified_baseline') {
  label = th ? 'ข้อมูลฐานยืนยันแล้ว' : 'Verified Baseline';
  classes = 'bg-blue-50 text-blue-800 border-blue-200';
  dotClass = 'bg-blue-500';
} else if (status === 'complete') {
  label = th ? 'ข้อมูลยืนยันแล้ว' : 'Verified';
  classes = 'bg-green-50 text-green-800 border-green-200';
  dotClass = 'bg-green-500';
} else if (status === 'in_progress') {
  label = th ? 'กำลังบันทึก' : 'In Progress';
  classes = 'bg-yellow-50 text-yellow-800 border-yellow-200';
  dotClass = 'bg-yellow-500';
} else if (status === 'pending') {
  label = th ? 'รอข้อมูล' : 'Data Pending';
  classes = 'bg-gray-50 text-gray-600 border-gray-200';
  dotClass = 'bg-gray-400';
} else {
  label = th ? 'ไม่มีข้อมูล' : 'No Data';
  classes = 'bg-gray-50 text-gray-500 border-gray-200';
  dotClass = 'bg-gray-400';
}
---

<span
  class={`inline-flex items-center gap-1.5 rounded-full border font-medium ${sizeClass} ${classes}`}
  role="status"
>
  <span class={`inline-block w-1.5 h-1.5 rounded-full ${dotClass}`} aria-hidden="true"></span>
  {label}
</span>