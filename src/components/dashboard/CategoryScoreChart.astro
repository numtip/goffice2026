---
interface Props {
  title: string;
  description?: string;
  categories: {
    code: string;
    label: string;
    score: number;
    maxScore?: number;
    trend?: 'up' | 'down' | 'stable';
    href: string;
    statusText?: string;
  }[];
  maxScore?: number;
  locale?: 'th' | 'en';
}

const {
  title, description, categories,
  maxScore: maxScoreProp, locale = 'th',
} = Astro.props;

const maxScore = maxScoreProp ?? Math.max(...categories.map((c) => c.score), 100);
const pad = { left: 160, right: 72, top: 16, bottom: 16 };
const barH = 22;
const gap = 14;
const chartW = 600;
const chartH = categories.length * (barH + gap) + pad.top + pad.bottom;
const drawW = chartW - pad.left - pad.right;

const trendArrow: Record<string, string> = { up: '\u2191', down: '\u2193', stable: '\u2192' };
const trendColorHex: Record<string, string> = { up: '#059669', down: '#dc2626', stable: '#707974' };
---

<div class="bg-white rounded-stitch-lg border border-outline-variant/20 p-5 shadow-sm mb-6">
  <h3 class="text-sm font-semibold text-on-surface mb-1">{title}</h3>
  {description && <p class="text-xs text-outline-variant mb-3">{description}</p>}

  <div class="overflow-x-auto" tabindex="0" role="img" aria-label={title}>
    <svg width={chartW} height={chartH} viewBox={`0 0 ${chartW} ${chartH}`} role="img" aria-label={title}>
      <title>{title}</title>
      <desc>{description ?? 'Horizontal bar chart of category scores'}</desc>

      {categories.map((cat, i) => {
        const y = pad.top + i * (barH + gap);
        const barW = Math.max(2, (cat.score / maxScore) * drawW);
        return (
          <g>
            <a href={cat.href}>
              <text x={pad.left - 8} y={y + barH - 4} text-anchor="end" class="text-[11px] fill-primary" fill="#003527" font-weight="600">{cat.label}</text>
            </a>
            <rect x={pad.left} y={y} width={drawW} height={barH} fill="#f3f4f6" rx="3" />
            <rect x={pad.left} y={y} width={barW} height={barH} fill="#006c49" rx="3" opacity="0.85">
              <title>{`${cat.label}: ${cat.score}/${maxScore}`}</title>
            </rect>
            <text x={pad.left + barW + 6} y={y + barH - 4} class="text-[11px] fill-on-surface-variant" fill="#404944" font-weight="500">
              {cat.score}
              {cat.trend && (
                <tspan dx="4" fill={trendColorHex[cat.trend] ?? '#707974'}>{trendArrow[cat.trend]}</tspan>
              )}
            </text>
            {cat.statusText && (
              <text x={pad.left + drawW + 8} y={y + barH - 4} text-anchor="end" class="text-[9px] fill-outline-variant" fill="#bfc9c3">{cat.statusText}</text>
            )}
          </g>
        );
      })}
    </svg>
  </div>

  <details class="mt-3">
    <summary class="text-xs text-outline cursor-pointer hover:text-primary">{locale === 'th' ? 'ตารางคะแนน' : 'Score table'}</summary>
    <div class="mt-2">
      <table class="w-full text-xs text-left">
        <thead class="border-b border-outline-variant/20">
          <tr>
            <th class="py-1 px-2 font-medium text-outline">{locale === 'th' ? 'หมวดหมู่' : 'Category'}</th>
            <th class="py-1 px-2 font-medium text-outline">{locale === 'th' ? 'คะแนน' : 'Score'}</th>
            <th class="py-1 px-2 font-medium text-outline">%</th>
            <th class="py-1 px-2 font-medium text-outline">{locale === 'th' ? 'แนวโน้ม' : 'Trend'}</th>
          </tr>
        </thead>
        <tbody>
          {categories.map((cat) => {
            const pct = Math.round((cat.score / maxScore) * 100);
            return (
              <tr class="border-b border-outline-variant/5">
                <td class="py-1 px-2 text-primary font-medium"><a href={cat.href} class="hover:underline">{cat.label}</a></td>
                <td class="py-1 px-2 text-on-surface-variant">{cat.score}</td>
                <td class="py-1 px-2 text-on-surface-variant">{pct}%</td>
                <td class="py-1 px-2 text-on-surface-variant">{cat.trend ? trendArrow[cat.trend] : '-'}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </details>
</div>
