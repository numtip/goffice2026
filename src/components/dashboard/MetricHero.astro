---
import MetricIcon from './MetricIcon.astro';
import DataStatusBadge from './DataStatusBadge.astro';
import type { MetricTheme } from '../../data/metric-theme';
import type { DisplayStatus } from '../../utils/data-status';

interface Props {
  title: string;
  purpose: string;
  theme: MetricTheme;
  /** Green Office indicator code (e.g. "3.2.2") */
  indicatorCode?: string;
  indicatorLabel?: string;
  currentDisplayStatus: DisplayStatus;
  currentVerified: boolean;
  lastUpdated?: string;
  locale: 'th' | 'en';
}

const {
  title,
  purpose,
  theme,
  indicatorCode,
  indicatorLabel,
  currentDisplayStatus,
  currentVerified,
  lastUpdated,
  locale,
} = Astro.props;

const th = locale === 'th';

const updatedLabel = th ? 'อัปเดตล่าสุด' : 'Last updated';
const indicatorBadgeLabel = th ? 'ตัวชี้วัด Green Office' : 'Green Office Indicator';
---

<section
  class="metric-hero rounded-stitch-lg border border-outline-variant/20 bg-white p-5 md:p-6 shadow-sm"
  style={`--metric-accent: ${theme.accent}; --metric-accent-light: ${theme.accentLight}; --metric-accent-dark: ${theme.accentDark}; --metric-accent-border: ${theme.accentBorder};`}
  aria-labelledby="metric-hero-title"
>
  <div class="flex flex-col sm:flex-row sm:items-start gap-4">
    <!-- Icon -->
    <div
      class="flex items-center justify-center w-12 h-12 rounded-stitch shrink-0"
      style={`background-color: ${theme.accentLight}; color: ${theme.accentDark};`}
      aria-hidden="true"
    >
      <MetricIcon metric={theme.icon} class="w-7 h-7" />
    </div>

    <!-- Title + purpose -->
    <div class="flex-1 min-w-0">
      <h1 id="metric-hero-title" class="text-xl md:text-2xl font-bold text-on-surface leading-tight">
        {title}
      </h1>
      <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">{purpose}</p>

      <!-- Badges row -->
      <div class="flex flex-wrap items-center gap-2 mt-3">
        {indicatorCode && (
          <span
            class="inline-flex items-center gap-1.5 rounded-full border text-xs font-medium px-2.5 py-1"
            style={`background-color: ${theme.accentLight}; color: ${theme.accentDark}; border-color: ${theme.accentBorder};`}
            title={indicatorBadgeLabel}
          >
            <svg class="w-3 h-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <span class="font-mono">{indicatorCode}</span>
            {indicatorLabel && <span class="hidden sm:inline opacity-90">· {indicatorLabel}</span>}
          </span>
        )}

        <DataStatusBadge
          status={currentDisplayStatus}
          verified={currentVerified}
          locale={locale}
          size="sm"
        />

        {lastUpdated && (
          <span class="text-xs text-on-surface-variant" title={updatedLabel}>
            {updatedLabel}: {lastUpdated}
          </span>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .metric-hero {
    position: relative;
  }
  .metric-hero::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.5rem;
    bottom: 1.5rem;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background-color: var(--metric-accent);
  }
  @media (prefers-reduced-motion: reduce) {
    .metric-hero::before {
      transition: none;
    }
  }
</style>