---
interface Props {
  title: string;
  href: string;
  currentValue: string;
  baselineValue: string;
  unit: string;
  trendPct?: number | null;
  trendDir?: 'up' | 'down' | 'stable';
  monthsCompleted: number;
  color: string;
  monthlyValues?: number[];
  statusLabel?: string;
  partialYear?: boolean;
}

const {
  title, href, currentValue, baselineValue, unit,
  trendPct, trendDir = 'stable', monthsCompleted, color,
  monthlyValues, statusLabel, partialYear,
} = Astro.props;

// YoY trend colors: negative = good (reduction), positive = bad (increase)
const hasYoy = trendPct != null && monthsCompleted > 0;
const yoyColor = hasYoy
  ? (trendPct! < 0 ? 'text-emerald-600' : trendPct! > 0 ? 'text-amber-600' : 'text-outline')
  : 'text-outline-variant/50';

const trendArrow = trendDir === 'up' ? '\u2191' : trendDir === 'down' ? '\u2193' : '\u2192';
const yoyDisplay = hasYoy ? `${trendPct! > 0 ? '+' : ''}${trendPct}% ${trendArrow}` : '\u2014';

// Status badge color
const badgeColor = monthsCompleted >= 12
  ? 'bg-emerald-100 text-emerald-700'
  : monthsCompleted >= 6
    ? 'bg-amber-100 text-amber-700'
    : 'bg-red-100 text-red-700';

const badgeLabel = statusLabel ?? `${monthsCompleted} of 12 months`;

// Mini sparkline SVG (increased height)
const hasSparkline = monthlyValues && monthlyValues.length >= 2;
let sparkPoints = '';
let sparkTrendDir: 'up' | 'down' | 'flat' = 'flat';
let sparkAreaPoints = '';
let sparkLastX = 0;
let sparkLastY = 0;
if (hasSparkline) {
  const w = 150; const h = 40; const pad = 3;
  const values = monthlyValues!;
  const min = Math.min(...values);
  const max = Math.max(...values);
  const range = max - min || 1;
  const stepX = w / (values.length - 1 || 1);
  sparkPoints = values.map((v, i) => {
    const x = i * stepX;
    const y = h - pad - ((v - min) / range) * (h - pad * 2);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');

  // Area fill polygon: start at bottom-left, follow points, end at bottom-right
  const lastIdx = values.length - 1;
  sparkLastX = lastIdx * stepX;
  sparkLastY = h - pad - ((values[lastIdx] - min) / range) * (h - pad * 2);
  sparkAreaPoints = `0,${h} ${sparkPoints} ${sparkLastX.toFixed(1)},${h}`;

  sparkTrendDir = values[lastIdx] > values[0] ? 'up'
    : values[lastIdx] < values[0] ? 'down' : 'flat';
}
---

<a
  href={href}
  style={`border-left-color:${color};`}
  class="group flex flex-col bg-white rounded-stitch-lg border border-outline-variant/20 border-l-4 p-5 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 h-full"
>
  <!-- Top row: title + YoY trend -->
  <div class="flex items-start justify-between gap-2 mb-3">
    <h3 class="text-lg font-bold text-on-surface leading-snug">{title}</h3>
    <span class={`inline-flex items-center gap-0.5 shrink-0 text-xs font-semibold tabular-nums ${yoyColor}`}>
      {yoyDisplay}
    </span>
  </div>

  <!-- Current value + unit (prominent) -->
  <p class="text-3xl font-bold text-on-surface leading-none tracking-tight">
    {currentValue}
    <span class="text-base text-outline-variant font-medium ml-1">{unit}</span>
  </p>

  <!-- Baseline subtle reference -->
  <p class="text-xs text-outline-variant mt-1.5">
    Baseline: {baselineValue}{unit}
  </p>

  <!-- Sparkline (more prominent) -->
  {hasSparkline ? (
    <div class="mt-3 mb-3">
      <svg width="100%" height="40" viewBox="0 0 150 40" preserveAspectRatio="none" class="w-full" aria-hidden="true">
        <polygon
          points={sparkAreaPoints}
          fill={color}
          opacity="0.1"
        />
        <polyline
          fill="none"
          stroke={color}
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          points={sparkPoints}
        />
        {sparkTrendDir !== 'flat' && (
          <circle
            cx={sparkLastX}
            cy={sparkLastY}
            r="3"
            fill={color}
          />
        )}
      </svg>
    </div>
  ) : (
    <div class="flex-1"></div>
  )}

  <!-- Status badge at bottom -->
  <div class="mt-auto pt-3 border-t border-outline-variant/10">
    <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-semibold ${badgeColor}`}>
      {badgeLabel}
      {partialYear && <span class="ml-1 opacity-70">*</span>}
    </span>
  </div>
</a>
