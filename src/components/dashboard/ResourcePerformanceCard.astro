---
interface Props {
  title: string;
  href: string;
  currentValue: string;
  baselineValue: string;
  unit: string;
  trendPct?: number | null;
  trendDir?: 'up' | 'down' | 'stable';
  monthsCompleted: number;
  color: string;
  monthlyValues?: number[];
  statusLabel?: string;
  partialYear?: boolean;
}

const {
  title, href, currentValue, baselineValue, unit,
  trendPct, trendDir = 'stable', monthsCompleted, color,
  monthlyValues, statusLabel, partialYear,
} = Astro.props;

const trendColor = trendPct != null
  ? (trendPct <= -5 ? 'text-green-600' : trendPct >= 5 ? 'text-red-600' : 'text-amber-600')
  : 'text-outline';

const trendArrow = trendDir === 'up' ? '\u2191' : trendDir === 'down' ? '\u2193' : '\u2192';
const trendText = trendPct != null ? `${trendPct > 0 ? '+' : ''}${trendPct}% ${trendArrow}` : null;

// Mini sparkline SVG
const hasSparkline = monthlyValues && monthlyValues.length >= 2;
let sparkPoints = '';
let sparkTrendDir: 'up' | 'down' | 'flat' = 'flat';
if (hasSparkline) {
  const w = 100; const h = 28; const pad = 2;
  const min = Math.min(...monthlyValues);
  const max = Math.max(...monthlyValues);
  const range = max - min || 1;
  const stepX = w / (monthlyValues.length - 1 || 1);
  sparkPoints = monthlyValues.map((v, i) => {
    const x = i * stepX;
    const y = h - pad - ((v - min) / range) * (h - pad * 2);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
  sparkTrendDir = monthlyValues[monthlyValues.length - 1] > monthlyValues[0] ? 'up'
    : monthlyValues[monthlyValues.length - 1] < monthlyValues[0] ? 'down' : 'flat';
}
---

<a
  href={href}
  class="group block bg-white rounded-stitch-lg border border-outline-variant/20 p-5 shadow-sm hover:shadow-md hover:border-primary/30 transition-all"
>
  <div class="flex items-start justify-between mb-3">
    <h3 class="font-semibold text-primary group-hover:text-primary-container text-sm">{title}</h3>
    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-surface-container text-on-surface-variant shrink-0 ml-2">
      {monthsCompleted}/12
    </span>
  </div>

  <div class="flex items-end justify-between gap-3">
    <div>
      <p class="text-2xl font-bold text-on-surface leading-none">
        {currentValue}
        <span class="text-sm text-outline font-normal">{unit}</span>
      </p>
      <p class="text-[11px] text-outline-variant mt-1">
        {statusLabel ?? `${monthsCompleted} of 12 months`}
        {partialYear && <span class="text-amber-600 ml-1">*</span>}
      </p>
    </div>
    {hasSparkline && (
      <svg width="100" height="28" viewBox="0 0 100 28" class="shrink-0 opacity-70 group-hover:opacity-100 transition-opacity" aria-hidden="true">
        <polyline
          fill="none"
          stroke={color}
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          points={sparkPoints}
        />
        {sparkTrendDir !== 'flat' && (
          <circle
            cx={(monthlyValues.length - 1) * (100 / (monthlyValues.length - 1))}
            cy={28 - 2 - ((monthlyValues[monthlyValues.length - 1] - Math.min(...monthlyValues)) / (Math.max(...monthlyValues) - Math.min(...monthlyValues) || 1)) * (28 - 4)}
            r="2.5"
            fill={color}
          />
        )}
      </svg>
    )}
  </div>

  <div class="mt-3 pt-3 border-t border-outline-variant/10 grid grid-cols-2 gap-2 text-xs">
    <div>
      <span class="text-outline-variant">Baseline</span>
      <span class="font-medium text-on-surface block">{baselineValue}{unit}</span>
    </div>
    <div>
      <span class="text-outline-variant">YoY</span>
      {trendText ? (
        <span class={`font-semibold block ${trendColor}`}>{trendText}</span>
      ) : (
        <span class="text-outline block">N/A</span>
      )}
    </div>
  </div>
</a>
