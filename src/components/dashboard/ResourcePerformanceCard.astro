---
interface Props {
  title: string;
  href: string;
  currentValue: string;
  baselineValue: string;
  unit: string;
  trendPct?: number | null;
  trendDir?: 'up' | 'down' | 'stable';
  monthsCompleted: number;
  color: string;
  monthlyValues?: number[];
  statusLabel?: string;
  partialYear?: boolean;
  /** Per-resource icon URL from resourceIconMap */
  iconUrl?: string;
  /** Semantic accent color from resourceAccentMap */
  accentColor?: string;
}

const {
  title, href, currentValue, baselineValue, unit,
  trendPct, trendDir = 'stable', monthsCompleted, color,
  monthlyValues, statusLabel, partialYear,
  iconUrl, accentColor,
} = Astro.props;

const accent = accentColor ?? color;

// YoY trend colors: negative = good (reduction), positive = bad (increase)
const hasYoy = trendPct != null && monthsCompleted > 0;
const yoyColor = hasYoy
  ? (trendPct! < 0 ? 'text-emerald-600' : trendPct! > 0 ? 'text-amber-600' : 'text-slate-600')
  : 'text-slate-400';

const trendArrow = trendDir === 'up' ? '\u2191' : trendDir === 'down' ? '\u2193' : '\u2192';
const yoyDisplay = hasYoy ? `${trendPct! > 0 ? '+' : ''}${trendPct}% ${trendArrow}` : '\u2014';

// Status badge color
const badgeColor = monthsCompleted >= 12
  ? 'bg-emerald-100 text-emerald-700'
  : monthsCompleted >= 6
    ? 'bg-amber-100 text-amber-700'
    : 'bg-red-100 text-red-700';

const badgeLabel = statusLabel ?? `${monthsCompleted} of 12 months`;

// Mini sparkline SVG
const hasSparkline = monthlyValues && monthlyValues.length >= 2;
let sparkPoints = '';
let sparkTrendDir: 'up' | 'down' | 'flat' = 'flat';
let sparkAreaPoints = '';
let sparkLastX = 0;
let sparkLastY = 0;
if (hasSparkline) {
  const w = 150; const h = 40; const pad = 3;
  const values = monthlyValues!;
  const min = Math.min(...values);
  const max = Math.max(...values);
  const range = max - min || 1;
  const stepX = w / (values.length - 1 || 1);
  sparkPoints = values.map((v, i) => {
    const x = i * stepX;
    const y = h - pad - ((v - min) / range) * (h - pad * 2);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');

  const lastIdx = values.length - 1;
  sparkLastX = lastIdx * stepX;
  sparkLastY = h - pad - ((values[lastIdx] - min) / range) * (h - pad * 2);
  sparkAreaPoints = `0,${h} ${sparkPoints} ${sparkLastX.toFixed(1)},${h}`;

  sparkTrendDir = values[lastIdx] > values[0] ? 'up'
    : values[lastIdx] < values[0] ? 'down' : 'flat';
}
---

<a
  href={href}
  class="group flex flex-col bg-white rounded-stitch-lg border border-outline-variant/20 p-5 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 h-full"
>
  <!-- Header: icon + title + trend -->
  <div class="flex items-start gap-2.5 sm:gap-2.5 mb-3">
    {iconUrl ? (
      <div
        class="flex h-12 w-12 sm:h-[50px] sm:w-[50px] md:h-[52px] md:w-[52px] shrink-0 items-center justify-center rounded-xl border"
        style={`background-color:${accent}10; border-color:${accent}30;`}
      >
        <img
          src={iconUrl}
          alt=""
          class="h-7 w-7 sm:h-[30px] sm:w-[30px] md:h-8 md:w-8 object-contain"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
          width={64}
          height={64}
        />
      </div>
    ) : (
      <div
        class="h-12 w-12 sm:h-[50px] sm:w-[50px] md:h-[52px] md:w-[52px] shrink-0 rounded-xl"
        style={`background-color:${accent}15;`}
        aria-hidden="true"
      />
    )}
    <div class="min-w-0 flex-1">
      <h3 class="text-sm font-bold text-on-surface leading-snug">{title}</h3>
      <span class={`inline-flex items-center gap-0.5 text-xs font-semibold tabular-nums ${yoyColor}`}>
        {yoyDisplay}
      </span>
    </div>
  </div>

  <!-- Current value + unit -->
  <p class="text-3xl font-bold text-on-surface leading-none tracking-tight">
    {currentValue}
    <span class="text-base text-slate-700 font-medium ml-1">{unit}</span>
  </p>

  <!-- Baseline reference -->
  <p class="text-xs text-slate-500 mt-1.5">
    Baseline: {baselineValue}{unit}
  </p>

  <!-- Sparkline -->
  {hasSparkline ? (
    <div class="mt-3 mb-3">
      <svg width="100%" height="40" viewBox="0 0 150 40" preserveAspectRatio="none" class="w-full" aria-hidden="true">
        <polygon
          points={sparkAreaPoints}
          fill={accent}
          opacity="0.1"
        />
        <polyline
          fill="none"
          stroke={accent}
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          points={sparkPoints}
        />
        {sparkTrendDir !== 'flat' && (
          <circle
            cx={sparkLastX}
            cy={sparkLastY}
            r="3"
            fill={accent}
          />
        )}
      </svg>
    </div>
  ) : (
    <div class="flex-1"></div>
  )}

  <!-- Status badge -->
  <div class="mt-auto pt-3 border-t" style={`border-color:${accent}18;`}>
    <span class={`inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-semibold ${badgeColor}`}>
      {badgeLabel}
      {partialYear && <span class="ml-1 opacity-70">*</span>}
    </span>
  </div>
</a>
