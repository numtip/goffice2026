---
import { getLocalizedPath } from '../../i18n/utils';

interface Props {
  locale?: 'th' | 'en';
  t?: { label: string; heading: string; description: string; btn_dashboard: string; btn_categories: string; btn_evidence: string; btn_documents: string; btn_search: string };
}

const { locale = 'th' } = Astro.props;
const t = Astro.props.t ?? {
  label: 'Ready to explore',
  heading: 'Your next-generation Green Office command center',
  description: 'Welcome to the next-generation Green Office dashboard — start with executive monitoring, category review, or evidence discovery.',
  btn_dashboard: 'Explore Dashboard',
  btn_categories: 'Explore Green Office',
  btn_evidence: 'Evidence Library',
  btn_documents: 'Document Center',
  btn_search: 'Search',
};
---

<section class="relative eco-mesh-bg eco-mesh-bg-ambient py-14 sm:py-16 md:py-24" aria-labelledby="landing-cta-title">
  <div class="pointer-events-none absolute inset-x-0 -top-16 h-16 bg-gradient-to-b from-[#ecfdf5]/0 to-[#04130a]/20" aria-hidden="true" />

  <div class="landing-container max-w-4xl text-center">
    <p class="landing-reveal mb-3 font-mono text-label-sm uppercase tracking-widest text-emerald-100/80 sm:mb-4">
      {t.label}
    </p>
    <h2 id="landing-cta-title" class="landing-reveal landing-heading mb-4 text-white sm:mb-5">
      {t.heading}
    </h2>
    <p class="landing-reveal mx-auto mb-8 max-w-2xl text-body-md text-emerald-50/85 sm:mb-10 sm:text-body-lg">
      {t.description}
    </p>

    <nav class="landing-reveal landing-stagger flex flex-wrap items-center justify-center gap-2 sm:gap-3" aria-label="Primary destinations">
      <a href={getLocalizedPath(locale, '/dashboard')} class="landing-btn-primary bg-emerald-500 hover:bg-emerald-400 focus-visible:ring-emerald-200">
        {t.btn_dashboard}
      </a>
      <a
        href={getLocalizedPath(locale, '/categories')}
        class="landing-btn-glass border-white/15 bg-white/10 text-white hover:bg-white/15 focus-visible:ring-white/40"
      >
        {t.btn_categories}
      </a>
      <a
        href={getLocalizedPath(locale, '/evidence')}
        class="landing-btn-glass border-white/15 bg-white/10 text-white hover:bg-white/15 focus-visible:ring-white/40"
      >
        {t.btn_evidence}
      </a>
      <a
        href={getLocalizedPath(locale, '/documents')}
        class="landing-btn-glass border-white/15 bg-white/10 text-white hover:bg-white/15 focus-visible:ring-white/40"
      >
        {t.btn_documents}
      </a>
      <a
        href={getLocalizedPath(locale, '/search')}
        class="landing-btn-glass border-white/15 bg-white/10 text-white hover:bg-white/15 focus-visible:ring-white/40"
      >
        {t.btn_search}
      </a>
    </nav>
  </div>
</section>
