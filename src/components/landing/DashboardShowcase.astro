---
import { getLocalizedPath } from '../../i18n/utils';
import type { HomeShowcaseStrings } from '../../i18n/dictionary';
import { dashboardScreenshotImageUrl, dashboardScreenshotDimensions } from '../../utils/wow2-images';

interface Props {
  locale?: 'th' | 'en';
  t?: HomeShowcaseStrings;
}

const { locale = 'th' } = Astro.props;
const t = Astro.props.t ?? {
  heading: 'Environmental Intelligence Center',
  subtitle: 'Green Office 2026 Platform',
  body: "The organization's environmental intelligence hub supporting end-to-end Green Office operations — from executive KPI monitoring and resource analytics to evidence management and continuous improvement.",
  bullet_kpi: 'Executive KPI Dashboard',
  bullet_intelligence: 'Resource Intelligence',
  bullet_analytics: 'Environmental Analytics',
  bullet_evidence: 'Evidence Management',
  bullet_assessment: 'Green Office Assessment',
  bullet_improvement: 'Continuous Improvement',
  cta_dashboard: 'Explore Dashboard',
  cta_evidence: 'View Evidence',
} as HomeShowcaseStrings;

const bullets = [
  { key: 'bullet_kpi',        icon: 'M4 6h16M4 12h16M4 18h16' },
  { key: 'bullet_intelligence', icon: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z' },
  { key: 'bullet_analytics',   icon: 'M3 3v18h18 M18 9V5M13 13V5M8 9v8' },
  { key: 'bullet_evidence',    icon: 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z M14 2v6h6' },
  { key: 'bullet_assessment',  icon: 'M9 12l2 2 4-4 M21 12a9 9 0 11-3.6-7.2' },
  { key: 'bullet_improvement', icon: 'M12 16v-4M12 8h.01 M12 22a10 10 0 100-20' },
] as const;
---

<section
  class="landing-section relative overflow-hidden bg-gradient-to-b from-surface to-surface-container-lowest"
  aria-labelledby="dashboard-showcase-title"
>
  <div class="pointer-events-none absolute inset-x-0 -top-16 h-16 landing-scene-bridge-top" aria-hidden="true" />

  <div class="landing-container py-2 sm:py-4">
    <div class="grid grid-cols-1 items-center gap-8 sm:gap-10 lg:grid-cols-[1fr_1.2fr] lg:gap-16 xl:gap-20">
      <!-- Left: Content -->
      <div>
        <p class="landing-reveal mb-2 inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-[11px] font-semibold uppercase tracking-widest text-emerald-700 sm:mb-3">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-500" aria-hidden="true"></span>
          {t.subtitle}
        </p>
        <h2 id="dashboard-showcase-title" class="landing-reveal mb-4 text-3xl font-semibold tracking-tight text-primary md:text-4xl">
          {t.heading}
        </h2>
        <p class="landing-reveal mb-6 max-w-lg text-base leading-relaxed text-on-surface-variant sm:mb-8 sm:text-lg">
          {t.body}
        </p>

        <!-- Capability bullets — 2-column grid on desktop -->
        <ul class="landing-reveal mb-7 grid gap-x-6 gap-y-3 sm:mb-8 sm:grid-cols-2 sm:gap-y-3.5" role="list" aria-label={locale === 'th' ? 'ความสามารถของแพลตฟอร์ม' : 'Platform capabilities'}>
          {bullets.map((b) => (
            <li class="flex items-start gap-2.5 text-sm text-on-surface-variant sm:text-base">
              <svg class="mt-1 h-4 w-4 shrink-0 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d={b.icon} stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>{t[b.key as keyof HomeShowcaseStrings]}</span>
            </li>
          ))}
        </ul>

        <!-- CTAs -->
        <div class="landing-reveal landing-stagger flex flex-wrap gap-3">
          <a
            href={getLocalizedPath(locale, '/dashboard')}
            class="inline-flex items-center justify-center gap-2 rounded-full bg-emerald-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-600/20 transition-all duration-300 ease-out hover:-translate-y-0.5 hover:bg-emerald-500 hover:shadow-xl hover:shadow-emerald-600/25 focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2"
          >
            {t.cta_dashboard}
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a
            href={getLocalizedPath(locale, '/evidence')}
            class="inline-flex items-center justify-center gap-2 rounded-full border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-primary shadow-sm transition-all duration-300 ease-out hover:-translate-y-0.5 hover:border-emerald-300 hover:bg-emerald-50 hover:text-emerald-700 hover:shadow-md focus-visible:ring-2 focus-visible:ring-emerald-400 focus-visible:ring-offset-2"
          >
            {t.cta_evidence}
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 5v14M5 12h14" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: Dashboard Screenshot -->
      <div class="landing-reveal self-center">
        <div class="showcase-image-wrapper relative mx-auto max-w-xl lg:max-w-none">
          <div class="rounded-2xl bg-gradient-to-br from-emerald-100/50 via-white to-emerald-50/30 p-2 shadow-2xl shadow-black/10 sm:p-3">
            <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-inner">
              <img
                src={dashboardScreenshotImageUrl}
                alt={locale === 'th' ? 'ภาพหน้าจอแดชบอร์ดผู้บริหาร Green Office 2026' : 'Green Office 2026 executive dashboard screenshot'}
                class="w-full"
                loading="lazy"
                decoding="async"
                width={dashboardScreenshotDimensions.w}
                height={dashboardScreenshotDimensions.h}
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .showcase-image-wrapper {
    animation: showcase-float 6s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .showcase-image-wrapper {
      animation: none;
    }
  }

  @keyframes showcase-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
</style>
