---
import { getLocalizedPath } from '../../i18n/utils';
import type { HomeMissionStrings } from '../../i18n/dictionary';
import { heroImageUrl, heroDimensions } from '../../utils/wow2-images';

interface Props {
  locale?: 'th' | 'en';
  t?: HomeMissionStrings;
}

const { locale = 'th' } = Astro.props;
const t = Astro.props.t ?? {
  heading: 'Green Office 2026 Platform',
  description1: 'A centralized platform for tracking, measuring, and reporting environmental performance aligned with Green Office certification criteria. Features six-resource dashboards, assessment category framework, and evidence management system.',
  description2: 'Support the full certification lifecycle — from policy planning and performance tracking to evidence collection and audit readiness.',
  cta: 'Explore Categories',
} as HomeMissionStrings;
---

<section
  class="landing-section relative z-10 bg-surface-container-lowest"
  aria-labelledby="mission-scene-title"
>
  <div class="pointer-events-none absolute inset-x-0 -top-16 h-16 landing-scene-bridge-top" aria-hidden="true" />

  <div class="landing-container">
    <div class="grid grid-cols-1 items-center gap-10 sm:gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 id="mission-scene-title" class="landing-reveal landing-heading mb-5 sm:mb-6">
          {t.heading}
        </h2>
        <p class="landing-reveal mb-5 text-body-md leading-relaxed text-on-surface-variant sm:mb-6 sm:text-body-lg">
          {t.description1}
        </p>
        <p class="landing-reveal mb-7 text-body-md leading-relaxed text-outline sm:mb-8">
          {t.description2}
        </p>
        <a
          href={getLocalizedPath(locale, '/categories')}
          class="landing-reveal landing-btn-ghost inline-flex border-transparent px-0 text-secondary hover:bg-transparent hover:text-primary"
        >
          {t.cta}
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <div class="landing-reveal relative flex aspect-[4/3] items-center justify-center overflow-hidden rounded-stitch-lg shadow-2xl">
        <img
          src={heroImageUrl}
          alt=""
          class="absolute inset-0 h-full w-full object-cover"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
          width={heroDimensions.w}
          height={heroDimensions.h}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent" aria-hidden="true"></div>
        <div class="relative px-6 text-center">
          <p class="font-mono text-label-sm uppercase tracking-widest text-white/90">Green Office 2026</p>
          <p class="mt-2 text-body-md text-white/80">
            Show &middot; Measure &middot; Prove &middot; Improve
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
