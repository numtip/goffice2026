---
import { withBase } from '../../utils/with-base';
---

<section
  class="landing-section relative z-10 bg-surface-container-lowest"
  aria-labelledby="mission-scene-title"
>
  <div class="pointer-events-none absolute inset-x-0 -top-16 h-16 landing-scene-bridge-top" aria-hidden="true" />

  <div class="landing-container">
    <div class="grid grid-cols-1 items-center gap-10 sm:gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <h2 id="mission-scene-title" class="landing-reveal landing-heading mb-5 sm:mb-6">
          Green Office 2026 Content Framework
        </h2>
        <p class="landing-reveal mb-5 text-body-md leading-relaxed text-on-surface-variant sm:mb-6 sm:text-body-lg">
          This landing page introduces the repository's current Green Office structure: resource
          dashboards, assessment categories, document placeholders, and navigation into the evidence
          library.
        </p>
        <p class="landing-reveal mb-7 text-body-md leading-relaxed text-outline sm:mb-8">
          Institutional narratives, campus photography, and activity outcomes should be added only
          after approved local content is available in the repo.
        </p>
        <a
          href={withBase('/categories')}
          class="landing-reveal landing-btn-ghost inline-flex border-transparent px-0 text-secondary hover:bg-transparent hover:text-primary"
        >
          Read the Full Mandate
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <div class="landing-reveal relative flex aspect-[4/3] items-center justify-center overflow-hidden rounded-stitch-lg border border-dashed border-outline-variant/40 bg-surface-container-high shadow-2xl">
        <div class="absolute inset-0 landing-mesh-bg landing-mesh-bg-ambient opacity-80" aria-hidden="true" />
        <div class="relative max-w-sm px-6 text-center">
          <p class="font-mono text-label-sm uppercase tracking-widest text-outline">Local asset pending</p>
          <p class="mt-3 text-body-md text-on-surface-variant">
            Replace this preview once approved campus or program imagery is committed under public assets.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
