---
import { withBase } from '../../utils/with-base';

interface Category {
  id: string;
  number: number;
  title: string;
  shortTitle: string;
  score: number;
  description: string;
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;

const droneBg =
  'https://lh3.googleusercontent.com/aida-public/AB6AXuDzUHXDO1n4ZfBGpBdy5geSwVDTjPRTvY7z52AV3r5iiyCxqJw8o1y2lW5axHTpjNTY8GAbXP5mLbyJBbPy8V5Kpxf4kEWIQGfGxEgvIuQkU_471M2V-wfxDX3LbMC2_ahsa1YdSgwq_VMZhPio9tpJ890IHfrDolGppaF1pmxRLJ6DHApWGTAmYWWH0CbZQJZpg0TESVqsDAFtKd5I9LAxPRoYDD1sLYI1e4hSnGV0nVZ10JaAEZQJRIpFqCSpB4ZNJu1Tcms1kp4';
---

<section class="relative overflow-hidden bg-surface py-section-gap">
  <div class="absolute inset-0 z-0 opacity-10" aria-hidden="true">
    <img src={droneBg} alt="" class="h-full w-full object-cover" loading="lazy" />
  </div>

  <div class="relative z-10 mx-auto max-w-container-max px-margin-mobile md:px-margin-desktop">
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-headline-lg text-primary">Assessment Matrix Framework</h2>
      <p class="mx-auto max-w-2xl text-body-lg text-on-surface-variant">
        Seven certification dimensions — systematically tracked, connected, and validated across the
        Green Office 2569+ program.
      </p>
    </div>

    <div class="relative mx-auto max-w-5xl">
      <div class="framework-connector absolute left-1/2 top-1/2 hidden h-px w-[78%] -translate-x-1/2 -translate-y-1/2 lg:block" aria-hidden="true" />
      <div class="framework-connector absolute left-1/2 top-1/2 hidden h-[68%] w-px -translate-x-1/2 -translate-y-1/2 lg:block" aria-hidden="true" />

      <div class="relative mb-10 flex justify-center">
        <div class="glass-panel rounded-full border border-primary-container/20 px-8 py-4 text-center shadow-lg">
          <p class="font-mono text-label-sm uppercase tracking-widest text-primary">Green Office 2569+</p>
          <p class="mt-1 text-headline-md text-primary">Connected Assessment System</p>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {categories.map((category, index) => {
          const isHighlight = index === categories.length - 1;
          return (
            <a
              href={withBase(`/categories/${category.id}`)}
              class:list={[
                'glass-panel group relative rounded-stitch-lg border p-5 transition hover:-translate-y-1 hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-container',
                isHighlight ? 'border-primary-container/30 bg-surface-container-low sm:col-span-2 lg:col-span-2' : 'border-outline-variant/20',
              ]}
            >
              <div class="mb-3 flex items-center justify-between gap-3">
                <span
                  class:list={[
                    'flex h-10 w-10 items-center justify-center rounded-stitch text-sm font-bold',
                    isHighlight ? 'bg-primary text-white' : 'bg-surface-container text-primary',
                  ]}
                >
                  {category.number}
                </span>
                <span class="font-mono text-mono-data text-primary">{category.score}%</span>
              </div>
              <h3 class="mb-2 text-lg font-semibold text-primary group-hover:text-secondary">{category.shortTitle}</h3>
              <p class="text-sm leading-relaxed text-on-surface-variant">{category.description}</p>
              <div class="mt-4 h-1 overflow-hidden rounded-full bg-surface-container">
                <div
                  class="h-full rounded-full bg-gradient-to-r from-primary-container to-secondary-fixed"
                  style={`width: ${category.score}%;`}
                />
              </div>
            </a>
          );
        })}
      </div>

      <div class="mt-10 text-center">
        <a
          href={withBase('/categories')}
          class="inline-flex items-center gap-2 rounded-full border border-outline-variant/30 bg-surface-container-high px-6 py-3 font-mono text-label-sm uppercase tracking-wider text-primary transition hover:bg-surface-variant focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-container"
        >
          View Full Framework
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
