---
import { getLocalizedPath } from '../../i18n/utils';
import type { HomeHeroStrings } from '../../i18n/dictionary';
import { heroImageUrl, heroDimensions } from '../../utils/wow2-images';

interface Props {
  locale?: 'th' | 'en';
  overallScore: number;
  t?: HomeHeroStrings;
}

const { overallScore, locale = 'th' } = Astro.props;
const t = Astro.props.t ?? {
  badge: 'Environmental Intelligence Platform',
  title_line1: 'Green Office 2026:',
  title_line2: 'Environmental Intelligence Platform',
  description: 'Monitor, measure and report environmental performance for Green Office certification. Explore resource dashboards, assessment categories, and evidence library.',
  cta_dashboard: 'Explore Dashboard',
  cta_categories: 'Explore Categories',
  executive_preview: 'Executive Overview',
  preview_only: 'Latest update',
  metric_energy: 'Energy',
  metric_water: 'Water',
  metric_fuel: 'Fuel',
  metric_paper: 'Paper',
  metric_waste: 'Waste',
  metric_ghg: 'GHG',
} as HomeHeroStrings;

const metricLabels = [t.metric_energy, t.metric_water, t.metric_fuel, t.metric_paper, t.metric_waste, t.metric_ghg];
---

<header
  class="relative flex min-h-[88vh] items-center justify-center overflow-hidden pt-6 sm:min-h-[92vh] sm:pt-8"
  aria-labelledby="landing-hero-title"
>
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={heroImageUrl}
      alt=""
      class="h-full w-full object-cover object-center"
      loading="eager"
      decoding="async"
      aria-hidden="true"
      width={heroDimensions.w}
      height={heroDimensions.h}
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#001a12]/92 via-[#002620]/80 to-[#001a12]/85" aria-hidden="true"></div>
  </div>

  <div class="relative z-10 mx-auto mt-12 w-full max-w-5xl px-margin-mobile text-center sm:mt-16 md:px-margin-desktop lg:mt-20">
    <div class="landing-reveal mb-6 inline-flex w-fit items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 backdrop-blur-sm sm:mb-8">
      <span class="h-2 w-2 rounded-full bg-emerald-400" aria-hidden="true"></span>
      <span class="font-mono text-label-sm uppercase tracking-widest text-white">{t.badge}</span>
    </div>

    <h1
      id="landing-hero-title"
      class="landing-reveal landing-hero-title mb-5 text-4xl font-bold tracking-tight text-white sm:mb-6 md:text-display-xl"
    >
      {t.title_line1}<br />
      <span class="text-emerald-300">{t.title_line2}</span>
    </h1>

    <p class="landing-reveal mx-auto mb-8 max-w-2xl rounded-stitch-lg border border-white/10 bg-white/5 p-5 text-body-md text-white/85 backdrop-blur-sm sm:mb-10 sm:p-6 sm:text-body-lg">
      {t.description}
    </p>

    <div class="landing-reveal landing-stagger flex flex-wrap justify-center gap-3 sm:gap-4">
      <a href={getLocalizedPath(locale, '/dashboard')} class="landing-btn-primary px-6 py-3.5 sm:px-8 sm:py-4">
        {t.cta_dashboard}
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M7 17L17 7M17 7H7M17 7V17" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
      <a href={getLocalizedPath(locale, '/categories')} class="landing-btn-glass px-6 py-3.5 sm:px-8 sm:py-4">
        {t.cta_categories}
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 5v14M5 12l7 7 7-7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <div class="landing-reveal mx-auto mt-10 max-w-3xl sm:mt-14">
      <aside
        class="overflow-hidden rounded-stitch-lg border border-white/10 bg-black/30 p-1 shadow-lg backdrop-blur-sm"
        aria-label={locale === 'th' ? 'ภาพรวมผู้บริหาร' : 'Executive dashboard overview'}
      >
        <div class="rounded-[calc(2rem-4px)] p-4 sm:p-5 md:p-6">
          <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
            <p class="text-label-sm text-white/70">{t.executive_preview}</p>
            <span class="flex items-center gap-2 rounded-full border border-white/10 bg-black/40 px-3 py-1">
              <span class="h-2 w-2 rounded-full bg-emerald-400" aria-hidden="true"></span>
              <span class="font-mono text-[11px] text-white/70">
                <span data-count-up={overallScore} data-count-suffix="%">0%</span>
              </span>
            </span>
          </div>
          <div class="grid grid-cols-2 gap-2 sm:grid-cols-3 md:grid-cols-6" role="list" aria-label={locale === 'th' ? 'ตัวชี้วัดทรัพยากร' : 'Resource indicators'}>
            {metricLabels.map((label, i) => (
              <div class="rounded-lg bg-white/5 p-2 text-center ring-1 ring-white/10" role="listitem">
                <p class="text-[10px] text-white/60">{label}</p>
                <div class="mx-auto mt-2 h-1 w-full overflow-hidden rounded-full bg-white/10">
                  <div
                    class="landing-metric-bar h-full rounded-full bg-gradient-to-r from-emerald-400 to-emerald-600"
                    style={`width: ${62 + i * 5}%;`}
                  />
                </div>
              </div>
            ))}
          </div>
          <p class="mt-3 text-center text-[10px] text-white/50">
            {t.preview_only}
          </p>
        </div>
      </aside>
    </div>
  </div>
</header>
