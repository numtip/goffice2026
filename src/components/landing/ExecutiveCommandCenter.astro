---
import { withBase } from '../../utils/with-base';
import { dashboards } from '../../data/dashboard-config';
import type { MultiYearMetric } from '../../utils/multi-year-schema';
import type { HomeExecutiveStrings } from '../../i18n/dictionary';

import energyGen from '../../data/generated/energy.json';
import waterGen from '../../data/generated/water.json';
import fuelGen from '../../data/generated/fuel.json';
import paperGen from '../../data/generated/paper.json';
import wasteGen from '../../data/generated/waste.json';
import ghgGen from '../../data/generated/ghg.json';

interface Props {
  t?: HomeExecutiveStrings;
}

const t = Astro.props.t ?? {
  heading: 'Unified Command Center',
  description: 'Build-time dashboard snapshot across the six operational resource metrics, prepared from generated static JSON in the repository.',
  label: 'Dashboard Preview',
  overview: 'Global Resource Overview',
  snapshot: 'Static Snapshot',
  cta: 'Open Dashboard',
  data_pending: 'Data pending',
  months_format: '{year} \u00b7 {months}/12 months',
} as HomeExecutiveStrings;

interface MetricDisplay {
  id: string;
  label: string;
  value: string;
  unit: string;
  status: string;
  barWidth: string;
  barColor: string;
}

const genMap: Record<string, MultiYearMetric> = {
  energy: energyGen as MultiYearMetric,
  water: waterGen as MultiYearMetric,
  fuel: fuelGen as MultiYearMetric,
  paper: paperGen as MultiYearMetric,
  waste: wasteGen as MultiYearMetric,
  ghg: ghgGen as MultiYearMetric,
};

const metricIcons: Record<string, string> = {
  energy: 'M13 2L3 14h9l-1 8 10-12h-9l1-8z',
  water: 'M12 2.69l5.66 5.66a8 8 0 11-11.32 0z',
  fuel: 'M3 22h18M6 18V8a2 2 0 012-2h8a2 2 0 012 2v10',
  paper: 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z M14 2v6h6',
  waste: 'M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2',
  ghg: 'M2 20h20M7 20V10M12 20V4M17 20v-6',
};

const metrics: MetricDisplay[] = dashboards.map((d) => {
  const metric = genMap[d.id];
  const current = metric?.years[metric.currentYear.toString()];
  const monthCount = current?.months.length ?? 0;
  const displayValue = current
    ? Intl.NumberFormat('en', { maximumFractionDigits: 1 }).format(current.total)
    : t.data_pending;
  const displayUnit = metric?.unit ?? d.kpiUnit ?? '';
  const status = current
    ? t.months_format.replace('{year}', String(metric.currentYear)).replace('{months}', String(monthCount))
    : t.data_pending;
  const barWidth = `${Math.min(95, Math.max(20, Math.round((monthCount / 12) * 100)))}%`;
  const barColor = d.id === 'water' || d.id === 'paper' || d.id === 'ghg' ? 'bg-primary-fixed' : 'bg-secondary-fixed';

  return {
    id: d.id,
    label: d.id === 'ghg' ? 'GHG' : d.title.split(' ')[0],
    value: displayValue,
    unit: displayUnit,
    status,
    barWidth,
    barColor,
  };
});
---

<section
  class="landing-section relative overflow-hidden bg-inverse-surface text-white"
  aria-labelledby="command-center-title"
>
  <div class="pointer-events-none absolute inset-x-0 -top-16 h-16 landing-scene-bridge-dark-top" aria-hidden="true" />

  <div class="landing-container">
    <div class="landing-reveal mb-10 flex flex-col gap-4 sm:mb-12 sm:gap-6 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 id="command-center-title" class="landing-heading mb-3 text-white sm:mb-4">
          {t.heading}
        </h2>
        <p class="max-w-2xl text-body-md text-outline-variant sm:text-body-lg">
          {t.description}
        </p>
      </div>
      <p class="font-mono text-label-sm uppercase tracking-wider text-outline-variant">{t.label}</p>
    </div>

    <div class="landing-reveal dark-glass relative flex flex-col overflow-hidden rounded-stitch-lg border border-white/10 p-5 shadow-2xl sm:p-6 md:p-8">
      <div class="absolute inset-0 z-0 opacity-20" aria-hidden="true">
        <div class="h-full w-full landing-mesh-bg" />
      </div>

      <div class="relative z-10">
        <div class="mb-6 flex flex-wrap items-center justify-between gap-3 border-b border-white/10 pb-5 sm:mb-8 sm:pb-6">
          <div class="flex items-center gap-3 sm:gap-4">
            <svg class="h-5 w-5 text-secondary-fixed sm:h-6 sm:w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="3" y="4" width="18" height="14" rx="2" />
              <path d="M8 20h8M12 18v2" />
            </svg>
            <span class="font-mono text-label-sm uppercase tracking-widest text-outline-variant">{t.overview}</span>
          </div>
          <div class="flex items-center gap-2 rounded-full border border-white/5 bg-black/40 px-3 py-1.5">
            <span class="h-2 w-2 rounded-full bg-secondary-fixed animate-pulse" aria-hidden="true" />
            <span class="font-mono text-[12px] text-outline-variant">{t.snapshot}</span>
          </div>
        </div>

        <div class="landing-stagger grid grid-cols-2 gap-4 sm:gap-6 md:grid-cols-3 lg:grid-cols-6 lg:gap-8" role="list" aria-label="Resource metrics preview">
          {metrics.map((metric) => (
            <a
              href={withBase(`/dashboard/${metric.id}`)}
              role="listitem"
              class="landing-reveal dashboard-metric-highlight group flex flex-col gap-2 p-2 sm:p-3"
              aria-label={`${metric.label}: ${metric.value} ${metric.unit}`}
            >
              <span class="flex items-center gap-2 font-mono text-[11px] uppercase text-outline-variant sm:text-label-sm">
                <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d={metricIcons[metric.id]} stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {metric.label}
              </span>
              <span class="text-lg font-semibold text-white sm:text-headline-md">
                {metric.value}
                <span class="text-sm text-outline-variant sm:text-body-md"> {metric.unit}</span>
              </span>
              <span class="font-mono text-[10px] uppercase tracking-wide text-outline-variant">{metric.status}</span>
              <div class="mt-1 h-1 w-full overflow-hidden rounded-full bg-white/10 sm:mt-2">
                <div
                  class={`landing-metric-bar h-full rounded-full ${metric.barColor}`}
                  style={`width: ${metric.barWidth};`}
                />
              </div>
              <div class="mt-1 hidden items-end gap-0.5 sm:flex" aria-hidden="true">
                {[3, 5, 4, 7, 5, 8, 6, 9].map((h, i) => (
                  <div
                    class="w-1 rounded-sm bg-gradient-to-t from-primary-container to-primary-fixed opacity-70 transition-opacity group-hover:opacity-100"
                    style={`height: ${h * 3}px; opacity: ${0.4 + i * 0.06};`}
                  />
                ))}
              </div>
            </a>
          ))}
        </div>

        <div class="mt-10 flex justify-center border-t border-white/5 pt-7 sm:mt-12 sm:pt-8">
          <a
            href={withBase('/dashboard')}
            class="inline-flex items-center gap-2 rounded-full bg-primary-fixed px-6 py-3 font-mono text-label-sm uppercase tracking-wider text-[#002117] shadow-lg transition duration-300 ease-out hover:-translate-y-0.5 hover:bg-primary-fixed-dim focus-visible:ring-2 focus-visible:ring-white/40 focus-visible:ring-offset-2 sm:px-8"
          >
            {t.cta}
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
