---
import { withBase } from '../../utils/with-base';
import type { HomeImprovementStrings } from '../../i18n/dictionary';

interface Props {
  t?: HomeImprovementStrings;
}

const t = Astro.props.t ?? {
  label: 'Lifecycle Narrative',
  heading: 'Improvement Journey',
  description: 'A navigational overview of the configured category flow. Replace with verified program narrative once approved source material is available.',
  stage_1_title: 'Policy',
  stage_1_subtitle: 'Planning & Governance',
  stage_1_description: 'Strategic commitments and organizational structure for sustainability leadership.',
  stage_2_title: 'Awareness',
  stage_2_subtitle: 'Communication & Training',
  stage_2_description: 'Behavioral change through campaigns, workshops, and institutional engagement.',
  stage_3_title: 'Resource Management',
  stage_3_subtitle: 'Energy · Water · Materials',
  stage_3_description: 'Conservation across electricity, water, fuel, and paper consumption vectors.',
  stage_4_title: 'Waste',
  stage_4_subtitle: 'Reduction & Recycling',
  stage_4_description: 'Segregation, diversion, and responsible disposal across campus operations.',
  stage_5_title: 'Safety',
  stage_5_subtitle: 'Environment & Occupant Health',
  stage_5_description: 'Indoor air quality, ergonomics, and emergency readiness standards.',
  stage_6_title: 'Green Procurement',
  stage_6_subtitle: 'Sustainable Purchasing',
  stage_6_description: 'Supplier evaluation and environmentally preferred purchasing policies.',
  stage_7_title: 'Continuous Improvement',
  stage_7_subtitle: 'Audit & Refinement',
  stage_7_description: 'Management review, target refinement, and certification readiness cycles.',
} as HomeImprovementStrings;

const stages = [
  { step: 1, title: t.stage_1_title, subtitle: t.stage_1_subtitle, description: t.stage_1_description, href: '/categories/cat7' },
  { step: 2, title: t.stage_2_title, subtitle: t.stage_2_subtitle, description: t.stage_2_description, href: '/categories' },
  { step: 3, title: t.stage_3_title, subtitle: t.stage_3_subtitle, description: t.stage_3_description, href: '/categories/cat1' },
  { step: 4, title: t.stage_4_title, subtitle: t.stage_4_subtitle, description: t.stage_4_description, href: '/categories/cat3' },
  { step: 5, title: t.stage_5_title, subtitle: t.stage_5_subtitle, description: t.stage_5_description, href: '/categories/cat5' },
  { step: 6, title: t.stage_6_title, subtitle: t.stage_6_subtitle, description: t.stage_6_description, href: '/categories/cat6' },
  { step: 7, title: t.stage_7_title, subtitle: t.stage_7_subtitle, description: t.stage_7_description, href: '/categories/cat7' },
];
---

<section
  class="landing-section relative landing-mesh-bg landing-mesh-bg-ambient"
  aria-labelledby="improvement-journey-title"
>
  <div class="pointer-events-none absolute inset-x-0 -top-16 h-16 bg-gradient-to-b from-surface to-transparent" aria-hidden="true" />

  <div class="landing-container">
    <div class="landing-reveal mb-10 text-center sm:mb-14">
      <p class="mb-3 font-mono text-label-sm uppercase tracking-widest text-secondary">{t.label}</p>
      <h2 id="improvement-journey-title" class="landing-heading mb-3 sm:mb-4">{t.heading}</h2>
      <p class="mx-auto max-w-2xl text-body-md text-on-surface-variant sm:text-body-lg">
        {t.description}
      </p>
    </div>

    <div class="relative hidden xl:block" aria-hidden="true">
      <div class="journey-line absolute left-[4%] right-[4%] top-[2.75rem] h-0.5 rounded-full opacity-40" />
    </div>

    <ol class="landing-stagger grid gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3 xl:grid-cols-7 xl:gap-4" aria-label="Green Office improvement lifecycle">
      {stages.map((stage, index) => (
        <li class="landing-reveal relative list-none">
          {index < stages.length - 1 && (
            <div class="absolute left-[calc(50%+1.5rem)] top-6 hidden h-px w-[calc(100%-3rem)] bg-primary-container/25 xl:block" aria-hidden="true" />
          )}
          <a
            href={withBase(stage.href)}
            class="landing-card-interactive group flex h-full flex-col rounded-stitch-lg border border-outline-variant/20 bg-surface-container-lowest/80 p-4 shadow-sm backdrop-blur-sm hover:border-primary-container/30 sm:p-5"
          >
            <div class="mb-3 flex items-center gap-3 sm:mb-4">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white transition-transform duration-300 group-hover:scale-105 motion-reduce:group-hover:scale-100 sm:h-10 sm:w-10" aria-hidden="true">
                {stage.step}
              </span>
              <div class="h-px flex-1 bg-gradient-to-r from-primary-container/40 to-transparent xl:hidden" aria-hidden="true" />
            </div>
            <h3 class="mb-1 text-base font-semibold text-primary transition-colors duration-300 group-hover:text-secondary sm:text-lg">
              {stage.title}
            </h3>
            <p class="mb-2 font-mono text-[10px] uppercase tracking-wider text-outline sm:mb-3 sm:text-[11px]">{stage.subtitle}</p>
            <p class="text-sm leading-relaxed text-on-surface-variant">{stage.description}</p>
          </a>
        </li>
      ))}
    </ol>
  </div>
</section>
