---
import { withBase } from '../../utils/with-base';

interface Props {
  id: string;
  title: string;
  description: string;
  year: number;
  fileType: string;
  status: string;
  traceabilityLevel: string;
  verificationStatus: string;
  categoryTitle?: string;
  locale: 'th' | 'en';
}

const {
  id,
  title,
  description,
  year,
  fileType,
  status,
  traceabilityLevel,
  verificationStatus,
  categoryTitle,
  locale,
} = Astro.props;

const isPlaceholder = status === 'placeholder';

// Traceability level config
const traceabilityConfig: Record<string, { th: string; en: string; class: string }> = {
  indicator: {
    th: 'เชื่อมโยงตัวชี้วัด',
    en: 'Indicator-linked',
    class: 'bg-green-100 text-green-800 border-green-300',
  },
  issue: {
    th: 'เชื่อมโยงประเด็น',
    en: 'Issue-linked',
    class: 'bg-blue-100 text-blue-800 border-blue-300',
  },
  category: {
    th: 'เชื่อมโยงหมวดหมู่',
    en: 'Category-linked',
    class: 'bg-amber-100 text-amber-800 border-amber-300',
  },
  unmapped: {
    th: 'ยังไม่เชื่อมโยง',
    en: 'Unmapped',
    class: 'bg-gray-100 text-gray-600 border-gray-300',
  },
};
const traceCfg = traceabilityConfig[traceabilityLevel] || traceabilityConfig.unmapped;

// Verification status config
const verificationConfig: Record<string, { th: string; en: string; class: string }> = {
  verified: {
    th: 'ตรวจสอบแล้ว',
    en: 'Verified',
    class: 'bg-green-100 text-green-800',
  },
  pending: {
    th: 'รอตรวจสอบ',
    en: 'Pending review',
    class: 'bg-amber-100 text-amber-800',
  },
  unresolved: {
    th: 'ยังไม่ตรวจสอบ',
    en: 'Unresolved',
    class: 'bg-yellow-100 text-yellow-800',
  },
  rejected: {
    th: 'ไม่ผ่าน',
    en: 'Rejected',
    class: 'bg-red-100 text-red-800',
  },
};
const verCfg = verificationConfig[verificationStatus] || verificationConfig.unresolved;

// Source status config
const sourceStatusLabel: Record<string, { th: string; en: string }> = {
  available: { th: 'พร้อมใช้งาน', en: 'Available' },
  pending: { th: 'รอดำเนินการ', en: 'Pending' },
  'in-review': { th: 'กำลังตรวจสอบ', en: 'In Review' },
  placeholder: { th: 'ต้นฉบับรออยู่', en: 'Source Pending' },
};
const srcLabel = sourceStatusLabel[status] || { th: status, en: status };

// File type badge colors
const fileTypeBadgeColor: Record<string, string> = {
  PDF: 'bg-red-100 text-red-700',
  XLSX: 'bg-emerald-100 text-emerald-700',
  DOCX: 'bg-indigo-100 text-indigo-700',
  MD: 'bg-gray-100 text-gray-600',
};
const fileTypeClass = fileTypeBadgeColor[fileType] || 'bg-gray-100 text-gray-700';

const cardBorder = isPlaceholder ? 'border-dashed border-gray-200' : 'border-gray-100';
const cardOpacity = isPlaceholder ? 'opacity-80' : '';
const detailHref = withBase(`/evidence/${id}/`);
---

<article class={`bg-white rounded-xl shadow-sm border ${cardBorder} p-5 hover:shadow-md transition-shadow ${cardOpacity}`}>
  <!-- Badge row -->
  <div class="flex flex-wrap items-center gap-2 mb-3">
    <!-- Source pending pill -->
    {isPlaceholder && (
      <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold uppercase tracking-wider bg-amber-100 text-amber-700 border border-amber-300">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {locale === 'th' ? 'ยังไม่มีไฟล์ต้นฉบับ' : 'Source Pending'}
      </span>
    )}
    <!-- File type badge -->
    <span class:list={["inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium", fileTypeClass]}>
      {fileType}
    </span>
    <!-- Year badge -->
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-700">
      {year}
    </span>
  </div>

  <!-- Title (links to detail page) -->
  <h3 class="text-lg font-semibold text-gray-900 mt-1">
    <a href={detailHref} class="text-green-700 hover:text-green-800 underline decoration-green-300 underline-offset-2">
      {title}
    </a>
  </h3>

  <!-- Description -->
  <p class="text-sm text-gray-600 mt-2 leading-relaxed line-clamp-2">{description}</p>

  <!-- Meta badges -->
  <div class="flex flex-wrap items-center gap-2 mt-3">
    <!-- Traceability badge -->
    <span class:list={["inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border", traceCfg.class]}>
      {locale === 'th' ? traceCfg.th : traceCfg.en}
    </span>
    <!-- Verification badge -->
    <span class:list={["inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium", verCfg.class]}>
      {locale === 'th' ? verCfg.th : verCfg.en}
    </span>
    <!-- Category -->
    {categoryTitle && (
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
        {categoryTitle}
      </span>
    )}
    <!-- Source status -->
    <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-50 text-gray-500 border border-gray-200">
      {isPlaceholder ? (
        <svg class="w-3 h-3 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      ) : (
        <svg class="w-3 h-3 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      )}
      {locale === 'th' ? srcLabel.th : srcLabel.en}
    </span>
  </div>

  <!-- Action row -->
  <div class="mt-4 flex items-center gap-3 border-t border-gray-100 pt-3">
    <a
      href={detailHref}
      class="inline-flex items-center gap-1.5 text-sm font-medium text-green-600 hover:text-green-800 transition-colors"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      {locale === 'th' ? 'ดูรายละเอียด' : 'View Details'}
    </a>
    <span class="text-xs text-gray-400 ml-auto">{locale === 'th' ? 'รหัส' : 'ID'}: {id}</span>
  </div>
</article>
