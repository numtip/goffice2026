---
import { withBase } from '../../utils/with-base';

interface EvidenceItem {
  id: string;
  title: string;
  description: string;
  fileType: string;
  status: string;
  categoryId: string;
}

interface Props {
  items: EvidenceItem[];
  totalItems: number;
  availableItems: number;
}

const { items, totalItems, availableItems } = Astro.props;

const statusClass: Record<string, string> = {
  available: 'bg-emerald-100 text-emerald-800',
  placeholder: 'bg-slate-100 text-slate-500',
  pending: 'bg-amber-100 text-amber-800',
  'in-review': 'bg-sky-100 text-sky-800',
};
---

<div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
  <div class="space-y-3">
    {items.map((item) => (
      <article class="glass-card-light p-4 transition hover:shadow-md">
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-violet-100 px-2 py-0.5 text-[11px] font-semibold text-violet-700">
            {item.fileType}
          </span>
          <span class:list={['rounded-full px-2 py-0.5 text-[11px] font-semibold', statusClass[item.status] ?? 'bg-slate-100 text-slate-600']}>
            {item.status}
          </span>
        </div>
        <h3 class="mt-2 text-sm font-semibold text-slate-900">{item.title}</h3>
        <p class="mt-1 line-clamp-2 text-sm text-slate-600">{item.description}</p>
      </article>
    ))}
  </div>

  <div class="flex flex-col gap-4">
    <div class="rounded-2xl bg-gradient-to-br from-slate-900 to-emerald-950 p-6 text-white shadow-xl">
      <p class="text-xs font-semibold uppercase tracking-wide text-emerald-200/80">Evidence Library</p>
      <p class="mt-2 text-3xl font-bold">{totalItems}</p>
      <p class="text-sm text-emerald-100/75">Indexed evidence items across 7 categories</p>
      <p class="mt-4 text-sm">
        <span class="font-semibold text-emerald-300">{availableItems}</span> available now
      </p>
      <a
        href={withBase('/evidence')}
        class="mt-6 inline-flex w-full items-center justify-center rounded-xl bg-emerald-500 px-4 py-3 text-sm font-semibold text-white transition hover:bg-emerald-400 focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-200"
      >
        Browse Evidence Library
      </a>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1">
      <a
        href={withBase('/documents')}
        class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-emerald-200 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
      >
        <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">Document Center</p>
        <p class="mt-2 text-sm text-slate-600">
          Browse and download certification evidence documents organized by Green Office category.
        </p>
      </a>
      <a
        href={withBase('/search')}
        class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-emerald-200 hover:shadow-md focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
      >
        <p class="text-xs font-semibold uppercase tracking-wide text-emerald-700">Search</p>
        <p class="mt-2 text-sm text-slate-600">
          Discover evidence, documents, and dashboard resources across the platform.
        </p>
      </a>
    </div>
  </div>
</div>
