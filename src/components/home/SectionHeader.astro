---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  light?: boolean;
}

const { eyebrow, title, description, align = 'left', light = false } = Astro.props;
const alignClass = align === 'center' ? 'text-center mx-auto max-w-3xl' : 'max-w-3xl';
const eyebrowClass = light ? 'text-emerald-200/90' : 'text-emerald-700';
const titleClass = light ? 'text-white' : 'text-slate-900';
const descClass = light ? 'text-emerald-50/80' : 'text-slate-600';
---

<div class={`mb-8 md:mb-10 ${alignClass}`}>
  {eyebrow && (
    <p class={`text-xs font-semibold uppercase tracking-[0.2em] ${eyebrowClass} mb-3`}>
      {eyebrow}
    </p>
  )}
  <h2 class={`text-2xl md:text-3xl font-bold tracking-tight ${titleClass}`}>{title}</h2>
  {description && (
    <p class={`mt-3 text-sm md:text-base leading-relaxed ${descClass}`}>{description}</p>
  )}
</div>
