---
import { withBase } from '../../utils/with-base';
import type { DashboardMeta } from '../../data/dashboard-config';

interface Props {
  dashboards: DashboardMeta[];
}

const { dashboards } = Astro.props;

const trendLabel: Record<string, string> = {
  up: '↑',
  down: '↓',
  stable: '→',
};
---

<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
  {dashboards.map((d) => (
    <a
      href={withBase(`/dashboard/${d.id}`)}
      class="group relative overflow-hidden rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500"
    >
      <div
        class="absolute inset-x-0 top-0 h-1"
        style={`background: linear-gradient(90deg, ${d.color}, transparent)`}
        aria-hidden="true"
      />
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">{d.kpiLabel}</p>
          <h3 class="mt-1 text-base font-semibold text-slate-900 group-hover:text-emerald-800">{d.title}</h3>
        </div>
        {d.trend && (
          <span class="rounded-full bg-slate-100 px-2 py-1 text-xs font-bold text-slate-600" aria-hidden="true">
            {trendLabel[d.trend]}
          </span>
        )}
      </div>
      <p class="mt-3 line-clamp-2 text-sm leading-relaxed text-slate-600">{d.description}</p>
      <div class="mt-4 flex items-end justify-between">
        <div>
          <span class="text-2xl font-bold text-slate-900">{d.kpiScore}</span>
          {d.kpiUnit && <span class="ml-1 text-sm text-slate-500">{d.kpiUnit}</span>}
          {!d.kpiUnit && d.kpiScore !== undefined && (
            <span class="ml-1 text-sm text-slate-500">%</span>
          )}
        </div>
        <div class="flex items-end gap-1" aria-hidden="true">
          {[35, 52, 44, 61, 48, 58].map((h) => (
            <div
              class="w-2 rounded-sm opacity-80 transition group-hover:opacity-100"
              style={`height: ${h}px; background: ${d.color}`}
            />
          ))}
        </div>
      </div>
    </a>
  ))}
</div>

<div class="mt-6 text-center">
  <a
    href={withBase('/dashboard')}
    class="inline-flex items-center gap-2 text-sm font-semibold text-emerald-700 hover:text-emerald-800"
  >
    View full dashboard
    <span aria-hidden="true">→</span>
  </a>
</div>
