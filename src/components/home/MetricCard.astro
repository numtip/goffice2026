---
interface Props {
  label: string;
  value: string;
  unit?: string;
  trend?: 'up' | 'down' | 'stable';
  description?: string;
  href?: string;
  accent?: 'emerald' | 'sky' | 'violet' | 'amber';
}

const { label, value, unit, trend, description, href, accent = 'emerald' } = Astro.props;

const accentRing: Record<string, string> = {
  emerald: 'from-emerald-500/20 to-teal-500/10 ring-emerald-500/20',
  sky: 'from-sky-500/20 to-cyan-500/10 ring-sky-500/20',
  violet: 'from-violet-500/20 to-purple-500/10 ring-violet-500/20',
  amber: 'from-amber-500/20 to-orange-500/10 ring-amber-500/20',
};

const trendLabel: Record<string, string> = {
  up: '↑',
  down: '↓',
  stable: '→',
};

const trendColor: Record<string, string> = {
  up: 'text-emerald-600',
  down: 'text-rose-600',
  stable: 'text-slate-500',
};

const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class={`group block rounded-2xl bg-gradient-to-br ${accentRing[accent]} ring-1 p-5 transition hover:-translate-y-0.5 hover:shadow-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500`}
>
  <p class="text-xs font-medium uppercase tracking-wide text-slate-500">{label}</p>
  <div class="mt-2 flex items-end gap-1">
    <span class="text-3xl font-bold text-slate-900">{value}</span>
    {unit && <span class="pb-1 text-sm font-medium text-slate-500">{unit}</span>}
    {trend && (
      <span class={`ml-auto text-sm font-semibold ${trendColor[trend]}`} aria-hidden="true">
        {trendLabel[trend]}
      </span>
    )}
  </div>
  {description && <p class="mt-2 text-sm leading-relaxed text-slate-600">{description}</p>}
  {href && (
    <span class="mt-3 inline-flex text-xs font-semibold text-emerald-700 group-hover:text-emerald-800">
      View details →
    </span>
  )}
</Tag>
