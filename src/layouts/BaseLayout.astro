---
import Navigation from '../components/ui/Navigation.astro';
import PreviewBadge from '../components/ui/PreviewBadge.astro';

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Green Office 2026 static preview with repository-backed dashboards, categories, and evidence placeholders." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title} - Green Office Platform</title>
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-stitch focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      Skip to main content
    </a>
    <header>
      <Navigation />
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="mt-8 border-t border-primary/10 bg-inverse-surface py-8 text-white">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 text-sm text-outline-variant sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-semibold text-white">Green Office 2026</p>
          <p>Static preview. Content and evidence are repository-backed unless marked as placeholder.</p>
        </div>
        <p class="text-xs">&copy; {new Date().getFullYear()} Green Office Platform</p>
      </div>
    </footer>
    <PreviewBadge />
  </body>
</html>
