---
import { stripLocalePrefix, stripBasePath, getLocalizedPath, getLocale } from '../i18n/utils';
import { getDictionary } from '../i18n/dictionary';
import Navigation from '../components/ui/Navigation.astro';
import PreviewBadge from '../components/ui/PreviewBadge.astro';
import {
  SITE_META,
  resolveSiteOrigin,
  buildCanonicalUrl,
  assetUrl,
} from '../config/site-meta';
import type { LocaleStrings, HomeNavStrings } from '../i18n/dictionary';

interface Props {
  title?: string;
  description?: string;
  locale?: 'th' | 'en';
  dict?: LocaleStrings;
  ogImage?: string;
  noindex?: boolean;
  /** Error pages: hreflang + language switcher target locale home, not /404/ */
  errorPage?: boolean;
}

const {
  title,
  description: customDesc,
  locale: localeProp,
  dict: dictProp,
  ogImage,
  noindex = false,
  errorPage = false,
} = Astro.props;

const lang = localeProp ?? getLocale(Astro.url);
const dict = dictProp ?? await getDictionary(lang);

const skipLabel = dict.site.skip_to_content;
const defaultDesc = dict.home.hero.description;
const desc = customDesc ?? defaultDesc;
const footerTitle = dict.home.footer.title;
const footerDesc = dict.home.footer.description;
const footerCopy = dict.home.footer.copyright;
const footerLinks = dict.home.footer;

const pageTitle = title ?? `${dict.site.name} - ${dict.site.title_suffix}`;

const navLabels: HomeNavStrings = dict.home.nav;

const appPath = errorPage ? '/' : stripLocalePrefix(stripBasePath(Astro.url.pathname));
const siteOrigin = resolveSiteOrigin(Astro.site, Astro.url.origin);
const thUrl = new URL(getLocalizedPath('th', appPath), `${siteOrigin}/`).href;
const enUrl = new URL(getLocalizedPath('en', appPath), `${siteOrigin}/`).href;
const canonicalUrl = buildCanonicalUrl(siteOrigin, Astro.url.pathname);
const baseUrl = import.meta.env.BASE_URL ?? '/';
const defaultOgImage = assetUrl(siteOrigin, baseUrl, SITE_META.ogDefaultImagePath);
const socialImage = ogImage ? assetUrl(siteOrigin, baseUrl, ogImage) : defaultOgImage;
const manifestHref = assetUrl(siteOrigin, baseUrl, '/manifest.webmanifest');
const faviconSvg = assetUrl(siteOrigin, baseUrl, '/favicon.svg');
const faviconIco = assetUrl(siteOrigin, baseUrl, '/favicon.ico');
const appleTouchIcon = assetUrl(siteOrigin, baseUrl, '/icons/apple-touch-icon.png');
const maskIcon = assetUrl(siteOrigin, baseUrl, '/icons/safari-pinned-tab.svg');
const ogLocale = lang === 'en' ? SITE_META.alternateLocale : SITE_META.locale;
const ogLocaleAlt = lang === 'en' ? SITE_META.locale : SITE_META.alternateLocale;
const keywords = SITE_META.keywords.join(', ');
const robotsContent = noindex ? 'noindex, follow' : 'index, follow';
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={desc} />
    <meta name="author" content={SITE_META.author} />
    <meta name="keywords" content={keywords} />
    <meta name="application-name" content={SITE_META.applicationName} />
    <meta name="color-scheme" content={SITE_META.colorScheme} />
    <meta name="theme-color" content={SITE_META.themeColor} />
    <meta name="robots" content={robotsContent} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content={SITE_META.applicationName} />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="msapplication-config" content={assetUrl(siteOrigin, baseUrl, '/browserconfig.xml')} />

    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />

    {thUrl && <link rel="alternate" hreflang="th" href={thUrl} />}
    {enUrl && thUrl !== enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
    {thUrl && <link rel="alternate" hreflang="x-default" href={thUrl} />}

    <link rel="icon" href={faviconIco} sizes="32x32" />
    <link rel="icon" href={faviconSvg} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={appleTouchIcon} />
    <link rel="mask-icon" href={maskIcon} color={SITE_META.themeColor} />
    <link rel="manifest" href={manifestHref} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_META.applicationName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content={String(SITE_META.ogImageWidth)} />
    <meta property="og:image:height" content={String(SITE_META.ogImageHeight)} />
    <meta property="og:image:alt" content={pageTitle} />

    <meta name="twitter:card" content={SITE_META.twitterCard} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={pageTitle} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-stitch focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      {skipLabel}
    </a>
    <header class="sticky top-0 z-50">
      <Navigation
        locale={lang}
        t={navLabels}
        university={dict.site.university}
        platformLabel={dict.site.title_suffix}
      />
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="mt-8 border-t border-primary/10 bg-inverse-surface py-8 text-white">
      <div class="mx-auto max-w-6xl px-4">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
          <div class="max-w-md">
            <p class="font-semibold text-white">{footerTitle}</p>
            <p class="text-sm text-outline-variant mt-1">{footerDesc}</p>
          </div>
          <nav class="grid grid-cols-2 gap-x-8 gap-y-2 text-sm" aria-label={footerLinks.label_nav}>
            <a href={getLocalizedPath(lang, '/documents')} class="text-outline-variant hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/70 focus-visible:ring-offset-2 focus-visible:ring-offset-inverse-surface rounded-sm">{footerLinks.links_documents}</a>
            <a href={getLocalizedPath(lang, '/evidence')} class="text-outline-variant hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/70 focus-visible:ring-offset-2 focus-visible:ring-offset-inverse-surface rounded-sm">{footerLinks.links_evidence}</a>
            <a href={getLocalizedPath(lang, '/dashboard')} class="text-outline-variant hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/70 focus-visible:ring-offset-2 focus-visible:ring-offset-inverse-surface rounded-sm">{footerLinks.links_data_source}</a>
            <a href={getLocalizedPath(lang, '/search')} class="text-outline-variant hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/70 focus-visible:ring-offset-2 focus-visible:ring-offset-inverse-surface rounded-sm">{dict.home.cta.btn_search}</a>
            <a href="https://www.mju.ac.th/" class="text-outline-variant hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/70 focus-visible:ring-offset-2 focus-visible:ring-offset-inverse-surface rounded-sm" target="_blank" rel="noopener noreferrer">{footerLinks.links_org}</a>
            <span class="text-outline/50 text-xs cursor-default" role="note">{footerLinks.links_accessibility} &mdash; {lang === 'th' ? 'อยู่ระหว่างดำเนินการ' : 'in progress'}</span>
          </nav>
        </div>
        <div class="mt-6 border-t border-white/10 pt-4 text-xs text-outline/60">
          <p>&copy; {new Date().getFullYear()} {footerCopy}</p>
        </div>
      </div>
    </footer>
    <PreviewBadge locale={lang} />
  </body>
</html>
