---
import Navigation from '../components/ui/Navigation.astro';
import PreviewBadge from '../components/ui/PreviewBadge.astro';

const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Maejo University Green Office 2026 — executive environmental intelligence, certification dashboards, and evidence preview." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title} - Green Office Platform</title>
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-stitch focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      Skip to main content
    </a>
    <header class="bg-white shadow-md">
      <Navigation />
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="bg-gray-800 text-white py-4 mt-8">
      <div class="container mx-auto text-center">
        <p>&copy; {new Date().getFullYear()} Green Office Platform. All rights reserved.</p>
      </div>
    </footer>
    <PreviewBadge />
  </body>
</html>
