---
import { stripLocalePrefix, stripBasePath, getLocalizedPath, getLocale } from '../i18n/utils';
import { getDictionary } from '../i18n/dictionary';
import Navigation from '../components/ui/Navigation.astro';
import PreviewBadge from '../components/ui/PreviewBadge.astro';
import type { LocaleStrings, HomeNavStrings } from '../i18n/dictionary';

interface Props {
  title?: string;
  description?: string;
  locale?: 'th' | 'en';
  dict?: LocaleStrings;
}

const { title, description: customDesc, locale: localeProp, dict: dictProp } = Astro.props;

const lang = localeProp ?? getLocale(Astro.url);
const dict = dictProp ?? await getDictionary(lang);

const skipLabel = dict.site.skip_to_content;
const defaultDesc = dict.home.hero.description;
const desc = customDesc ?? defaultDesc;
const footerTitle = dict.home.footer.title;
const footerDesc = dict.home.footer.description;
const footerCopy = dict.home.footer.copyright;

const pageTitle = title ?? `${dict.site.name} - ${dict.site.title_suffix}`;

const navLabels: HomeNavStrings = dict.home.nav;

const appPath = stripLocalePrefix(stripBasePath(Astro.url.pathname));
const thUrl = Astro.url.origin ? `${Astro.url.origin}${getLocalizedPath('th', appPath)}` : '';
const enUrl = Astro.url.origin ? `${Astro.url.origin}${getLocalizedPath('en', appPath)}` : '';
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={desc} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{pageTitle}</title>

    {thUrl && <link rel="alternate" hreflang="th" href={thUrl} />}
    {enUrl && thUrl !== enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
    {thUrl && <link rel="alternate" hreflang="x-default" href={thUrl} />}
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-stitch focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      {skipLabel}
    </a>
    <header class="sticky top-0 z-50">
      <Navigation
        locale={lang}
        t={navLabels}
        university={dict.site.university}
        platformLabel={dict.site.title_suffix}
      />
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="mt-8 border-t border-primary/10 bg-inverse-surface py-8 text-white">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 text-sm text-outline-variant sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-semibold text-white">{footerTitle}</p>
          <p>{footerDesc}</p>
        </div>
        <p class="text-xs">&copy; {new Date().getFullYear()} {footerCopy}</p>
      </div>
    </footer>
    <PreviewBadge />
  </body>
</html>
