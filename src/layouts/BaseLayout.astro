---
import Navigation from '../components/ui/Navigation.astro';
import PreviewBadge from '../components/ui/PreviewBadge.astro';
import type { LocaleStrings, HomeNavStrings } from '../i18n/dictionary';

interface Props {
  // Legacy: used by all non-landing pages
  title?: string;
  // Custom meta description (optional — falls back to dict or default)
  description?: string;
  // New: used by LandingPage.astro for bilingual support
  locale?: 'th' | 'en';
  dict?: LocaleStrings;
}

const { title, description: customDesc, locale, dict } = Astro.props;

// Determine final values from dict (bilingual) or hardcoded defaults (legacy)
const lang = locale ?? 'en';
const skipLabel = dict?.site?.skip_to_content ?? 'Skip to main content';
const defaultDesc = dict?.home?.hero?.description ?? 'Green Office 2026 static preview with repository-backed dashboards, categories, and evidence placeholders.';
const desc = customDesc ?? defaultDesc;
const footerTitle = dict?.home?.footer?.title ?? 'Green Office 2026';
const footerDesc = dict?.home?.footer?.description ?? 'Static preview. Content and evidence are repository-backed unless marked as placeholder.';
const footerCopy = dict?.home?.footer?.copyright ?? 'Green Office Platform';
const siteTagline = dict?.site?.tagline ?? 'Maejo University';

// Title: either explicit title prop or generated from dict
const pageTitle = title ?? `${dict?.site?.name ?? 'Green Office 2026'} - ${dict?.site?.title_suffix ?? 'Green Office Platform'}`;

// Navigation labels
const navLabels: HomeNavStrings = dict?.home?.nav ?? {
  home: 'Home', dashboard: 'Dashboard', categories: 'Categories',
  evidence: 'Evidence', documents: 'Documents', search: 'Search',
} as HomeNavStrings;

// hreflang alternate links
const canonical = Astro.url.pathname.replace(/^\/en(?:\/|$)/, '/');
const siteUrl = Astro.site?.href.replace(/\/+$/, '') || '';
const thUrl = siteUrl ? `${siteUrl}${canonical}` : '';
const enUrl = siteUrl ? `${siteUrl}/en${canonical}` : '';
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={desc} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{pageTitle}</title>

    <!-- hreflang alternate links for bilingual content -->
    {thUrl && <link rel="alternate" hreflang="th" href={thUrl} />}
    {enUrl && thUrl !== enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
    {thUrl && <link rel="alternate" hreflang="x-default" href={thUrl} />}
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-stitch focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      {skipLabel}
    </a>
    <header>
      <Navigation locale={lang} t={navLabels} />
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="mt-8 border-t border-primary/10 bg-inverse-surface py-8 text-white">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 text-sm text-outline-variant sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-semibold text-white">{footerTitle}</p>
          <p>{footerDesc}</p>
        </div>
        <p class="text-xs">&copy; {new Date().getFullYear()} {footerCopy}</p>
      </div>
    </footer>
    <PreviewBadge />
  </body>
</html>
