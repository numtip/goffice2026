---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { dashboards, dashTitle, dashDescription, dashSourceLabel } from '../../data/dashboard-config';
import type { DashboardMeta } from '../../data/dashboard-config';
import type { MultiYearMetric, YearData } from '../../utils/multi-year-schema';
import categoriesData from '../../data/criteria/categories.json';
import indicatorsData from '../../data/criteria/indicators.json';

import energyGen from '../../data/generated/energy.json';
import waterGen from '../../data/generated/water.json';
import fuelGen from '../../data/generated/fuel.json';
import paperGen from '../../data/generated/paper.json';
import wasteGen from '../../data/generated/waste.json';
import ghgGen from '../../data/generated/ghg.json';
import { getLocale, getLocalizedPath } from '../../i18n/utils';
import { getEvidenceForDashboard } from '../../utils/evidence-traceability';
import LinkedEvidenceList from '../../components/evidence/LinkedEvidenceList.astro';
import {
  resolveDisplayStatus,
  shouldShowYoy,
  hasDisplayableTotal,
} from '../../utils/data-status';

import ExecutiveKpi from '../../components/dashboard/ExecutiveKpi.astro';
import DashboardInsight from '../../components/dashboard/DashboardInsight.astro';
import MonthlyComparisonChart from '../../components/dashboard/MonthlyComparisonChart.astro';
import DashboardEmptyState from '../../components/dashboard/DashboardEmptyState.astro';

const genMap: Record<string, MultiYearMetric> = {
  energy: energyGen as MultiYearMetric,
  water: waterGen as MultiYearMetric,
  fuel: fuelGen as MultiYearMetric,
  paper: paperGen as MultiYearMetric,
  waste: wasteGen as MultiYearMetric,
  ghg: ghgGen as MultiYearMetric,
};

export function getStaticPaths() {
  return dashboards.map((d) => ({
    params: { id: d.id },
    props: { dashboard: d },
  }));
}

const { dashboard } = Astro.props as { dashboard: DashboardMeta };
const locale = getLocale(Astro.url);
const th = locale === 'th';
const metric = genMap[dashboard.id];

const baselineYear = metric?.years[metric.baselineYear.toString()] as YearData | undefined;
const currentYear = metric?.years[metric.currentYear.toString()] as YearData | undefined;
const yoy = metric?.yoyChange;
const target = metric?.target;

const category = dashboard.categoryId
  ? categoriesData.categories.find((c: { code: string }) => c.code === dashboard.categoryId)
  : null;

const relatedIndicators = indicatorsData.indicators.filter(
  (ind: { relatedDashboards: string[] }) => ind.relatedDashboards.includes(dashboard.id)
);
const linkedEvidence = getEvidenceForDashboard(dashboard.id);

const monthAbbr = th
  ? ['', 'ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.', 'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.']
  : ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

const currentDisplayStatus = resolveDisplayStatus(currentYear);
const showYoy = shouldShowYoy(currentYear);
const showCurrentTotal = hasDisplayableTotal(currentYear);
const pageTitle = dashTitle(dashboard, locale);
const pageDescription = dashDescription(dashboard, locale);

const fmt = (v: number) => Intl.NumberFormat(th ? 'th' : 'en').format(Math.round(v));

const yoyColor = (pct: number) => pct <= -5 ? 'text-green-600' : pct >= 5 ? 'text-red-600' : 'text-amber-600';
const yoyArrow = (dir: string) => dir === 'up' ? '\u2191' : dir === 'down' ? '\u2193' : '\u2192';
const yoyPctText = yoy ? `${yoy.percent > 0 ? '+' : ''}${yoy.percent}% ${yoyArrow(yoy.direction)}` : null;

// Prev/next navigation
const dashIndex = dashboards.findIndex((d) => d.id === dashboard.id);
const prevDash = dashIndex > 0 ? dashboards[dashIndex - 1] : null;
const nextDash = dashIndex < dashboards.length - 1 ? dashboards[dashIndex + 1] : null;

const showTargetMarker = target?.status !== 'TARGET_PENDING_APPROVAL' && (target?.months?.length ?? 0) > 0;
---

<BaseLayout title={pageTitle} description={pageDescription} locale={locale}>
  <div class="p-4 max-w-6xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="text-xs text-outline-variant mb-4" aria-label={th ? 'เส้นทาง' : 'Breadcrumb'}>
      <a href={getLocalizedPath(locale, '/')} class="text-primary hover:underline">{th ? 'หน้าแรก' : 'Home'}</a>
      <span class="mx-1.5" aria-hidden="true">/</span>
      <a href={getLocalizedPath(locale, '/dashboard')} class="text-primary hover:underline">{th ? 'แดชบอร์ด' : 'Dashboard'}</a>
      <span class="mx-1.5" aria-hidden="true">/</span>
      <span class="text-on-surface font-medium">{pageTitle}</span>
    </nav>

    {metric && baselineYear ? (
      <>
        <!-- Resource Header -->
        <section class="mb-6">
          <h1 class="text-2xl font-bold text-on-surface">{pageTitle}</h1>
          <p class="text-sm text-outline-variant mt-1">{pageDescription}</p>
        </section>

        <!-- KPI Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
          <ExecutiveKpi
            label={th ? `ปีฐาน (${metric.baselineYear})` : `Baseline (${metric.baselineYear})`}
            value={fmt(baselineYear.total)}
            unit={metric.unit}
            subtext={th ? `ข้อมูลปีฐานครบถ้วน · ${baselineYear.months.length} เดือน` : `Frozen baseline · ${baselineYear.months.length} months`}
            trendLabel={th ? 'ตรวจสอบแล้ว' : 'Verified'}
            trendColor="text-green-600"
          />
          <ExecutiveKpi
            label={th ? `เป้าหมาย (${metric.targetYear ?? metric.currentYear})` : `Target (${metric.targetYear ?? metric.currentYear})`}
            value={target && target.targetValue !== null ? fmt(target.targetValue) : (th ? 'TBD' : 'TBD')}
            unit={metric.unit}
            subtext={target && target.status === 'TARGET_PENDING_APPROVAL' ? (th ? 'รอการอนุมัติจากเจ้าหน้าที่' : 'Awaiting staff approval') : (th ? 'เป้าหมายการลดใช้' : 'Reduction target')}
            trendLabel={target?.status === 'TARGET_PENDING_APPROVAL' ? (th ? 'ยังไม่ยืนยัน' : 'Unconfirmed') : undefined}
            trendColor="text-amber-600"
          />
          <ExecutiveKpi
            label={th ? `ปีปัจจุบัน (${metric.currentYear})` : `Current (${metric.currentYear})`}
            value={showCurrentTotal ? fmt(currentYear?.total ?? 0) : (th ? 'ไม่มีข้อมูล' : 'No data')}
            unit={metric.unit}
            subtext={showCurrentTotal ? (th ? `${currentYear?.months.length ?? 0} จาก 12 เดือน` : `${currentYear?.months.length ?? 0} of 12 months`) : (th ? 'ยังไม่มีข้อมูล' : 'Data not yet available')}
            trendLabel={showYoy && yoyPctText ? yoyPctText : undefined}
            trendColor={showYoy && yoy ? yoyColor(yoy.percent) : 'text-outline'}
          />
        </div>

        <!-- YoY Context -->
        {showYoy && yoy && currentYear && (
          <DashboardInsight
            heading={th ? 'การเปลี่ยนแปลงเทียบปีก่อน' : 'Year-over-Year Change'}
            body={th
              ? `เทียบกับปีฐาน ${metric.baselineYear} (ครบ 12 เดือน): ${yoyPctText} (${fmt(Math.abs(yoy.absolute))}${metric.unit} ${yoy.direction === 'up' ? 'เพิ่มขึ้น' : yoy.direction === 'down' ? 'ลดลง' : 'คงที่'})`
              : `vs ${metric.baselineYear} baseline (full 12 months): ${yoyPctText} (${fmt(Math.abs(yoy.absolute))}${metric.unit} ${yoy.direction === 'up' ? 'increase' : yoy.direction === 'down' ? 'decrease' : 'stable'})`}
            type={yoy.direction === 'down' ? 'positive' : yoy.direction === 'up' ? 'warning' : 'neutral'}
          />
        )}

        <!-- Partial-Year Warning -->
        {currentYear && currentDisplayStatus === 'in_progress' && currentYear.months.length < 12 && (
          <DashboardInsight
            heading={th ? 'ข้อมูลยังไม่ครบปี' : 'Partial-Year Comparison'}
            body={th
              ? `ปี ${metric.currentYear} มีข้อมูลแล้ว ${currentYear.months.length} จาก 12 เดือน ตัวเลขเทียบปีข้างต้นจึงเป็นการเทียบกับข้อมูลปีฐาน ${metric.baselineYear} แบบยังไม่ครบปี อาจไม่สะท้อนแนวโน้มที่แท้จริงทั้งปี ตัวเลขจะปรับเปลี่ยนเมื่อมีการบันทึกข้อมูลเดือนใหม่เพิ่มขึ้น`
              : `2569 (current year) has data for ${currentYear.months.length} of 12 months. The YoY comparison above reflects a partial-year comparison against the full ${metric.baselineYear} baseline and may not be representative of the full annual trend. Data entry is ongoing.`}
            type="warning"
          />
        )}

        <!-- Month Coverage Visualization -->
        {currentYear && (
          <div class="bg-white rounded-stitch-lg border border-outline-variant/20 p-5 shadow-sm mb-6">
            <h3 class="text-sm font-semibold text-on-surface mb-2">
              {th ? `ความคืบหน้าการบันทึกข้อมูล ปี ${metric.currentYear}` : `${metric.currentYear} Data Entry Progress`}
            </h3>
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs text-outline-variant">
                {th ? `บันทึกแล้ว ${currentYear.months.length} จาก 12 เดือน` : `${currentYear.months.length} of 12 months entered`}
              </span>
            </div>
            <div class="grid grid-cols-12 gap-1">
              {Array.from({ length: 12 }, (_, i) => i + 1).map((m) => {
                const hasData = currentYear.months.some((mo) => mo.month === m);
                const monthStatus = hasData ? (th ? 'มีข้อมูลแล้ว' : 'Data present') : (th ? 'ยังไม่มีข้อมูล' : 'Pending');
                return (
                  <div class="flex flex-col items-center" title={`${monthAbbr[m]} — ${monthStatus}`}>
                    <span
                      class={`flex h-5 w-full items-center justify-center rounded-sm text-[10px] font-bold ${hasData ? 'bg-green-600 text-white' : 'bg-gray-200 text-black'}`}
                      aria-label={`${monthAbbr[m]} — ${monthStatus}`}
                    >{hasData ? '\u2713' : '\u2013'}</span>
                    <span class="mt-0.5 text-[10px] text-outline-variant">{monthAbbr[m]}</span>
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <!-- Monthly Comparison Chart -->
        {baselineYear && (
          <MonthlyComparisonChart
            title={th ? `เปรียบเทียบข้อมูลรายเดือน: ${metric.baselineYear} เทียบกับ ${metric.currentYear}` : `Monthly Comparison: ${metric.baselineYear} vs ${metric.currentYear}`}
            description={th
              ? `แท่งสีเขียวเข้ม = ปีฐาน, แท่งสีเขียวอ่อน = ปีปัจจุบัน${showTargetMarker ? ', แท่งสีเหลือง = เป้าหมาย' : ''}`
              : `Dark bars = Baseline, Light bars = Current${showTargetMarker ? ', Amber bars = Target' : ''}`}
            months={Array.from({ length: 12 }, (_, i) => {
              const m = i + 1;
              const bVal = baselineYear.months.find((mo) => mo.month === m);
              const cVal = currentYear?.months.find((mo) => mo.month === m);
              const tVal = showTargetMarker ? target?.months.find((tm) => tm.month === m) : undefined;
              return {
                month: m,
                label: monthAbbr[m],
                baseline: bVal?.value,
                current: cVal?.value,
                target: tVal?.value,
              };
            })}
            unit={metric.unit}
            baselineLabel={th ? `ปีฐาน ${metric.baselineYear}` : `${metric.baselineYear} Baseline`}
            currentLabel={th ? `ปีปัจจุบัน ${metric.currentYear}` : `${metric.currentYear} Current`}
            targetLabel={th ? `เป้าหมาย ${metric.targetYear ?? metric.currentYear}` : `${metric.targetYear ?? metric.currentYear} Target`}
            showTarget={showTargetMarker}
            locale={locale}
            baselineColor="#003527"
            currentColor="#006c49"
            targetColor="#d97706"
          />
        )}

        <!-- Provenance -->
        {baselineYear.provenance && (
          <div class="bg-white rounded-stitch-lg border border-blue-200 p-5 shadow-sm mb-6">
            <h3 class="text-sm font-semibold text-blue-700 mb-3 flex items-center gap-2">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              {th ? 'ที่มาของข้อมูล' : 'Provenance & Source Attribution'}
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 text-xs">
              <div class="space-y-1">
                <p class="text-outline-variant">{th ? 'ไฟล์ต้นฉบับ' : 'Source Workbook'}</p>
                <p class="text-on-surface font-mono">{baselineYear.provenance.sourceWorkbook}</p>
              </div>
              <div class="space-y-1">
                <p class="text-outline-variant">{th ? 'ชีตข้อมูล' : 'Source Sheet'}</p>
                <p class="text-on-surface font-mono">{baselineYear.provenance.sourceSheet}</p>
              </div>
              {baselineYear.provenance.sourceColumn && (
                <div class="space-y-1">
                  <p class="text-outline-variant">{th ? 'คอลัมน์ข้อมูล' : 'Source Column'}</p>
                  <p class="text-on-surface font-mono">{baselineYear.provenance.sourceColumn}</p>
                </div>
              )}
              <div class="space-y-1">
                <p class="text-outline-variant">{th ? 'สคริปต์ดึงข้อมูล' : 'Extraction Script'}</p>
                <p class="text-on-surface font-mono">{baselineYear.provenance.extractionScript}</p>
              </div>
              <div class="space-y-1">
                <p class="text-outline-variant">{th ? 'เวลาที่ดึงข้อมูล' : 'Extraction Timestamp'}</p>
                <p class="text-on-surface font-mono">{baselineYear.provenance.extractionTimestamp}</p>
              </div>
            </div>
          </div>
        )}

        <!-- Data Interpretation -->
        <DashboardInsight
          heading={th ? 'การตีความข้อมูล' : 'Data Interpretation'}
          body={th
            ? `ข้อมูลนี้มาจาก ${baselineYear.source} และถูกประมวลผลอัตโนมัติผ่าน pipeline นำเข้าข้อมูลของระบบ หน่วยงานที่เกี่ยวข้อง: ${category ? category.title.th : dashboard.kpiLabelTh || dashboard.kpiLabel}`
            : `Data sourced from ${baselineYear.source} and processed automatically through the repository import pipeline. Relevant department: ${category ? category.title.en : dashboard.kpiLabel}`}
          type="info"
        />

        <!-- Category & Source metadata -->
        <div class="bg-surface-container rounded-stitch-lg border border-outline-variant/20 p-4 text-xs text-outline-variant mb-6">
          {category ? (
            <p class="mb-1">
              {th ? 'หมวด' : 'Category'}: <a href={getLocalizedPath(locale, `/categories/${category.code}`)} class="text-primary underline hover:text-primary-container">
                {th ? category.title.th : category.title.en}
              </a>
            </p>
          ) : (
            <p class="mb-1">{th ? 'แดชบอร์ดติดตามการใช้ทรัพยากร (ไม่ได้ผูกกับหมวดการประเมินใดหมวดหนึ่งโดยตรง)' : 'Resource monitoring dashboard (not tied to a single certification category)'}</p>
          )}
          <div class="space-y-0.5 mt-2">
            <p><strong>{th ? `ปีฐาน ${metric.baselineYear}:` : `${metric.baselineYear} Baseline:`}</strong> {baselineYear.source} &middot; {th ? 'อัปเดตเมื่อ' : 'Updated'}: {baselineYear.updated}</p>
            <p><strong>{th ? `ปีปัจจุบัน ${metric.currentYear}:` : `${metric.currentYear} Current:`}</strong> {currentYear?.source} &middot; {th ? 'อัปเดตเมื่อ' : 'Updated'}: {currentYear?.updated}</p>
            <p>{th ? 'โครงสร้างข้อมูล' : 'Data model'}: <code>src/data/generated/{metric.metric}.json</code> &middot; {th ? 'อ้างอิง' : 'Ref'}: {dashSourceLabel(dashboard, locale)}</p>
          </div>
        </div>

      </>
    ) : (
      <DashboardEmptyState
        title={th ? 'ยังไม่มีข้อมูลเข้าสู่ระบบ' : 'Data Ingest Pending'}
        body={th
          ? 'ยังไม่มีการบันทึกข้อมูลหลายปีของแดชบอร์ดนี้เข้าสู่ระบบ เจ้าหน้าที่กำลังรวบรวมข้อมูลจากไฟล์ Excel เมื่อข้อมูลพร้อม หน้านี้จะแสดงการเปรียบเทียบรายเดือน อัตราการเปลี่ยนแปลงเทียบปีก่อน และแนวโน้มการใช้ทรัพยากรโดยอัตโนมัติ'
          : 'Multi-year monitoring data for this dashboard has not yet been entered into the system. Staff are currently compiling data from Excel records. Once available, this page will automatically display monthly comparisons, year-over-year rates, and resource trends.'}
        backHref={getLocalizedPath(locale, '/dashboard')}
        backLabel={th ? 'กลับไปภาพรวมแดชบอร์ด' : 'Back to Dashboard Overview'}
        extraLinks={category ? [{ href: getLocalizedPath(locale, `/categories/${category.code}`), label: th ? `หมวด: ${category.title.th}` : `Category: ${category.title.en}` }] : []}
      />
    )}

    <!-- Linked Evidence -->
    {linkedEvidence.length > 0 ? (
      <div class="bg-white rounded-stitch-lg border border-outline-variant/20 p-5 shadow-sm mb-6">
        <LinkedEvidenceList items={linkedEvidence} locale={locale} headingId="dashboard-linked-evidence" />
      </div>
    ) : (
      <div class="bg-surface-container rounded-stitch-lg border border-outline-variant/20 p-5 mb-6">
        <h2 class="text-sm font-semibold text-on-surface mb-2">{th ? 'หลักฐานที่เชื่อมโยง' : 'Linked Evidence'}</h2>
        <p class="text-sm text-outline-variant">{th ? 'ยังไม่มีรายการหลักฐานที่เชื่อมโยงกับแดชบอร์ดนี้ ระบบจะแสดงรายการที่นี่เมื่อมีการแมปหลักฐานจากดัชนีของระบบ' : 'No evidence records are currently linked to this dashboard. Records will appear here once evidence is mapped from the repository index.'}</p>
        <div class="mt-3">
          <a href={getLocalizedPath(locale, '/evidence')} class="inline-flex items-center gap-1.5 text-sm text-primary hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-sm">
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.707-10.293a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L9.414 11H13a1 1 0 100-2H9.414l1.293-1.293z" clip-rule="evenodd"/></svg>
            {th ? 'เรียกดูคลังหลักฐาน' : 'Browse Evidence Library'}
          </a>
        </div>
      </div>
    )}

    <!-- Related Indicators -->
    {relatedIndicators.length > 0 ? (
      <div class="bg-white rounded-stitch-lg border border-outline-variant/20 p-5 shadow-sm mb-6">
        <h2 class="text-sm font-semibold text-on-surface mb-2">{th ? 'ตัวชี้วัดที่เกี่ยวข้อง' : 'Related Indicators'}</h2>
        <div class="flex flex-wrap gap-2">
          {relatedIndicators.map((ind: any) => (
            <a
              href={getLocalizedPath(locale, `/indicators/${ind.code}/`)}
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-green-50 border border-green-200 text-sm text-green-700 hover:bg-green-100 transition-colors"
            >
              <span class="text-[10px] font-mono text-green-500">{ind.code}</span>
              <span>{th ? ind.title.th : ind.title.en}</span>
            </a>
          ))}
        </div>
      </div>
    ) : (
      <div class="bg-surface-container rounded-stitch-lg border border-outline-variant/20 p-5 mb-6">
        <h2 class="text-sm font-semibold text-on-surface mb-2">{th ? 'ตัวชี้วัดที่เกี่ยวข้อง' : 'Related Indicators'}</h2>
        <p class="text-sm text-outline-variant">{th ? 'ยังไม่มีตัวชี้วัดที่แมปกับแดชบอร์ดนี้ในระบบ ตัวชี้วัดจะปรากฏที่นี่เมื่อมีการกำหนดค่าในการตั้งค่ากลุ่มข้อมูล' : 'No indicators are currently mapped to this dashboard. Indicators will appear here once configured in the taxonomy settings.'}</p>
        <div class="mt-3">
          <a href={getLocalizedPath(locale, '/dashboard')} class="inline-flex items-center gap-1.5 text-sm text-primary hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 rounded-sm">
            <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm.707-10.293a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L9.414 11H13a1 1 0 100-2H9.414l1.293-1.293z" clip-rule="evenodd"/></svg>
            {th ? 'กลับไปภาพรวมแดชบอร์ด' : 'View Dashboard Overview'}
          </a>
        </div>
      </div>
    )}

    <!-- Prev / Next Navigation -->
    <nav class="flex items-center justify-between gap-4 mt-8 pt-6 border-t border-outline-variant/20" aria-label={th ? 'การนำทางแดชบอร์ด' : 'Dashboard navigation'}>
      {prevDash ? (
        <a href={getLocalizedPath(locale, `/dashboard/${prevDash.id}`)} class="flex items-center gap-2 text-sm text-primary hover:text-primary-container transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          <span class="hidden sm:inline">{th ? 'ก่อนหน้า' : 'Previous'}:</span>
          <span class="font-medium">{dashTitle(prevDash, locale)}</span>
        </a>
      ) : <div />}
      {nextDash ? (
        <a href={getLocalizedPath(locale, `/dashboard/${nextDash.id}`)} class="flex items-center gap-2 text-sm text-primary hover:text-primary-container transition-colors">
          <span class="hidden sm:inline">{th ? 'ถัดไป' : 'Next'}:</span>
          <span class="font-medium">{dashTitle(nextDash, locale)}</span>
          <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
        </a>
      ) : <div />}
    </nav>

  </div>
</BaseLayout>
