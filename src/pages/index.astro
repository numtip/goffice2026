---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import categoriesData from '../data/categories.json';
import dashboardKpi from '../data/dashboard-kpi.json';
import evidenceIndex from '../data/evidence-index.json';

import LandingHero from '../components/landing/LandingHero.astro';
import MissionScene from '../components/landing/MissionScene.astro';
import ExecutiveCommandCenter from '../components/landing/ExecutiveCommandCenter.astro';
import AssessmentFramework from '../components/landing/AssessmentFramework.astro';
import EvidenceGateway from '../components/landing/EvidenceGateway.astro';
import ActivitiesScene from '../components/landing/ActivitiesScene.astro';
import ImprovementJourney from '../components/landing/ImprovementJourney.astro';
import LandingCTA from '../components/landing/LandingCTA.astro';

const previewEvidence = evidenceIndex.items.slice(0, 3);
const availableItems = evidenceIndex.items.filter((i) => i.status === 'available').length;
---

<BaseLayout title="Green Office Home">
  <div class="landing-page -mt-8 bg-surface text-on-surface">
    <LandingHero overallScore={dashboardKpi.overallScore} />
    <MissionScene />
    <ExecutiveCommandCenter />
    <AssessmentFramework categories={categoriesData.categories} />
    <EvidenceGateway
      items={previewEvidence}
      totalItems={evidenceIndex.items.length}
      availableItems={availableItems}
    />
    <ActivitiesScene />
    <ImprovementJourney />
    <LandingCTA />
  </div>
</BaseLayout>
