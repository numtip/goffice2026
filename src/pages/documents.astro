---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import categoriesData from '../data/criteria/categories.json';
import evidenceIndex from '../data/evidence-index.json';
import { getLocale } from '../i18n/utils';
import { withBase } from '../utils/with-base';

const locale = getLocale(Astro.url);

function getDocumentCounts(categoryCode: string) {
  const items = evidenceIndex.items.filter((item) => {
    const codes = Array.isArray(item.categoryCodes) ? item.categoryCodes : item.categoryId ? [item.categoryId] : [];
    return codes.includes(categoryCode);
  });
  return {
    total: items.length,
    available: items.filter((i) => i.status === 'available').length,
  };
}
---

<BaseLayout title={locale === 'th' ? 'ศูนย์เอกสาร | Document Center' : 'Document Center | ศูนย์เอกสาร'} description="Browse and download Green Office certification evidence documents organized by assessment category.">
  <div class="p-4 max-w-5xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Document Center</h1>
      <p class="text-gray-600 mt-2">
        Browse and download certification evidence documents organized by Green Office category.
      </p>
    </div>

    <!-- Category grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {categoriesData.categories.map((category) => {
        const { total, available } = getDocumentCounts(category.code);
        const allAvailable = total > 0 && total === available;
        const badgeBg = allAvailable ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600';
        const catTitle = locale === 'th' ? (category.title.th || category.title.en) : category.title.en;
        const catDesc = locale === 'th' ? (category.summary.th || category.summary.en) : category.summary.en;
        return (
          <a
            href={withBase(`/documents/${category.code}`)}
            class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md hover:border-green-200 transition-all group"
          >
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <h2 class="font-bold text-green-700 group-hover:text-green-800 text-lg">
                  {catTitle}
                </h2>
                <p class="text-sm text-gray-600 mt-1">{catDesc}</p>
              </div>
              <span class={"inline-flex items-center px-3 py-1 rounded-full text-sm font-medium shrink-0 ml-3 " + badgeBg}>
                {available}/{total} file{total !== 1 ? 's' : ''}
              </span>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Summary -->
    <div class="mt-8 text-center text-xs text-gray-400">
      Total: {categoriesData.categories.length} categories &middot; {evidenceIndex.items.length} evidence items
    </div>
  </div>
</BaseLayout>
