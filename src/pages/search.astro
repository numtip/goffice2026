---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import categoriesData from '../data/categories.json';
import evidenceIndex from '../data/evidence-index.json';

const plannedIndexFields = [
  'Page and category titles',
  'Category short names and descriptions',
  'Evidence item titles and types',
  'Document paths under public/documents/',
];
---

<BaseLayout title="Search">
  <div class="p-4 max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Search</h1>
    <p class="text-gray-600 mb-4">
      Static placeholder only. No search engine or client-side index is active in Sprint 0.1.
    </p>
    <p class="text-gray-600 mb-6">
      A future sprint will add build-time search over titles, categories, and evidence metadata
      from <code class="text-sm bg-gray-100 px-1 rounded">categories.json</code> and{' '}
      <code class="text-sm bg-gray-100 px-1 rounded">evidence-index.json</code>.
    </p>

    <section class="bg-white rounded-lg shadow p-4 mb-6">
      <h2 class="text-lg font-semibold mb-3">Planned index scope</h2>
      <ul class="list-disc list-inside text-gray-700 space-y-1">
        {plannedIndexFields.map((field) => (
          <li>{field}</li>
        ))}
      </ul>
    </section>

    <section class="bg-gray-100 rounded-lg p-4 mb-6">
      <h2 class="text-lg font-semibold mb-3">Preview: searchable titles (static list)</h2>
      <ul class="text-sm text-gray-700 space-y-2">
        {categoriesData.categories.map((category) => (
          <li>
            <span class="font-medium">{category.title}</span>
            <span class="text-gray-500"> — category {category.id}</span>
          </li>
        ))}
        {evidenceIndex.items.map((item) => (
          <li>
            <span class="font-medium">{item.title}</span>
            <span class="text-gray-500"> — evidence · {item.categoryId}</span>
          </li>
        ))}
      </ul>
    </section>

    <div class="bg-white rounded-lg shadow p-4 opacity-75">
      <label for="q" class="block text-sm font-medium text-gray-700 mb-2">Search query (disabled)</label>
      <input
        id="q"
        name="q"
        type="search"
        disabled
        placeholder="Search will be enabled in a later sprint..."
        class="w-full border border-gray-300 rounded px-3 py-2 bg-gray-50 text-gray-500 cursor-not-allowed"
      />
      <p class="text-xs text-gray-500 mt-2">Form is non-functional by design for this sprint.</p>
    </div>
  </div>
</BaseLayout>
