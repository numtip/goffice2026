---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---

<BaseLayout title="Search">
  <div class="p-4 max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Search</h1>
    <p class="text-gray-600 mb-6">Placeholder search page. Client-side search across evidence and documents will be added in a later sprint.</p>

    <form class="bg-white rounded-lg shadow p-4" action="/search" method="get">
      <label for="q" class="block text-sm font-medium text-gray-700 mb-2">Search query</label>
      <input
        id="q"
        name="q"
        type="search"
        placeholder="Search evidence, documents, categories..."
        class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-green-500"
      />
      <button
        type="submit"
        class="mt-4 bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 transition"
      >
        Search (placeholder)
      </button>
    </form>
  </div>
</BaseLayout>
