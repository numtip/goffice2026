---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import categoriesData from '../../../data/criteria/categories.json';
import evidenceIndex from '../../../data/evidence-index.json';
import EvidenceCard from '../../../components/evidence/EvidenceCard.astro';
import { getLocale, getLocalizedPath } from '../../../i18n/utils';

const locale = getLocale(Astro.url);

export function getStaticPaths() {
  return categoriesData.categories.map((category) => ({
    params: { id: category.code },
    props: {
      category,
      documents: evidenceIndex.items.filter((item) => {
        const codes = Array.isArray(item.categoryCodes) ? item.categoryCodes : item.categoryId ? [item.categoryId] : [];
        return codes.includes(category.code);
      }),
    },
  }));
}

const { category, documents } = Astro.props;
const catTitle = locale === 'th' ? (category.title.th || category.title.en) : category.title.en;
const catSummary = locale === 'th' ? (category.summary.th || category.summary.en) : category.summary.en;
const availableCount = documents.filter((d) => d.status === 'available').length;
const placeholderCount = documents.filter((d) => d.status === 'placeholder').length;
---

<BaseLayout title={`${locale === 'th' ? 'เอกสาร' : 'Documents'}: ${catTitle}`} description={catSummary} locale={locale}>
  <div class="p-4 max-w-4xl mx-auto">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href={getLocalizedPath(locale, '/documents')} class="text-green-600 underline hover:text-green-800">Document Center</a>
      <span aria-hidden="true"> / </span>
      <span class="text-gray-700 font-medium">{catTitle}</span>
    </nav>

    <!-- Category header -->
    <div class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-2">
        <h1 class="text-2xl font-bold text-gray-900">{catTitle}</h1>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
          {availableCount} available
        </span>
        {placeholderCount > 0 && (
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-500">
            {placeholderCount} placeholder{placeholderCount !== 1 ? 's' : ''}
          </span>
        )}
      </div>
      <p class="text-gray-600">{catSummary}</p>
    </div>

    <!-- Evidence / Documents -->
    {documents.length > 0 ? (
      <section class="space-y-4">
        <h2 class="text-xl font-semibold text-gray-800">Evidence Items</h2>
        {documents.map((doc) => (
          <EvidenceCard
            id={doc.id}
            title={doc.title}
            description={doc.description}
            year={doc.year}
            fileType={doc.fileType}
            status={doc.status}
            traceabilityLevel={doc.traceabilityLevel || 'category'}
            verificationStatus={(doc.verification?.status) || 'unresolved'}
            locale={locale}
          />
        ))}
      </section>
    ) : (
      <div class="text-center py-12 bg-white rounded-xl border border-dashed border-gray-300">
        <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <p class="text-gray-500 text-lg">No evidence files indexed for this category yet.</p>
        <p class="text-gray-400 text-sm mt-1">Documents will appear here once uploaded.</p>
      </div>
    )}

    <!-- Back link -->
    <div class="mt-8">
      <a href={getLocalizedPath(locale, `/categories/${category.code}`)} class="text-green-600 underline hover:text-green-800 text-sm">
        &larr; Back to {catTitle} overview
      </a>
    </div>
  </div>
</BaseLayout>
