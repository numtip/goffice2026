---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import dashboardKpi from '../../../data/dashboard-kpi.json';
import { dashboards } from '../../../data/dashboard-config';
import type { MultiYearMetric } from '../../../utils/multi-year-schema';

import energyGen from '../../../data/generated/energy.json';
import waterGen from '../../../data/generated/water.json';
import fuelGen from '../../../data/generated/fuel.json';
import paperGen from '../../../data/generated/paper.json';
import wasteGen from '../../../data/generated/waste.json';
import ghgGen from '../../../data/generated/ghg.json';
import { getLocalizedPath } from '../../../i18n/utils';
import { getDictionary } from '../../../i18n/dictionary';
import {
  resolveDisplayStatus,
  shouldShowYoy,
  statusBadgeClass,
} from '../../../utils/data-status';

const genMap: Record<string, MultiYearMetric> = {
  energy: energyGen as MultiYearMetric,
  water: waterGen as MultiYearMetric,
  fuel: fuelGen as MultiYearMetric,
  paper: paperGen as MultiYearMetric,
  waste: wasteGen as MultiYearMetric,
  ghg: ghgGen as MultiYearMetric,
};

const trendLabel: Record<string, string> = {
  up: '\u2191',
  down: '\u2193',
  stable: '\u2192',
};
const trendColors: Record<string, string> = {
  up: 'text-green-500',
  down: 'text-red-500',
  stable: 'text-gray-400',
};

function yoyColor(percent: number): string {
  if (percent <= -5) return 'text-green-600';
  if (percent >= 5) return 'text-red-600';
  return 'text-yellow-600';
}

const locale = 'en' as const;
const dict = await getDictionary(locale);
const t = dict.dashboardPage;

const monthAbbr = ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
---

<BaseLayout title="Dashboard | แดชบอร์ด" description={t.subtitle} locale={locale}>
  <div class="p-4 max-w-5xl mx-auto">
    <!-- Header -->
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">{t.title}</h1>
      <p class="text-gray-600 mt-1">
        {t.subtitle}
      </p>
      <p class="text-xs text-gray-400 mt-1">
        {t.reference_label}: <a href="https://goffice.mju.ac.th/" class="underline hover:text-green-600" target="_blank">goffice.mju.ac.th</a>
        &middot; {t.updated_label}: {dashboardKpi.updated}
      </p>
    </div>

    <!-- Overall Score -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
      <p class="text-sm text-gray-500 mb-1">{t.overall_score_label}</p>
      <p class="text-4xl font-bold text-green-600">{dashboardKpi.overallScore}<span class="text-2xl">%</span></p>
      <p class="text-xs text-gray-400 mt-2">
        {t.taxonomy_summary}
        &middot; <a href="https://goffice.mju.ac.th/green-office-7cat-2568" class="underline hover:text-green-600" target="_blank">{t.view_reference}</a>
      </p>
    </div>

    <!-- Multi-Year Resource Monitoring -->
    <h2 class="text-lg font-semibold text-gray-800 mb-3">{t.yoy_heading}</h2>
    <p class="text-sm text-gray-500 mb-3">
      {t.yoy_caption}
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
      {dashboards.map((d) => {
        const m = genMap[d.id];
        const yoy = m?.yoyChange;
        const baseline = m ? m.years[m.baselineYear.toString()] : null;
        const current = m ? m.years[m.currentYear.toString()] : null;
        const displayStatus = resolveDisplayStatus(current ?? undefined);
        const showYoy = shouldShowYoy(current ?? undefined);
        return (
          <a
            href={getLocalizedPath(locale, `/dashboard/${d.id}`)}
            class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md hover:border-green-200 transition-all group"
          >
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-semibold text-green-700 group-hover:text-green-800">{d.title}</h3>
              {current && (
                <span class={"inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium shrink-0 ml-3 " + statusBadgeClass(displayStatus)} title={`${current.months.length}/12 ${t.months_unit}`}>
                  {current.months.length}
                  <span class="text-gray-500 font-normal">/12</span>
                </span>
              )}
            </div>

            <p class="text-sm text-gray-600 line-clamp-2">{d.description}</p>

            {m && baseline && current ? (
              <div class="mt-3 grid grid-cols-2 gap-2 text-xs border-t border-gray-50 pt-3">
                <div>
                  <span class="text-gray-400 block">{m.baselineYear} <span class="text-green-600 font-medium">{t.baseline_label}</span></span>
                  <span class="font-medium text-gray-800">{Intl.NumberFormat().format(baseline.total)}{m.unit}</span>
                  <span class="text-gray-400 ml-1">(12 {t.months_unit})</span>
                </div>
                <div>
                  <span class="text-gray-400 block">{m.currentYear} <span class="text-amber-600 font-medium">{t.current_label}</span></span>
                  <span class="font-medium text-gray-800">{Intl.NumberFormat().format(current.total)}{m.unit}</span>
                  <span class="text-gray-400 ml-1">({current.months.length} {t.months_unit})</span>
                </div>
                <div class="col-span-2 mt-1">
                  <span class="text-gray-400">{t.yoy_prefix}: </span>
                  {showYoy && yoy ? (
                    <span class={yoyColor(yoy.percent)}>
                      {yoy.percent > 0 ? '+' : ''}{yoy.percent}% {trendLabel[yoy.direction]}
                    </span>
                  ) : displayStatus === 'in_progress' ? (
                    <span class="text-amber-600 text-xs">{t.partial_year_tag} — N/A</span>
                  ) : (
                    <span class="text-gray-400 text-xs">—</span>
                  )}
                </div>
              </div>
            ) : (
              <div class="mt-3 text-xs text-gray-400 italic border-t border-gray-50 pt-3">
                {t.data_pending}
              </div>
            )}
          </a>
        );
      })}
    </div>

    <!-- Partial-Year Caveat -->
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-4 mb-6 flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
      <div>
        <p class="text-sm font-semibold text-amber-800">{t.partial_year_title}</p>
        <p class="text-xs text-amber-700 mt-1">
          {t.partial_year_body}
        </p>
      </div>
    </div>

    <!-- Certification Category Scores -->
    <h2 class="text-lg font-semibold text-gray-800 mb-3">{t.category_scores_heading}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      {dashboardKpi.kpis.filter((k) => k.categoryId).map((kpi) => {
        const catId = kpi.categoryId!;
        const dash = dashboards.find((d) => d.id === kpi.id);
        return (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <p class="text-sm text-gray-500">{kpi.label}</p>
            <p class="text-2xl font-bold text-green-600 mt-1">
              {kpi.value}{kpi.unit}
              {kpi.trend && (
                <span class={"text-base ml-1 " + (trendColors[kpi.trend] || 'text-gray-400')}>
                  {trendLabel[kpi.trend] ?? ''}
                </span>
              )}
            </p>
            <p class="text-xs text-gray-400 mt-1">{kpi.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <a href={getLocalizedPath(locale, `/categories/${catId}`)} class="text-xs text-green-600 underline hover:text-green-800">
                {t.category_prefix} {catId.replace('cat', '')}
              </a>
              {dash ? (
                <a href={getLocalizedPath(locale, `/dashboard/${dash.id}`)} class="text-xs text-blue-600 underline hover:text-blue-800">
                  {t.dashboard_link} &rarr;
                </a>
              ) : null}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Data Completeness -- Heatmap Grid -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-6">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-semibold text-gray-700">{t.completeness_heading}</h3>
        <div class="flex items-center gap-3 text-xs text-gray-400">
          <span class="flex items-center gap-1">
            <span class="inline-block w-2.5 h-2.5 rounded-sm bg-green-400"></span> {t.legend_present}
          </span>
          <span class="flex items-center gap-1">
            <span class="inline-block w-2.5 h-2.5 rounded-sm bg-gray-200"></span> {t.legend_pending}
          </span>
        </div>
      </div>
      <p class="text-xs text-gray-400 mb-2">{t.completeness_note}</p>
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr>
              <th class="text-left font-medium text-gray-500 pr-3 py-1">{t.table_metric}</th>
              <th class="text-center font-medium text-gray-500 px-1 py-1" colspan="12">{t.table_month}</th>
              <th class="text-center font-medium text-gray-500 pl-3 py-1">{t.table_total}</th>
            </tr>
          </thead>
          <tbody>
            {dashboards.map((d) => {
              const metricData = genMap[d.id];
              const curYear = metricData ? metricData.years[metricData.currentYear.toString()] : null;
              const monthPresent = (num: number) => curYear ? curYear.months.some((mo) => mo.month === num) : false;
              const monthCount = curYear ? curYear.months.length : 0;
              return (
                <tr class="border-t border-gray-50">
                  <td class="pr-3 py-2 text-gray-700 font-medium whitespace-nowrap">{metricData?.label ?? d.title}</td>
                  {Array.from({ length: 12 }, (_, i) => i + 1).map((monthNum) => {
                    const hasData = monthPresent(monthNum);
                    return (
                      <td class="px-0.5 py-1.5 text-center" title={monthAbbr[monthNum] + (hasData ? '' : ` — ${t.legend_pending}`)}>
                        <span class={"inline-block w-4 h-4 rounded-sm " + (hasData ? 'bg-green-400' : 'bg-gray-200')}></span>
                      </td>
                    );
                  })}
                  <td class="pl-3 py-2 text-center text-gray-500 whitespace-nowrap">{monthCount}/12</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Source Provenance -->
    <div class="bg-gray-50 rounded-xl border border-gray-200 p-4 text-xs text-gray-400">
      <p class="font-semibold text-gray-500 mb-2">{t.source_heading}</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-2">
        <div>
          <p class="text-gray-500 font-medium mb-1">{t.source_baseline_label}</p>
          <ul class="space-y-0.5">
            <li><span class="text-green-600">&bull;</span> <code>1.2-elect.xlsx</code> — Electricity Consumption (energy)</li>
            <li><span class="text-green-600">&bull;</span> <code>1.1-Water.xlsx</code> — Water Consumption (water)</li>
            <li><span class="text-green-600">&bull;</span> <code>1.6_GreenhouseGas.xlsx</code> — GHG Emissions (ghg)</li>
            <li><span class="text-green-600">&bull;</span> {t.source_departmental}</li>
          </ul>
        </div>
        <div>
          <p class="text-gray-500 font-medium mb-1">{t.source_current_label}</p>
          <ul class="space-y-0.5">
            <li><span class="text-amber-600">&bull;</span> {t.source_staff_excel}</li>
            <li><span class="text-amber-600">&bull;</span> {t.source_same_files}</li>
          </ul>
        </div>
      </div>

      <div class="border-t border-gray-200 pt-2 mt-2">
        <p class="text-gray-500 font-medium mb-1">{t.pipeline_heading}</p>
        <p>
          Excel &rarr; CSV &rarr; <code>scripts/import-dashboard-data.mjs</code> &rarr; <code>src/data/generated/{'{metric}'}.json</code> &rarr; Astro page
        </p>
        <p class="mt-1">
          {t.last_updated_label}: <time datetime="2026-06-12">2026-06-12</time> &middot;
          {t.generated_data_label}: <code>src/data/generated/energy.json</code>, <code>water.json</code>, <code>fuel.json</code>, <code>paper.json</code>, <code>waste.json</code>, <code>ghg.json</code>
        </p>
      </div>

      <div class="border-t border-gray-200 pt-2 mt-2">
        <p class="text-gray-500 font-medium mb-1">{t.reference_label}</p>
        <p>{t.reference_note} — <a href="https://goffice.mju.ac.th/" class="underline hover:text-green-600" target="_blank">goffice.mju.ac.th</a></p>
      </div>
    </div>
  </div>
</BaseLayout>
