---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import '../../../styles/global.css';
import dashboardKpi from '../../../data/dashboard-kpi.json';
import { dashboards } from '../../../data/dashboard-config';
import type { MultiYearMetric } from '../../../utils/multi-year-schema';

import energyGen from '../../../data/generated/energy.json';
import waterGen from '../../../data/generated/water.json';
import fuelGen from '../../../data/generated/fuel.json';
import paperGen from '../../../data/generated/paper.json';
import wasteGen from '../../../data/generated/waste.json';
import ghgGen from '../../../data/generated/ghg.json';
import { getLocalizedPath } from '../../../i18n/utils';
import { getDictionary } from '../../../i18n/dictionary';
import { resolveDisplayStatus, shouldShowYoy } from '../../../utils/data-status';
import { heroImageUrl, closingBannerImageUrl, resourceIconMap, resourceAccentMap } from '../../../utils/wow2-images';

import ResourcePerformanceCard from '../../../components/dashboard/ResourcePerformanceCard.astro';
import NormalizedTrendChart from '../../../components/dashboard/NormalizedTrendChart.astro';
import CategoryScoreChart from '../../../components/dashboard/CategoryScoreChart.astro';
import DataReadinessMatrix from '../../../components/dashboard/DataReadinessMatrix.astro';

const genMap: Record<string, MultiYearMetric> = {
  energy: energyGen as MultiYearMetric,
  water: waterGen as MultiYearMetric,
  fuel: fuelGen as MultiYearMetric,
  paper: paperGen as MultiYearMetric,
  waste: wasteGen as MultiYearMetric,
  ghg: ghgGen as MultiYearMetric,
};

const locale = 'en' as const;
const dict = await getDictionary(locale);
const t = dict.dashboardPage;

const monthAbbr = ['', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

const fmtCompact = (v: number) => Intl.NumberFormat('en', { notation: 'compact', maximumFractionDigits: 1 }).format(v);

const resourceLabels: Record<string, string> = {
  energy: 'Energy', water: 'Water', fuel: 'Fuel', paper: 'Paper', waste: 'Waste', ghg: 'GHG',
};

// Norm chart data
const resourcePerf: { id: string; label: string; color: string; baselineTotal: number; currentTotal: number }[] = [];
dashboards.forEach((d) => {
  const m = genMap[d.id];
  if (!m) return;
  const b = m.years[m.baselineYear.toString()];
  const c = m.years[m.currentYear.toString()];
  if (b && c && c.months.length > 0) {
    resourcePerf.push({
      id: d.id, label: resourceLabels[d.id] ?? d.title, color: d.color,
      baselineTotal: b.total, currentTotal: c.total,
    });
  }
});

// Cat scores
const catScores = dashboardKpi.kpis
  .filter((k) => k.categoryId)
  .map((kpi) => ({
    code: kpi.categoryId!,
    label: kpi.label,
    score: kpi.value ?? 0,
    trend: kpi.trend as 'up' | 'down' | 'stable' | undefined,
    href: getLocalizedPath(locale, `/categories/${kpi.categoryId!}`),
    statusText: '',
  }));

// Data readiness
const readinessResources = dashboards.map((d) => {
  const m = genMap[d.id];
  const cy = m ? m.years[m.currentYear.toString()] : null;
  return {
    id: d.id,
    label: resourceLabels[d.id] ?? d.title,
    monthsPresent: Array.from({ length: 12 }, (_, i) => cy ? cy.months.some((mo) => mo.month === i + 1) : false),
  };
});

const updatedDate = dashboardKpi.updated ?? '2026-06-12';

// ── Key Insights derived from YoY data ──────────────────────────
const insightImproved: { label: string; yoyPct: number; monthsCount: number; color: string }[] = [];
const insightAttention: { label: string; yoyPct: number; monthsCount: number; color: string }[] = [];
const insightIncomplete: { label: string; monthsCount: number; color: string }[] = [];

dashboards.forEach((d) => {
  const m = genMap[d.id];
  if (!m) return;
  const yoy = m.yoyChange;
  const current = m.years[m.currentYear.toString()];
  const monthsCount = current?.months.length ?? 0;
  const label = resourceLabels[d.id] ?? d.title;

  const isWaste = d.id === 'waste'; // recycling: up = good, down = bad

  if (yoy && current && monthsCount > 0 && yoy.direction !== 'stable') {
    const isImprovement = isWaste ? yoy.direction === 'up' : yoy.direction === 'down';
    const item = { label, yoyPct: yoy.percent, monthsCount, color: d.color };
    if (isImprovement) insightImproved.push(item);
    else insightAttention.push(item);
  }

  if (monthsCount < 12) {
    insightIncomplete.push({ label, monthsCount, color: d.color });
  }
});

// ── Highest Risk derivation ─────────────────────────────────────
const insightHighestRisk: { label: string; yoyPct: number; monthsCount: number; color: string }[] = [];
const riskCandidates = insightAttention.filter((item) => item.monthsCount >= 3);
if (riskCandidates.length > 0) {
  const maxRisk = riskCandidates.reduce((prev, curr) => (curr.yoyPct > prev.yoyPct ? curr : prev));
  insightHighestRisk.push(maxRisk);
}

// ── Category score mini-pills for hero ──────────────────────────
const catScoreMini = dashboardKpi.kpis
  .filter((k) => k.categoryId)
  .map((kpi) => ({
    code: kpi.categoryId!,
    label: kpi.label,
    score: kpi.value ?? 0,
    trend: kpi.trend as 'up' | 'down' | 'stable' | undefined,
  }));

const totalImproving = insightImproved.length;
const totalAttention = insightAttention.length;
const partialCount = insightIncomplete.length;
---

<BaseLayout title="Dashboard | แดชบอร์ด" description={t.subtitle} locale={locale}>
  <div class="p-4 max-w-6xl mx-auto">

    <!-- 1. Executive Score Hero -->
    <section class="mb-8">
      <div class="relative rounded-stitch-lg overflow-hidden text-white min-h-[320px] md:min-h-[380px] flex items-stretch">
        <!-- Hero Background Image -->
        <div class="absolute inset-0">
          <img
            src={heroImageUrl}
            alt=""
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
            aria-hidden="true"
            width="2048"
            height="1152"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-[#001a12]/90 via-[#002b1e]/75 to-[#003527]/60" aria-hidden="true"></div>
          <div class="absolute inset-0" style="background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.03) 0px, rgba(255,255,255,0.03) 1px, transparent 1px, transparent 24px), repeating-linear-gradient(90deg, rgba(255,255,255,0.03) 0px, rgba(255,255,255,0.03) 1px, transparent 1px, transparent 24px);" aria-hidden="true"></div>
        </div>

        <div class="relative z-10 p-6 md:p-8 w-full">
          <!-- Top label -->
          <p class="text-primary-fixed/40 text-[10px] uppercase tracking-[0.25em] font-bold mb-6">GREEN COMMAND CENTER</p>

          <!-- 3-Zone Layout: Gauge | Score | Context -->
          <div class="flex flex-col md:flex-row items-center md:items-start gap-6 md:gap-10">

            <!-- ZONE 1: Gauge (left, ~140px) -->
            <div class="shrink-0 flex flex-col items-center gap-2 w-[140px]">
              <svg viewBox="0 0 150 150" width="140" height="140" class="drop-shadow-lg">
                <defs>
                  <linearGradient id="gaugeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#6ffbbe"/>
                    <stop offset="100%" stop-color="#2dd4bf"/>
                  </linearGradient>
                </defs>
                <!-- Track -->
                <circle cx="75" cy="75" r="64" fill="none" stroke="rgba(255,255,255,0.10)" stroke-width="12"/>
                <!-- Progress -->
                <circle cx="75" cy="75" r="64" fill="none" stroke="url(#gaugeGrad)" stroke-width="12"
                  stroke-dasharray="402.12" stroke-dashoffset={402.12 * (1 - dashboardKpi.overallScore / 100)}
                  stroke-linecap="round" transform="rotate(-90 75 75)"
                  style="transition: stroke-dashoffset 1.2s cubic-bezier(0.16, 1, 0.3, 1);"/>
              </svg>
              <!-- Score badge below gauge -->
              <span class="px-3 py-0.5 rounded-full bg-emerald-400/20 border border-emerald-400/20 text-[10px] font-bold text-emerald-300 tracking-wide whitespace-nowrap">
                {dashboardKpi.overallScore >= 80 ? 'EXCELLENT' : dashboardKpi.overallScore >= 60 ? 'GOOD' : 'FAIR'}
              </span>
            </div>

            <!-- ZONE 2: Score (center, flex-1) -->
            <div class="flex-1 flex flex-col items-center md:items-start min-w-0">
              <div class="flex items-baseline gap-1.5">
                <span class="text-7xl md:text-8xl font-bold tracking-tight text-white leading-none">{dashboardKpi.overallScore}</span>
                <span class="text-4xl md:text-5xl font-light text-primary-fixed/30">%</span>
              </div>
              <p class="text-primary-fixed/50 text-[12px] mt-1 tracking-[0.15em] uppercase font-semibold">Overall Certification Score</p>

              <!-- Category Score Pills (max 2 rows) -->
              <div class="flex flex-wrap gap-1.5 mt-4 max-h-[3.25rem] overflow-hidden">
                {catScoreMini.map((cat) => {
                  const trendIcon = cat.trend === 'up' ? '\u2191' : cat.trend === 'down' ? '\u2193' : '\u2192';
                  const trendCls = cat.trend === 'up' ? 'text-emerald-300' : cat.trend === 'down' ? 'text-red-300' : 'text-primary-fixed/30';
                  return (
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-white/8 text-primary-fixed/60 border border-white/5 transition-colors hover:bg-white/12 hover:text-primary-fixed/80">
                      <span class="max-w-[60px] truncate">{cat.label}</span>
                      <span class="text-primary-fixed/40">{cat.score}</span>
                      <span class={trendCls}>{trendIcon}</span>
                    </span>
                  );
                })}
              </div>
            </div>

            <!-- ZONE 3: Context (right) -->
            <div class="shrink-0 flex flex-col items-end gap-3 text-right min-w-[180px]">
              <!-- Updated date -->
              <div>
                <p class="text-[10px] uppercase tracking-[0.15em] text-primary-fixed/30 font-semibold mb-0.5">Last Updated</p>
                <time datetime={updatedDate} class="text-sm font-bold text-primary-fixed/70 tabular-nums">{updatedDate}</time>
              </div>

              <!-- Taxonomy summary -->
              <p class="text-[11px] text-primary-fixed/40 leading-relaxed max-w-[200px]">{t.taxonomy_summary}</p>

              <!-- Quick Facts (compact row) -->
              <div class="flex flex-wrap gap-1.5 justify-end">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-white/8 text-emerald-300 border border-white/5">
                  <span class="w-1 h-1 rounded-full bg-emerald-400 shrink-0"></span>
                  {totalImproving} Improving
                </span>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-white/8 text-amber-300 border border-white/5">
                  <span class="w-1 h-1 rounded-full bg-amber-400 shrink-0"></span>
                  {totalAttention} Attention
                </span>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold bg-white/8 text-sky-300 border border-white/5">
                  <span class="w-1 h-1 rounded-full bg-sky-300 shrink-0"></span>
                  {partialCount}/6 Partial
                </span>
              </div>
            </div>
          </div>

          <!-- Footer caveat -->
          <p class="text-primary-fixed/30 text-[10px] mt-6 max-w-3xl leading-relaxed border-t border-white/5 pt-4">
            Executive-level Green Office readiness overview. Actual 2569 figures are partial-year and will adjust as data entry continues.
          </p>
        </div>
      </div>
    </section>

    <!-- 2. Six Resource KPI Cards -->
    <section class="mb-8">
      <div class="relative overflow-hidden rounded-stitch-lg bg-surface-container/60 border border-outline-variant/10 mb-4">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2 p-4 md:p-5">
          <div class="relative z-10">
            <h2 class="text-lg font-bold text-on-surface tracking-tight">6-Resource Overview</h2>
            <p class="text-xs text-outline-variant mt-0.5">Current year (2569) vs baseline (2568) with monthly trends</p>
          </div>
        <!-- Resource Icons decorative row -->
        <div class="flex items-center gap-3 text-[11px] text-outline-variant shrink-0">
          <span class="flex items-center gap-1">
            <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
            {totalImproving} improved
          </span>
          <span class="flex items-center gap-1">
            <span class="w-2 h-2 rounded-full bg-amber-500"></span>
            {totalAttention} attention
          </span>
          <span class="flex items-center gap-1">
            <span class="w-2 h-2 rounded-full bg-sky-400"></span>
            {partialCount}/6 partial
          </span>
        </div>
      </div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {dashboards.map((d) => {
          const m = genMap[d.id];
          const yoy = m?.yoyChange;
          const baseline = m ? m.years[m.baselineYear.toString()] : null;
          const current = m ? m.years[m.currentYear.toString()] : null;
          const displayStatus = resolveDisplayStatus(current ?? undefined);
          const showYoy = shouldShowYoy(current ?? undefined);
          const monthsCount = current?.months.length ?? 0;
          const statusLabel = monthsCount > 0 ? `${monthsCount} of 12 months` : 'Data pending';
          const partialYear = displayStatus === 'in_progress' && monthsCount < 12;
          const currentVal = current && displayStatus !== 'pending' ? fmtCompact(current.total) : 'Pending';
          const baselineVal = baseline ? fmtCompact(baseline.total) : '-';
          const trendPct = showYoy && yoy ? yoy.percent : null;
          const monthlyVals = current?.months.map((mo) => mo.value);

          return (
            <ResourcePerformanceCard
              title={resourceLabels[d.id] ?? d.title}
              href={getLocalizedPath(locale, `/dashboard/${d.id}`)}
              currentValue={currentVal}
              baselineValue={baselineVal}
              unit={m?.unit ?? ''}
              trendPct={trendPct}
              trendDir={yoy?.direction ?? 'stable'}
              monthsCompleted={monthsCount}
              color={d.color}
              monthlyValues={monthlyVals && monthlyVals.length >= 2 ? monthlyVals : undefined}
              statusLabel={statusLabel}
              partialYear={partialYear}
              iconUrl={resourceIconMap[d.id]}
              accentColor={resourceAccentMap[d.id]}
            />
          );
        })}
      </div>
    </section>

    <!-- 3. Key Insights Panel -->
    <section class="mb-8">
      <h2 class="text-lg font-bold text-on-surface tracking-tight mb-3">Executive Insights</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Improving (top-left) -->
        <div class="bg-emerald-50/60 rounded-stitch-lg border-l-4 border-emerald-500 border border-outline-variant/20 p-4">
          <div class="flex items-center gap-2.5 mb-2.5">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-500 text-white shrink-0" aria-hidden="true">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
            </span>
            <h3 class="text-sm font-bold text-emerald-800">
              Improving
              <span class="text-emerald-600/60 font-normal text-xs ml-1">({insightImproved.length})</span>
            </h3>
          </div>
          {insightImproved.length > 0 ? (
            <ul class="space-y-1.5">
              {insightImproved.map((item) => (
                <li class="flex items-center justify-between text-xs">
                  <span class="flex items-center gap-1.5 text-emerald-700 font-medium">
                    <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background-color:${item.color}`}></span>
                    {item.label}
                  </span>
                  <span class="text-emerald-600 font-bold tabular-nums">{item.yoyPct > 0 ? '+' : ''}{item.yoyPct}%</span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-xs text-emerald-600/60 italic">No clear improving trends yet</p>
          )}
          <p class="text-[10px] text-emerald-600/40 mt-2.5">Negative = reduced consumption (good)</p>
        </div>

        <!-- Needs Attention (top-right) -->
        <div class="bg-amber-50/60 rounded-stitch-lg border-l-4 border-amber-500 border border-outline-variant/20 p-4">
          <div class="flex items-center gap-2.5 mb-2.5">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-amber-500 text-white shrink-0" aria-hidden="true">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
            </span>
            <h3 class="text-sm font-bold text-amber-800">
              Needs Attention
              <span class="text-amber-600/60 font-normal text-xs ml-1">({insightAttention.length})</span>
            </h3>
          </div>
          {insightAttention.length > 0 ? (
            <ul class="space-y-1.5">
              {insightAttention.map((item) => (
                <li class="flex items-center justify-between text-xs">
                  <span class="flex items-center gap-1.5 text-amber-700 font-medium">
                    <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background-color:${item.color}`}></span>
                    {item.label}
                  </span>
                  <span class="text-amber-600 font-bold tabular-nums">+{item.yoyPct}%</span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-xs text-amber-600/60 italic">No areas of concern</p>
          )}
          <p class="text-[10px] text-amber-600/40 mt-2.5">Positive = increased consumption (monitor)</p>
        </div>

        <!-- Highest Risk (bottom-left) -->
        <div class="bg-rose-50/60 rounded-stitch-lg border-l-4 border-rose-500 border border-outline-variant/20 p-4">
          <div class="flex items-center gap-2.5 mb-2.5">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-rose-500 text-white shrink-0" aria-hidden="true">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            </span>
            <h3 class="text-sm font-bold text-rose-800">
              Highest Risk
            </h3>
          </div>
          {insightHighestRisk.length > 0 ? (
            <ul class="space-y-1.5">
              {insightHighestRisk.map((item) => (
                <li class="flex items-center justify-between text-xs">
                  <span class="flex items-center gap-1.5 text-rose-700 font-medium">
                    <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background-color:${item.color}`}></span>
                    {item.label}
                  </span>
                  <span class="text-rose-600 font-bold tabular-nums">+{item.yoyPct}%</span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-xs text-rose-600/60 italic">No resources with significant increase</p>
          )}
          <p class="text-[10px] text-rose-600/40 mt-2.5">
            Highest increase vs baseline — requires immediate review
          </p>
        </div>

        <!-- Partial-Year Data (bottom-right) -->
        <div class="bg-sky-50/60 rounded-stitch-lg border-l-4 border-sky-500 border border-outline-variant/20 p-4">
          <div class="flex items-center gap-2.5 mb-2.5">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-sky-500 text-white shrink-0" aria-hidden="true">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </span>
            <h3 class="text-sm font-bold text-sky-800">
              Partial-Year Data
              <span class="text-sky-600/60 font-normal text-xs ml-1">({insightIncomplete.length})</span>
            </h3>
          </div>
          <ul class="space-y-1.5">
            {insightIncomplete.map((item) => (
              <li class="flex items-center justify-between text-xs">
                <span class="flex items-center gap-1.5 text-sky-700 font-medium">
                  <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background-color:${item.color}`}></span>
                  {item.label}
                </span>
                <span class="text-sky-600 font-bold tabular-nums">{item.monthsCount}/12 mo</span>
              </li>
            ))}
          </ul>
          <p class="text-[10px] text-sky-600/40 mt-2.5 leading-relaxed">
            2569 data entry is still in progress. YoY comparisons reflect partial-year and may not represent full annual trends. Interpret with caution.
          </p>
        </div>
      </div>
    </section>

    <!-- 4. Baseline vs Current Comparison -->
    {resourcePerf.length > 0 && (
      <section class="mb-8">
        <div class="mb-3">
          <h2 class="text-lg font-bold text-on-surface tracking-tight mb-1">Baseline vs Current Comparison</h2>
          <p class="text-xs text-outline-variant">
            Index below 100 = reduced consumption (improvement) · {resourcePerf.length} resources compared to baseline 2568
          </p>
          <div class="flex flex-wrap gap-2 mt-2">
            {resourcePerf.map((r) => {
              const norm = r.baselineTotal > 0 ? Math.round((r.currentTotal / r.baselineTotal) * 100) : 0;
              const isImproved = norm < 100;
              return (
                <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-semibold border ${isImproved ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : 'bg-amber-50 text-amber-700 border-amber-200'}`}>
                  <span class="w-1.5 h-1.5 rounded-full shrink-0" style={`background-color:${r.color}`}></span>
                  {r.label} <span class="font-bold tabular-nums">{norm}</span>
                </span>
              );
            })}
          </div>
        </div>
      <NormalizedTrendChart
        title="Normalized Resource Performance vs Baseline (Index = 100)"
        description="Each resource compared against its own baseline set at 100. Values below 100 indicate reduced consumption (improvement), values above 100 indicate increased consumption."
        resources={resourcePerf}
        baselineLabel="Baseline 2568"
        currentLabel="Current 2569"
        locale={locale}
      />
      </section>
    )}

    <!-- 5. Category Score Visualization -->
    {catScores.length > 0 && (
      <section class="mb-8">
        <div class="mb-3">
          <h2 class="text-lg font-bold text-on-surface tracking-tight mb-1">Green Office Category Scores</h2>
          <p class="text-xs text-outline-variant">
            {catScores.length} category scores from reference system · Average {Math.round(catScores.reduce((s, c) => s + c.score, 0) / catScores.length)}%
          </p>
        </div>
      <CategoryScoreChart
        title="Green Office Certification Category Scores"
        description="Green Office certification scores by category from the reference system"
        categories={catScores}
        locale={locale}
      />
      </section>
    )}

    <!-- 6. Data Readiness Matrix -->
    <section class="mb-8">
      <h2 class="text-lg font-bold text-on-surface tracking-tight mb-3">Monthly Data Readiness</h2>
    <DataReadinessMatrix
      title="2569 Monthly Data Readiness"
      description="Monthly data entry progress for all resources. Baseline 2568 is complete across all metrics (12/12 months)."
      resources={readinessResources}
      monthLabels={monthAbbr.slice(1)}
      locale={locale}
    />
    </section>

    <!-- 7. Trust and Evidence Panel -->
    <section class="bg-surface-container rounded-stitch-lg border border-outline-variant/20 p-5 mb-6 text-xs text-outline-variant">
      <div class="flex items-center gap-2 mb-3">
        <h3 class="font-bold text-on-surface text-sm">Data Trust & Evidence</h3>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <p class="font-medium text-on-surface-variant mb-1">Data Sources</p>
          <ul class="space-y-0.5">
            <li>&bull; Staff Excel records (energy, water, fuel, paper, waste, GHG)</li>
            <li>&bull; Reference data from goffice.mju.ac.th</li>
          </ul>
        </div>
        <div>
          <p class="font-medium text-on-surface-variant mb-1">Processing Pipeline</p>
          <p class="font-mono text-[11px]">
            Excel &rarr; CSV &rarr; <code>import-dashboard-data.mjs</code> &rarr; <code>src/data/generated/</code> &rarr; Astro
          </p>
        </div>
      </div>
      <div class="mt-3 pt-3 border-t border-outline-variant/10 flex flex-wrap gap-3">
        <a href={getLocalizedPath(locale, '/documents')} class="text-primary underline hover:text-primary-container">Document Center</a>
        <a href={getLocalizedPath(locale, '/evidence')} class="text-primary underline hover:text-primary-container">Evidence Library</a>
        <a href="https://goffice.mju.ac.th/" class="text-primary underline hover:text-primary-container" target="_blank" rel="noopener">Reference Site</a>
      </div>
      <p class="mt-2 text-outline/60">Last updated: {updatedDate} · Generated data: src/data/generated/</p>
    </section>

    <!-- 8. Closing Statement with Banner -->
    <section class="mt-8 rounded-stitch-lg overflow-hidden relative min-h-[240px] flex items-center">
      <!-- Background banner image -->
      <div class="absolute inset-0">
        <img
          src={closingBannerImageUrl}
          alt=""
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
          aria-hidden="true"
          width="2048"
          height="1152"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-[#001a12]/85 via-[#002b1e]/70 to-[#003527]/60" aria-hidden="true"></div>
      </div>

      <div class="relative z-10 w-full p-8 md:p-10 text-center">
        <p class="text-lg md:text-xl font-bold text-white tracking-tight mb-2">
          Green Office 2026
        </p>
        <p class="text-sm text-white/80 mb-6 max-w-2xl mx-auto leading-relaxed">
          Show · Measure · Prove · Improve
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href={getLocalizedPath(locale, '/evidence')}
             class="inline-flex items-center justify-center gap-2 rounded-full border border-white/20 bg-white/15 px-6 py-3 text-label-sm font-medium uppercase tracking-wider text-white shadow-lg backdrop-blur-sm hover:bg-white/25 hover:-translate-y-0.5 transition"
             aria-label="Go to Evidence Library">
            Evidence Library
          </a>
          <a href={getLocalizedPath(locale, '/categories/')}
             class="inline-flex items-center justify-center gap-2 rounded-full border border-white/30 px-6 py-3 text-label-sm font-medium uppercase tracking-wider text-white/90 hover:text-white hover:bg-white/15 hover:-translate-y-0.5 transition"
             aria-label="Explore Categories">
            Explore Categories
          </a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>
