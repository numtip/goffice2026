---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import evidenceIndex from '../data/evidence-index.json';
import categoriesData from '../data/categories.json';
import EvidenceCard from '../components/evidence/EvidenceCard.astro';

const categoryMap = new Map(categoriesData.categories.map((c) => [c.id, c]));
const totalItems = evidenceIndex.items.length;
const availableItems = evidenceIndex.items.filter((i) => i.status === 'available').length;
const placeholderItems = evidenceIndex.items.filter((i) => i.status === 'placeholder').length;
const pendingItems = evidenceIndex.items.filter((i) => i.status === 'pending').length;
const reviewItems = evidenceIndex.items.filter((i) => i.status === 'in-review').length;
---

<BaseLayout title="Evidence Library">
  <div class="p-4 max-w-5xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Evidence Library</h1>
      <p class="text-gray-600 mt-2">
        Browse certification evidence items organized by Green Office category and indicator.
      </p>
    </div>

    <!-- Source Pending banner -->
    <div class="bg-amber-50 border-2 border-amber-300 rounded-xl p-5 mb-6 flex items-start gap-4 shadow-sm">
      <div class="flex-shrink-0 mt-0.5">
        <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z" />
        </svg>
      </div>
      <div>
        <h2 class="text-lg font-bold text-amber-800">Source Pending — Awaiting Approved Documents</h2>
        <p class="text-sm text-amber-700 mt-1 leading-relaxed">
          All <strong>{totalItems}</strong> evidence items are currently placeholder records. These entries define the
          certification evidence structure — indicator mappings, expected document types, and descriptions — but
          <strong>no actual source documents have been uploaded yet</strong>. Once approved office documents are indexed,
          they will replace these placeholders and the evidence library will become fully navigable.
        </p>
      </div>
    </div>

    <!-- Summary stats -->
    <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-8">
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4 text-center">
        <p class="text-2xl font-bold text-gray-900">{totalItems}</p>
        <p class="text-sm text-gray-500">Total Items</p>
      </div>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4 text-center">
        <p class="text-2xl font-bold text-green-600">{availableItems}</p>
        <p class="text-sm text-gray-500">Available</p>
      </div>
      <div class="bg-amber-50 rounded-xl border-2 border-amber-300 shadow-sm p-4 text-center col-span-2 md:col-span-1 scale-105 ring-2 ring-amber-200">
        <div class="flex items-center justify-center gap-1.5 mb-1">
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <p class="text-3xl font-bold text-amber-700">{placeholderItems}</p>
        </div>
        <p class="text-sm font-semibold text-amber-700">Placeholder</p>
        <p class="text-xs text-amber-500 mt-0.5">100% — source pending</p>
      </div>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4 text-center">
        <p class="text-2xl font-bold text-yellow-600">{pendingItems}</p>
        <p class="text-sm text-gray-500">Pending</p>
      </div>
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-4 text-center">
        <p class="text-2xl font-bold text-blue-600">{reviewItems}</p>
        <p class="text-sm text-gray-500">In Review</p>
      </div>
    </div>

    <!-- Status legend -->
    <details class="bg-white rounded-xl border border-gray-100 shadow-sm p-4 mb-6 group">
      <summary class="flex items-center gap-2 cursor-pointer text-sm font-medium text-gray-700 select-none">
        <svg class="w-4 h-4 text-gray-400 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        Status definitions
      </summary>
      <div class="mt-3 grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
        <div class="flex items-start gap-2 p-2 rounded-lg bg-amber-50 border border-amber-100">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-amber-200 text-amber-700 text-xs font-bold flex-shrink-0 mt-0.5">P</span>
          <div>
            <p class="font-semibold text-amber-800">Placeholder</p>
            <p class="text-amber-700">Record exists with title, indicator mapping, and description, but no actual source document has been uploaded. This is the initial state for all evidence items.</p>
          </div>
        </div>
        <div class="flex items-start gap-2 p-2 rounded-lg bg-blue-50 border border-blue-100">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-blue-200 text-blue-700 text-xs font-bold flex-shrink-0 mt-0.5">R</span>
          <div>
            <p class="font-semibold text-blue-800">In Review</p>
            <p class="text-blue-700">A source document has been submitted and is undergoing verification to confirm it meets certification standards.</p>
          </div>
        </div>
        <div class="flex items-start gap-2 p-2 rounded-lg bg-yellow-50 border border-yellow-100">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-yellow-200 text-yellow-700 text-xs font-bold flex-shrink-0 mt-0.5">A</span>
          <div>
            <p class="font-semibold text-yellow-800">Pending</p>
            <p class="text-yellow-700">Document has been identified but is awaiting final approval or formal indexing into the evidence library.</p>
          </div>
        </div>
        <div class="flex items-start gap-2 p-2 rounded-lg bg-green-50 border border-green-100">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-green-200 text-green-700 text-xs font-bold flex-shrink-0 mt-0.5">A</span>
          <div>
            <p class="font-semibold text-green-800">Available</p>
            <p class="text-green-700">Source document has been approved, indexed, and is ready to view and download. This is the target state for every evidence item.</p>
          </div>
        </div>
      </div>
    </details>

    <!-- Evidence items -->
    {evidenceIndex.items.length > 0 ? (
      <div class="space-y-4">
        {evidenceIndex.items.map((item) => (
          <EvidenceCard
            id={item.id}
            title={item.title}
            description={item.description}
            year={item.year}
            fileType={item.fileType}
            status={item.status}
            path={item.path}
            indicator={item.indicator}
            categoryTitle={categoryMap.get(item.categoryId)?.title}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-12 bg-white rounded-xl border border-dashed border-gray-300">
        <svg class="w-16 h-16 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <p class="text-gray-500 text-lg">No evidence items found.</p>
        <p class="text-gray-400 text-sm mt-1">Evidence items will appear here once indexed.</p>
      </div>
    )}

    <!-- Updated date -->
    <p class="text-xs text-gray-400 mt-6 text-center">
      Last updated: {evidenceIndex.updated} · Schema: v{evidenceIndex.version}
    </p>
  </div>
</BaseLayout>
