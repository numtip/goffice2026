---
import BaseLayout from '../layouts/BaseLayout.astro';
import NotFound from '../components/ui/NotFound.astro';
import { getLocale } from '../i18n/utils';

const locale = getLocale(Astro.url);

const title = locale === 'th' ? 'ไม่พบหน้าที่ต้องการ | Green Office 2026' : 'Page Not Found | Green Office 2026';
const description =
  locale === 'th'
    ? 'หน้าที่คุณค้นหาอาจถูกย้าย ลบออก หรือไม่มีอยู่ในระบบ Green Office 2026'
    : 'The page you requested may have been moved, removed, or does not exist on Green Office 2026.';
---

<BaseLayout title={title} description={description} locale={locale} noindex={true} errorPage={true}>
  <NotFound locale={locale} />
</BaseLayout>
