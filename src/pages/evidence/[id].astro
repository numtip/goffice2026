---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import evidenceIndex from '../../data/evidence-index.json';
import categoriesData from '../../data/criteria/categories.json';
import issuesData from '../../data/criteria/issues.json';
import indicatorsData from '../../data/criteria/indicators.json';
import { getLocale } from '../../i18n/utils';
import { withBase } from '../../utils/with-base';

export function getStaticPaths() {
  return evidenceIndex.items.map((item: Record<string, any>) => ({
    params: { id: item.id },
    props: { raw: item },
  }));
}

const { raw } = Astro.props;
const locale = getLocale(Astro.url);

// Build canonical lookups
const catMap = new Map(categoriesData.categories.map((c) => [c.code, c]));
const issueMap = new Map(issuesData.issues.map((i) => [i.code, i]));
const indMap = new Map(indicatorsData.indicators.map((i) => [i.code, i]));

// Normalize evidence item (handle old schema → new schema)
const categoryCodes: string[] = Array.isArray(raw.categoryCodes)
  ? raw.categoryCodes
  : raw.categoryId
    ? [raw.categoryId]
    : [];

const issueCodes: string[] = Array.isArray(raw.issueCodes) ? raw.issueCodes : [];
const indicatorCodes: string[] = Array.isArray(raw.indicatorCodes) ? raw.indicatorCodes : [];

const traceabilityLevel: string = raw.traceabilityLevel
  || (indicatorCodes.length > 0
    ? 'indicator'
    : issueCodes.length > 0
      ? 'issue'
      : categoryCodes.length > 0
        ? 'category'
        : 'unmapped');

const verification = raw.verification || { status: 'unresolved', basis: '' };
const verificationStatus = verification.status || 'unresolved';
const verificationBasis = verification.basis || '';

const isPlaceholder = raw.status === 'placeholder';

// Traceability config
const traceConfig: Record<string, { th: string; en: string; cls: string }> = {
  indicator: { th: 'เชื่อมโยงตัวชี้วัด', en: 'Indicator-linked', cls: 'bg-green-100 text-green-800 border-green-300' },
  issue: { th: 'เชื่อมโยงประเด็น', en: 'Issue-linked', cls: 'bg-blue-100 text-blue-800 border-blue-300' },
  category: { th: 'เชื่อมโยงหมวดหมู่', en: 'Category-linked', cls: 'bg-amber-100 text-amber-800 border-amber-300' },
  unmapped: { th: 'ยังไม่เชื่อมโยง', en: 'Unmapped', cls: 'bg-gray-100 text-gray-600 border-gray-300' },
};
const tCfg = traceConfig[traceabilityLevel] || traceConfig.unmapped;

// Verification config
const verConfig: Record<string, { th: string; en: string; cls: string }> = {
  verified: { th: 'ยืนยันแล้ว', en: 'Verified', cls: 'bg-green-100 text-green-800' },
  unresolved: { th: 'ยังไม่ได้รับการยืนยัน', en: 'Unresolved', cls: 'bg-yellow-100 text-yellow-800' },
  rejected: { th: 'ไม่ผ่าน', en: 'Rejected', cls: 'bg-red-100 text-red-800' },
};
const vCfg = verConfig[verificationStatus] || verConfig.unresolved;

// Resolve canonical names
const categories = categoryCodes
  .map((code: string) => catMap.get(code))
  .filter(Boolean);

const issues = issueCodes
  .map((code: string) => issueMap.get(code))
  .filter(Boolean);

const indicators = indicatorCodes
  .map((code: string) => indMap.get(code))
  .filter(Boolean);

function label(th: string, en: string): string {
  return locale === 'th' ? th : en;
}

const pageTitle = raw.title || raw.id;
---

<BaseLayout title={`${pageTitle} — ${label('คลังหลักฐาน', 'Evidence Library')}`} locale={locale}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-x-1.5 gap-y-1">
        <li>
          <a href={withBase('/')} class="text-green-600 hover:text-green-800 hover:underline transition-colors">
            {label('หน้าหลัก', 'Home')}
          </a>
        </li>
        <li class="text-gray-300 select-none" aria-hidden="true">/</li>
        <li>
          <a href={withBase('/evidence/')} class="text-green-600 hover:text-green-800 hover:underline transition-colors">
            {label('หลักฐาน', 'Evidence')}
          </a>
        </li>
        <li class="text-gray-300 select-none" aria-hidden="true">/</li>
        <li class="text-gray-700 font-medium truncate max-w-[200px]">{pageTitle}</li>
      </ol>
    </nav>

    <!-- Main card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
      <!-- Header -->
      <div class="p-6 border-b border-gray-100">
        <div class="flex flex-wrap items-center gap-2 mb-3">
          <!-- Traceability badge -->
          <span class:list={["inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border", tCfg.cls]}>
            {locale === 'th' ? tCfg.th : tCfg.en}
          </span>
          <!-- Verification badge -->
          <span class:list={["inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold", vCfg.cls]}>
            {locale === 'th' ? vCfg.th : vCfg.en}
          </span>
          <!-- File type badge -->
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gray-100 text-gray-700">
            {raw.fileType}
          </span>
          <!-- Year badge -->
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-purple-100 text-purple-700">
            {raw.year}
          </span>
          <!-- Source status -->
          {isPlaceholder ? (
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-amber-100 text-amber-700 border border-amber-300">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Source Pending
            </span>
          ) : (
            <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-green-100 text-green-700">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
              </svg>
              {label('พร้อมใช้งาน', 'Available')}
            </span>
          )}
        </div>

        <h1 class="text-2xl font-bold text-gray-900">{pageTitle}</h1>

        <p class="text-xs text-gray-400 mt-2">
          ID: {raw.id}
          {raw.updated && <span class="ml-3">{label('อัปเดต', 'Updated')}: {raw.updated}</span>}
        </p>
      </div>

      <!-- Description -->
      {raw.description && (
        <div class="p-6 border-b border-gray-100">
          <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">
            {label('คำอธิบาย', 'Description')}
          </h2>
          <p class="text-gray-800 leading-relaxed">{raw.description}</p>
        </div>
      )}

      <!-- Linked categories -->
      <div class="p-6 border-b border-gray-100">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
          {label('หมวดหมู่ที่เชื่อมโยง', 'Linked Categories')}
        </h2>
        {categories.length > 0 ? (
          <ul class="space-y-2">
            {categories.map((cat: any) => (
              <li>
                <a
                  href={withBase(`/categories/${cat.code}/`)}
                  class="inline-flex items-center gap-2 text-green-600 hover:text-green-800 hover:underline transition-colors"
                >
                  <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                  </svg>
                  <span>{label(cat.title.th, cat.title.en)} ({cat.code})</span>
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <p class="text-gray-400 italic">{label('ไม่มี', 'None')}</p>
        )}
      </div>

      <!-- Linked issues -->
      {issueCodes.length > 0 && (
        <div class="p-6 border-b border-gray-100">
          <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
            {label('ประเด็นที่เชื่อมโยง', 'Linked Issues')}
          </h2>
          {issues.length > 0 ? (
            <ul class="space-y-2">
              {issues.map((issue: any) => (
                <li class="text-gray-800 text-sm">
                  <span class="font-medium">{issue.code}:</span> {label(issue.title.th, issue.title.en)}
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-gray-400 italic">{label('ไม่มีข้อมูลประเด็น', 'No issue data')}</p>
          )}
        </div>
      )}

      <!-- Linked indicators -->
      {indicatorCodes.length > 0 && (
        <div class="p-6 border-b border-gray-100">
          <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
            {label('ตัวชี้วัดที่เชื่อมโยง', 'Linked Indicators')}
          </h2>
          {indicators.length > 0 ? (
            <ul class="space-y-2">
              {indicators.map((ind: any) => (
                <li>
                  <a
                    href={withBase(`/indicators/${ind.code}/`)}
                    class="inline-flex items-center gap-2 text-green-600 hover:text-green-800 hover:underline transition-colors"
                  >
                    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                    <span>{label(ind.title.th, ind.title.en)} ({ind.code})</span>
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-gray-400 italic">{label('ไม่มีข้อมูลตัวชี้วัด', 'No indicator data')}</p>
          )}
        </div>
      )}

      <!-- Verification details -->
      <div class="p-6 border-b border-gray-100">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
          {label('สถานะการยืนยัน', 'Verification Status')}
        </h2>
        <div class="flex items-center gap-2 mb-2">
          <span class:list={["inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium", vCfg.cls]}>
            {locale === 'th' ? vCfg.th : vCfg.en}
          </span>
        </div>
        {verificationBasis ? (
          <p class="text-sm text-gray-600 mt-1">
            <span class="font-medium">{label('พื้นฐานการยืนยัน', 'Verification Basis')}:</span> {verificationBasis}
          </p>
        ) : verificationStatus === 'unresolved' ? (
          <p class="text-sm text-amber-600 mt-1 italic">
            {label('ยังไม่ได้รับการยืนยัน', 'Not yet verified')}
          </p>
        ) : (
          <p class="text-sm text-gray-400 mt-1 italic">
            {label('ไม่มี', 'None')}
          </p>
        )}
      </div>

      <!-- Source section -->
      <div class="p-6">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">
          {label('ไฟล์ต้นฉบับ', 'Source Document')}
        </h2>
        {isPlaceholder ? (
          <div class="flex items-center gap-3 p-4 rounded-lg bg-amber-50 border border-amber-200">
            <svg class="w-6 h-6 text-amber-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-amber-800">
                {label('ยังไม่มีไฟล์ต้นฉบับสำหรับเปิดดู', 'No source file available for viewing')}
              </p>
              <p class="text-xs text-amber-600 mt-0.5">
                {label('เอกสารต้นฉบับจะถูกเพิ่มเมื่อได้รับการอนุมัติ', 'Source documents will be added upon approval')}
              </p>
            </div>
          </div>
        ) : (
          <div class="flex items-center gap-3 p-4 rounded-lg bg-green-50 border border-green-200">
            <svg class="w-6 h-6 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
            <div>
              <p class="text-sm font-medium text-green-800">
                <a href={withBase(raw.path)} class="underline decoration-green-400 underline-offset-2 hover:text-green-900">
                  {raw.path.split('/').pop() || raw.path}
                </a>
              </p>
              <p class="text-xs text-green-600 mt-0.5">
                {label('ไฟล์ต้นฉบับ', 'Source file')} — {raw.fileType}
              </p>
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Back link -->
    <div class="mt-6">
      <a
        href={withBase('/evidence/')}
        class="inline-flex items-center gap-1.5 text-sm font-medium text-green-600 hover:text-green-800 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        {label('กลับไปยังคลังหลักฐาน', 'Back to Evidence Library')}
      </a>
    </div>
  </div>
</BaseLayout>
