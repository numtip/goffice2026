---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import dashboardKpi from '../data/dashboard-kpi.json';
import { dashboards } from '../data/dashboard-config';

const trendLabel: Record<string, string> = {
  up: '\u2191',
  down: '\u2193',
  stable: '\u2192',
};
const trendColors: Record<string, string> = {
  up: 'text-green-500',
  down: 'text-red-500',
  stable: 'text-gray-400',
};
---

<BaseLayout title="Dashboard">
  <div class="p-4 max-w-5xl mx-auto">
    <!-- Header -->
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">Green Office Dashboard</h1>
      <p class="text-gray-600 mt-1">
        Overall certification progress, resource consumption monitoring, and per-category dashboards.
      </p>
      <p class="text-xs text-gray-400 mt-1">
        Reference: <a href="https://goffice.mju.ac.th/" class="underline hover:text-green-600" target="_blank">goffice.mju.ac.th</a>
        &middot; Updated: {dashboardKpi.updated}
      </p>
    </div>

    <!-- Overall Score -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
      <p class="text-sm text-gray-500 mb-1">Overall Certification Score (Green Score)</p>
      <p class="text-4xl font-bold text-green-600">{dashboardKpi.overallScore}<span class="text-2xl">%</span></p>
      <p class="text-xs text-gray-400 mt-2">
        7 หมวดหมู่ &middot; 24 ประเด็น &middot; 65 ตัวชี้วัด
        &middot; <a href="https://goffice.mju.ac.th/green-office-7cat-2568" class="underline hover:text-green-600" target="_blank">View on reference site</a>
      </p>
    </div>

    <!-- Resource Monitoring (Executive Dashboard style) -->
    <h2 class="text-lg font-semibold text-gray-800 mb-3">Resource Consumption Monitoring</h2>
    <p class="text-sm text-gray-500 mb-3">Based on Green Office หมวดที่ 3 การใช้ทรัพยากรและพลังงาน — aligned with <a href="https://goffice.mju.ac.th/images/data/executive/unified-executive-dashboard.html" class="underline hover:text-green-600" target="_blank">Executive Dashboard</a></p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
      {dashboards.map((d) => (
        <a
          href={`/dashboard/${d.id}`}
          class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md hover:border-green-200 transition-all group"
        >
          <div class="flex items-start justify-between mb-2">
            <h3 class="font-semibold text-green-700 group-hover:text-green-800">{d.title}</h3>
            <span
              class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium shrink-0 ml-3"
              style={`background-color: ${d.color}15; color: ${d.color}`}
            >
              {d.kpiScore ?? '-'}{d.kpiUnit ?? '%'}
            </span>
          </div>
          <p class="text-sm text-gray-600 line-clamp-2">{d.description}</p>
          <div class="mt-2 flex items-center gap-2 text-xs">
            {d.trend && (
              <span class={trendColors[d.trend] || 'text-gray-400'}>
                {trendLabel[d.trend] ?? ''} {d.trend}
              </span>
            )}
            {d.categoryId && (
              <span class="text-gray-400">
                &middot; {dashboards.find((x) => x.id === d.id)?.categoryId ? 'cat' + d.categoryId.slice(3) : ''}
              </span>
            )}
          </div>
        </a>
      ))}
    </div>

    <!-- Certification Category Scores -->
    <h2 class="text-lg font-semibold text-gray-800 mb-3">Certification Category Scores</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      {dashboardKpi.kpis.filter((k) => k.categoryId).map((kpi) => {
        const catId = kpi.categoryId!;
        const dash = dashboards.find((d) => d.id === kpi.id);
        return (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <p class="text-sm text-gray-500">{kpi.label}</p>
            <p class="text-2xl font-bold text-green-600 mt-1">
              {kpi.value}{kpi.unit}
              {kpi.trend && (
                <span class={"text-base ml-1 " + (trendColors[kpi.trend] || 'text-gray-400')}>
                  {trendLabel[kpi.trend] ?? ''}
                </span>
              )}
            </p>
            <p class="text-xs text-gray-400 mt-1">{kpi.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <a href={`/categories/${catId}`} class="text-xs text-green-600 underline hover:text-green-800">
                Category {catId.replace('cat', '')}
              </a>
              {dash ? (
                <a href={`/dashboard/${dash.id}`} class="text-xs text-blue-600 underline hover:text-blue-800">
                  Dashboard &rarr;
                </a>
              ) : null}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Reference attribution -->
    <div class="bg-gray-50 rounded-xl border border-gray-200 p-4 text-xs text-gray-400">
      <p class="font-medium text-gray-500 mb-1">Source Reference</p>
      <p>Dashboard structure and KPI terminology adapted from <a href="https://goffice.mju.ac.th/" class="underline hover:text-green-600" target="_blank">goffice.mju.ac.th</a> — Green Office Platform, Maejo University.</p>
      <p class="mt-1">Resource consumption patterns based on real 2568 (2025) data: Electricity 218,459 kWh &middot; Water 66,700 m&sup3; &middot; Fuel 22,928 L &middot; Paper 2,198 kg &middot; Waste 4,381 kg &middot; GHG 241 tCO₂e.</p>
    </div>
  </div>
</BaseLayout>
