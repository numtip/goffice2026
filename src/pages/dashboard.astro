---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
import dashboardKpi from '../data/dashboard-kpi.json';
import { dashboards } from '../data/dashboard-config';
import type { MultiYearMetric } from '../utils/multi-year-schema';

import energyGen from '../data/generated/energy.json';
import waterGen from '../data/generated/water.json';
import fuelGen from '../data/generated/fuel.json';
import paperGen from '../data/generated/paper.json';
import wasteGen from '../data/generated/waste.json';
import ghgGen from '../data/generated/ghg.json';
import { withBase } from '../utils/with-base';

const genMap: Record<string, MultiYearMetric> = {
  energy: energyGen as MultiYearMetric,
  water: waterGen as MultiYearMetric,
  fuel: fuelGen as MultiYearMetric,
  paper: paperGen as MultiYearMetric,
  waste: wasteGen as MultiYearMetric,
  ghg: ghgGen as MultiYearMetric,
};

const trendLabel: Record<string, string> = {
  up: '\u2191',
  down: '\u2193',
  stable: '\u2192',
};
const trendColors: Record<string, string> = {
  up: 'text-green-500',
  down: 'text-red-500',
  stable: 'text-gray-400',
};

function yoyColor(percent: number): string {
  if (percent <= -5) return 'text-green-600';
  if (percent >= 5) return 'text-red-600';
  return 'text-yellow-600';
}

function statusBadge(status: string): string {
  if (status === 'complete') return 'bg-green-100 text-green-800';
  if (status === 'in_progress') return 'bg-yellow-100 text-yellow-800';
  return 'bg-gray-100 text-gray-500';
}
---

<BaseLayout title="Dashboard">
  <div class="p-4 max-w-5xl mx-auto">
    <!-- Header -->
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-gray-900">Green Office Dashboard</h1>
      <p class="text-gray-600 mt-1">
        Multi-year monitoring: 2568 baseline &middot; 2569 current operational data.
      </p>
      <p class="text-xs text-gray-400 mt-1">
        Reference: <a href="https://goffice.mju.ac.th/" class="underline hover:text-green-600" target="_blank">goffice.mju.ac.th</a>
        &middot; Updated: {dashboardKpi.updated}
      </p>
    </div>

    <!-- Overall Score -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-6">
      <p class="text-sm text-gray-500 mb-1">Overall Certification Score (Green Score)</p>
      <p class="text-4xl font-bold text-green-600">{dashboardKpi.overallScore}<span class="text-2xl">%</span></p>
      <p class="text-xs text-gray-400 mt-2">
        7 หมวดหมู่ &middot; 24 ประเด็น &middot; 65 ตัวชี้วัด
        &middot; <a href="https://goffice.mju.ac.th/green-office-7cat-2568" class="underline hover:text-green-600" target="_blank">View on reference site</a>
      </p>
    </div>

    <!-- Multi-Year Resource Monitoring -->
    <h2 class="text-lg font-semibold text-gray-800 mb-3">2568 &rarr; 2569 Year-over-Year Comparison</h2>
    <p class="text-sm text-gray-500 mb-3">
      2568 = Baseline (complete) &middot; 2569 = Current operational year (data entry in progress)
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
      {dashboards.map((d) => {
        const m = genMap[d.id];
        const yoy = m?.yoyChange;
        const baseline = m ? m.years[m.baselineYear.toString()] : null;
        const current = m ? m.years[m.currentYear.toString()] : null;
        return (
          <a
            href={withBase(`/dashboard/${d.id}`)}
            class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md hover:border-green-200 transition-all group"
          >
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-semibold text-green-700 group-hover:text-green-800">{d.title}</h3>
              {current && (
                <span class={"inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium shrink-0 ml-3 " + statusBadge(current.dataStatus)}>
                  {current.months.length}/12
                </span>
              )}
            </div>

            <p class="text-sm text-gray-600 line-clamp-2">{d.description}</p>

            {m && baseline && current ? (
              <div class="mt-3 grid grid-cols-2 gap-2 text-xs border-t border-gray-50 pt-3">
                <div>
                  <span class="text-gray-400 block">{m.baselineYear} Total</span>
                  <span class="font-medium text-gray-800">{Intl.NumberFormat().format(baseline.total)}{m.unit}</span>
                </div>
                <div>
                  <span class="text-gray-400 block">{m.currentYear} Total</span>
                  <span class="font-medium text-gray-800">{Intl.NumberFormat().format(current.total)}{m.unit}</span>
                </div>
                <div class="col-span-2 mt-1">
                  <span class="text-gray-400">YoY: </span>
                  <span class={yoyColor(yoy.percent)}>
                    {yoy.percent > 0 ? '+' : ''}{yoy.percent}% {trendLabel[yoy.direction]}
                  </span>
                </div>
              </div>
            ) : (
              <div class="mt-3 text-xs text-gray-400 italic border-t border-gray-50 pt-3">
                Data pending entry
              </div>
            )}
          </a>
        );
      })}
    </div>

    <!-- Certification Category Scores -->
    <h2 class="text-lg font-semibold text-gray-800 mb-3">Certification Category Scores</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      {dashboardKpi.kpis.filter((k) => k.categoryId).map((kpi) => {
        const catId = kpi.categoryId!;
        const dash = dashboards.find((d) => d.id === kpi.id);
        return (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 hover:shadow-md transition-shadow">
            <p class="text-sm text-gray-500">{kpi.label}</p>
            <p class="text-2xl font-bold text-green-600 mt-1">
              {kpi.value}{kpi.unit}
              {kpi.trend && (
                <span class={"text-base ml-1 " + (trendColors[kpi.trend] || 'text-gray-400')}>
                  {trendLabel[kpi.trend] ?? ''}
                </span>
              )}
            </p>
            <p class="text-xs text-gray-400 mt-1">{kpi.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <a href={withBase(`/categories/${catId}`)} class="text-xs text-green-600 underline hover:text-green-800">
                Category {catId.replace('cat', '')}
              </a>
              {dash ? (
                <a href={withBase(`/dashboard/${dash.id}`)} class="text-xs text-blue-600 underline hover:text-blue-800">
                  Dashboard &rarr;
                </a>
              ) : null}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Data Completeness Summary -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-4 mb-6">
      <h3 class="text-sm font-semibold text-gray-700 mb-2">Data Completeness</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        {Object.entries(genMap).map(([, m]) => {
          const c = m.years[m.currentYear.toString()];
          return (
            <div class="text-xs">
              <span class="font-medium text-gray-700">{m.label}</span>
              <div class="mt-1 flex items-center gap-1">
                <span class={"inline-block w-2 h-2 rounded-full " + (c?.dataStatus === 'complete' ? 'bg-green-400' : 'bg-yellow-400')}></span>
                <span class="text-gray-500">{c?.months.length ?? 0}/12 months</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Reference attribution -->
    <div class="bg-gray-50 rounded-xl border border-gray-200 p-4 text-xs text-gray-400">
      <p class="font-medium text-gray-500 mb-1">Source Reference</p>
      <p>Dashboard structure and KPI terminology adapted from <a href="https://goffice.mju.ac.th/" class="underline hover:text-green-600" target="_blank">goffice.mju.ac.th</a> — Green Office Platform, Maejo University.</p>
      <p class="mt-1">2568 baseline from: <code>1.1-Water.xlsx</code>, <code>12-elect.xlsx</code>, <code>1.5_GreenhouseGas.xlsx</code> and departmental records. 2569 current data from ongoing staff Excel submissions.</p>
    </div>
  </div>
</BaseLayout>
