---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
---

<BaseLayout title="Category 5: Indoor Environmental Quality">
  <div class="p-4 max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Indoor Environmental Quality</h1>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Purpose</h2>
      <p>Maintain healthy indoor environments for occupants through air quality and comfort standards.</p>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Key Criteria Summary</h2>
      <ul class="list-disc list-inside">
        <li>Monitor indoor air quality parameters.</li>
        <li>Maintain ventilation and thermal comfort standards.</li>
        <li>Use low-emission materials and cleaning products.</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Evidence Checklist (placeholder)</h2>
      <ul class="list-disc list-inside">
        <li>IAQ monitoring reports</li>
        <li>Ventilation maintenance logs</li>
        <li>Green cleaning product inventory</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Relevant Documents</h2>
      <a href="/documents/cat5" class="text-green-600 underline">View Documents</a>
    </section>
  </div>
</BaseLayout>
