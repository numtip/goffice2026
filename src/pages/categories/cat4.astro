---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
---

<BaseLayout title="Category 4: GHG Emissions">
  <div class="p-4 max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Greenhouse Gas Emissions</h1>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Purpose</h2>
      <p>Measure, report, and reduce greenhouse gas emissions across operations.</p>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Key Criteria Summary</h2>
      <ul class="list-disc list-inside">
        <li>Establish GHG inventory for Scope 1 and Scope 2 emissions.</li>
        <li>Identify emission reduction opportunities.</li>
        <li>Report progress against reduction targets.</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Evidence Checklist (placeholder)</h2>
      <ul class="list-disc list-inside">
        <li>GHG inventory reports</li>
        <li>Emission factor documentation</li>
        <li>Carbon reduction project records</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Relevant Documents</h2>
      <a href="/documents/cat4" class="text-green-600 underline">View Documents</a>
    </section>
  </div>
</BaseLayout>
