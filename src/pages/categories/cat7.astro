---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
---

<BaseLayout title="Category 7: Innovation">
  <div class="p-4 max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Innovation and Additional Features</h1>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Purpose</h2>
      <p>Demonstrate leadership through innovative green initiatives beyond core criteria.</p>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Key Criteria Summary</h2>
      <ul class="list-disc list-inside">
        <li>Implement pilot projects for emerging sustainability practices.</li>
        <li>Engage staff in green innovation programs.</li>
        <li>Share best practices with external stakeholders.</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Evidence Checklist (placeholder)</h2>
      <ul class="list-disc list-inside">
        <li>Innovation project proposals</li>
        <li>Staff engagement activity records</li>
        <li>External recognition or partnership documents</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Relevant Documents</h2>
      <a href="/documents/cat7" class="text-green-600 underline">View Documents</a>
    </section>
  </div>
</BaseLayout>
