---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import categoriesData from '../../data/categories.json';

export function getStaticPaths() {
  return categoriesData.categories.map((category) => ({
    params: { id: category.id },
    props: { category },
  }));
}

const { category } = Astro.props;
const headline = category.headline ?? category.title;
---

<BaseLayout title={`Category ${category.number}: ${category.title}`}>
  <div class="p-4 max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">{headline}</h1>
    <p class="text-sm text-gray-500 mb-6">Score: {category.score}%</p>

    <section class="mb-6">
      <h2 class="text-xl font-semibold">Purpose</h2>
      <p>{category.purpose}</p>
    </section>

    <section class="mb-6">
      <h2 class="text-xl font-semibold">Key Criteria Summary</h2>
      <ul class="list-disc list-inside">
        {category.criteriaSummary.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="mb-6">
      <h2 class="text-xl font-semibold">Evidence Checklist (placeholder)</h2>
      <ul class="list-disc list-inside">
        {category.evidenceChecklist.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="mb-6">
      <h2 class="text-xl font-semibold">Relevant Documents</h2>
      <a href={`/documents/${category.id}`} class="text-green-600 underline">View Documents</a>
    </section>
  </div>
</BaseLayout>
