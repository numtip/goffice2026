---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
---

<BaseLayout title="Category 6: Transportation">
  <div class="p-4 max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Transportation</h1>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Purpose</h2>
      <p>Promote sustainable commuting and reduce transport-related environmental impact.</p>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Key Criteria Summary</h2>
      <ul class="list-disc list-inside">
        <li>Encourage public transit, cycling, and carpooling.</li>
        <li>Track fleet fuel consumption and emissions.</li>
        <li>Support remote work and virtual meetings where appropriate.</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Evidence Checklist (placeholder)</h2>
      <ul class="list-disc list-inside">
        <li>Commute survey results</li>
        <li>Fleet fuel usage records</li>
        <li>Sustainable transport policy documents</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Relevant Documents</h2>
      <a href="/documents/cat6" class="text-green-600 underline">View Documents</a>
    </section>
  </div>
</BaseLayout>
