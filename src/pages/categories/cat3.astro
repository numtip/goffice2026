---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
---

<BaseLayout title="Category 3: Waste Management">
  <div class="p-4 max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Waste Management</h1>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Purpose</h2>
      <p>Minimize waste generation and maximize recycling and responsible disposal.</p>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Key Criteria Summary</h2>
      <ul class="list-disc list-inside">
        <li>Implement waste segregation and recycling programs.</li>
        <li>Track waste volumes by type and disposal route.</li>
        <li>Set reduction targets aligned with GREENOFFICE_2569.</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Evidence Checklist (placeholder)</h2>
      <ul class="list-disc list-inside">
        <li>Waste audit reports</li>
        <li>Recycling vendor contracts</li>
        <li>Monthly waste tracking data</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Relevant Documents</h2>
      <a href="/documents/cat3" class="text-green-600 underline">View Documents</a>
    </section>
  </div>
</BaseLayout>
