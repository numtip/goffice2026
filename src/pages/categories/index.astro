---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import { getLocale } from '../../i18n/utils';
import CategoryCard from '../../components/categories/CategoryCard.astro';
import categoryData from '../../data/criteria/categories.json';
import issueData from '../../data/criteria/issues.json';
import indicatorData from '../../data/criteria/indicators.json';

const locale = getLocale(Astro.url);
const categories = categoryData.categories;
const issues = issueData.issues;
const indicators = indicatorData.indicators;

const issuesByCategory = new Map<string, typeof issues>();
const indicatorsByCategory = new Map<string, typeof indicators>();

for (const cat of categories) {
  const catIssues = issues.filter((i) => i.categoryCode === cat.code);
  issuesByCategory.set(cat.code, catIssues);

  const issueIds = new Set(catIssues.map((i) => i.id));
  indicatorsByCategory.set(
    cat.code,
    indicators.filter((ind) => issueIds.has(ind.issueCode)),
  );
}

const pageTitle = locale === 'th' ? 'หมวดหมู่ | Categories' : 'Categories | หมวดหมู่';
const heading = locale === 'th' ? 'หมวดหมู่เกณฑ์สำนักงานสีเขียว' : 'Green Office Criteria Categories';
const subtitle = locale === 'th'
  ? 'สำรวจหมวดหมู่การประเมิน 7 หมวดหมู่ตามเกณฑ์สำนักงานสีเขียว (Green Office) ประกอบด้วยประเด็นและตัวชี้วัดที่เกี่ยวข้อง'
  : 'Explore the 7 assessment categories of the Green Office criteria, including their issues and indicators';

const weightedCategories = categories.filter((c) => c.code !== 'cat7');
const separateCategory = categories.find((c) => c.code === 'cat7');
---

<BaseLayout title={pageTitle} description={subtitle} locale={locale}>
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <header class="mb-10 text-center">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        {heading}
      </h1>
      <p class="mt-3 text-base text-gray-500 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </header>

    <!-- Weighted Categories (cat1-cat6) -->
    <section class="mb-12">
      <h2 class="mb-6 text-lg font-semibold text-gray-700">
        {locale === 'th' ? 'หมวดหมู่ที่มีคะแนนถ่วงน้ำหนัก' : 'Weighted Assessment Categories'}
      </h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          weightedCategories.map((cat) => {
            const issueCount = (issuesByCategory.get(cat.code) || []).length;
            const indicatorCount = (indicatorsByCategory.get(cat.code) || []).length;
            return (
              <CategoryCard
                category={cat}
                issueCount={issueCount}
                indicatorCount={indicatorCount}
                locale={locale}
              />
            );
          })
        }
      </div>
    </section>

    <!-- Separate Category (cat7) -->
    {
      separateCategory && (() => {
        const issueCount = (issuesByCategory.get(separateCategory.code) || []).length;
        const indicatorCount = (indicatorsByCategory.get(separateCategory.code) || []).length;
        return (
          <section>
            <h2 class="mb-6 text-lg font-semibold text-gray-700">
              {locale === 'th' ? 'การประเมินความต่อเนื่อง (แยกส่วน)' : 'Continuity Assessment (Separate)'}
            </h2>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              <CategoryCard
                category={separateCategory}
                issueCount={issueCount}
                indicatorCount={indicatorCount}
                locale={locale}
                isSeparate={true}
              />
              <div class="rounded-xl border border-dashed border-amber-200 bg-amber-50/30 p-5 text-sm text-amber-800">
                <p class="font-semibold mb-2">
                  {locale === 'th' ? 'สำหรับหน่วยงานที่ขอต่ออายุหรือขอยกระดับการรับรอง' : 'For renewal or upgrade certification only'}
                </p>
                <p class="text-amber-700">
                  {locale === 'th'
                    ? 'หมวดที่ 7 ประเมินแยกต่างหากจากหมวด 1–6 โดยมีน้ำหนักภายใน: ประเด็น 7.1 (40%) และประเด็น 7.2 (60%)'
                    : 'Category 7 is assessed independently from Categories 1–6 with internal weighting: Issue 7.1 (40%) and Issue 7.2 (60%)'}
                </p>
              </div>
            </div>
          </section>
        );
      })()
    }

    <!-- Stats summary -->
    <section class="mt-12 rounded-xl border border-gray-100 bg-gray-50/50 p-6">
      <h3 class="text-sm font-semibold text-gray-700 mb-3">
        {locale === 'th' ? 'สรุปภาพรวม' : 'Overview'}
      </h3>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="text-center">
          <p class="text-2xl font-bold text-green-700">7</p>
          <p class="text-xs text-gray-500">{locale === 'th' ? 'หมวดหมู่' : 'Categories'}</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-green-700">{issues.length}</p>
          <p class="text-xs text-gray-500">{locale === 'th' ? 'ประเด็น' : 'Issues'}</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-green-700">{indicators.length}</p>
          <p class="text-xs text-gray-500">{locale === 'th' ? 'ตัวชี้วัด' : 'Indicators'}</p>
        </div>
        <div class="text-center">
          <p class="text-2xl font-bold text-amber-600">1</p>
          <p class="text-xs text-gray-500">{locale === 'th' ? 'แยกประเมิน' : 'Separate'}</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
