---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
import categoriesData from '../../data/categories.json';
---

<BaseLayout title="Categories">
  <div class="p-4">
    <h1 class="text-2xl font-bold mb-4">Green Office Categories</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {categoriesData.categories.map((category) => (
        <a
          href={`/categories/${category.id}`}
          class="bg-white rounded-lg shadow p-4 hover:shadow-md transition"
        >
          <h2 class="font-bold text-green-700">
            Category {category.number}: {category.title}
          </h2>
          <p class="text-sm text-gray-600">{category.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
