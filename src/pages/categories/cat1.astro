---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';
---

<BaseLayout title="Category 1: Energy Management">
  <div class="p-4 max-w-3xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Energy Management</h1>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Purpose</h2>
      <p>Reduce energy consumption and improve efficiency across facilities.</p>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Key Criteria Summary</h2>
      <ul class="list-disc list-inside">
        <li>Implement energy monitoring systems.</li>
        <li>Adopt LED lighting and efficient HVAC.</li>
        <li>Set reduction targets aligned with GREENOFFICE_2569.</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Evidence Checklist (placeholder)</h2>
      <ul class="list-disc list-inside">
        <li>Energy audit reports</li>
        <li>Metering data files</li>
        <li>Improvement project documentation</li>
      </ul>
    </section>
    <section class="mb-6">
      <h2 class="text-xl font-semibold">Relevant Documents</h2>
      <a href="/documents/cat1" class="text-green-600 underline">View Documents</a>
    </section>
  </div>
</BaseLayout>